  // QUIZ ENGINE
  function renderQuestion() {
    const currentQuestion = quizQuestions[currentQuestionIndex];
    
    // Update progress metadata
    const questionNumber = currentQuestionIndex + 1;
    const totalQuestions = quizQuestions.length;
    const progressPercent = Math.round(((questionNumber - 1) / totalQuestions) * 100);
    
    quizQuestionIndex.textContent = `Pregunta ${questionNumber} de ${totalQuestions}`;
    quizPercent.textContent = `${progressPercent}%`;
    quizProgressFill.style.width = `${progressPercent}%`;

    // Render text
    questionCategory.textContent = currentQuestion.categoryName;
    questionText.textContent = currentQuestion.question;

    // Render options
    optionsList.innerHTML = "";
    currentQuestion.options.forEach(opt => {
      const optionCard = document.createElement("div");
      optionCard.className = "option-card";
      if (userAnswers[currentQuestion.id] === opt.val) {
        optionCard.classList.add("selected");
      }

      optionCard.innerHTML = `
        <div class="option-letter">${opt.val}</div>
        <span class="option-text-span">${opt.text}</span>
      `;

      optionCard.addEventListener("click", () => {
        // Remove selection from others
        document.querySelectorAll(".option-card").forEach(el => el.classList.remove("selected"));
        optionCard.classList.add("selected");
        
        // Save answer
        userAnswers[currentQuestion.id] = opt.val;
        
        // Enable next button
        btnNext.removeAttribute("disabled");
      });

      optionsList.appendChild(optionCard);
    });

    // Add "No sé la respuesta" option
    const dontKnowCard = document.createElement("div");
    dontKnowCard.className = "option-card option-dont-know";
    if (userAnswers[currentQuestion.id] === "NOSAE") {
      dontKnowCard.classList.add("selected");
    }

    dontKnowCard.innerHTML = `
      <div class="option-letter">?</div>
      <span class="option-text-span" style="color: var(--text-muted); font-style: italic;">No sé la respuesta a esta pregunta / Saltar</span>
    `;

    dontKnowCard.addEventListener("click", () => {
      document.querySelectorAll(".option-card").forEach(el => el.classList.remove("selected"));
      dontKnowCard.classList.add("selected");
      userAnswers[currentQuestion.id] = "NOSAE";
      btnNext.removeAttribute("disabled");
    });

    optionsList.appendChild(dontKnowCard);

    // Update navigation button states
    if (currentQuestionIndex === 0) {
      btnPrev.setAttribute("disabled", "true");
    } else {
      btnPrev.removeAttribute("disabled");
    }

    // Next button state
    if (userAnswers[currentQuestion.id]) {
      btnNext.removeAttribute("disabled");
    } else {
      btnNext.setAttribute("disabled", "true");
    }

    // Change next button text on final question
    if (currentQuestionIndex === totalQuestions - 1) {
      btnNext.innerHTML = `Finalizar Evaluación <span class="btn-icon">🏁</span>`;
    } else {
      btnNext.innerHTML = `Siguiente <span class="btn-icon">➡️</span>`;
    }
  }

  // NAVIGATION EVENT LISTENERS
  btnPrev.addEventListener("click", () => {
    if (currentQuestionIndex > 0) {
      currentQuestionIndex--;
      renderQuestion();
    }
  });

  btnNext.addEventListener("click", () => {
    const totalQuestions = quizQuestions.length;
    
    if (currentQuestionIndex < totalQuestions - 1) {
      currentQuestionIndex++;
      renderQuestion();
    } else {
      // Finished!
      processResults();
    }
  });

  // PROCESSING AND CALCULATING RESULTS
  function processResults() {
    stepQuiz.classList.remove("active");
    stepLoading.classList.add("active");

    const loadingMessages = [
      "Analizando respuestas de normativa NAG 200...",
      "Calculando caudales e instalación hídrica...",
      "Evaluando conocimientos en calderas y losa radiante...",
      "Calificando la matriz de seguridad industrial...",
      "Sincronizando reporte de competencias técnicas...",
      "Registrando veredicto de ingreso..."
    ];

    let msgIndex = 0;
    const interval = setInterval(() => {
      if (msgIndex < loadingMessages.length) {
        loaderMsg.textContent = loadingMessages[msgIndex];
        msgIndex++;
      }
    }, 600);

    // Compute metrics
    let correctCount = 0;
    let categoryScores = {
      normativa: { correct: 0, total: 5 },
      tecnica: { correct: 0, total: 5 },
      planos: { correct: 0, total: 5 },
      seguridad: { correct: 0, total: 5 }
    };

    let incorrectList = [];

    quizQuestions.forEach(q => {
      const selected = userAnswers[q.id];
      const isCorrect = (selected === q.answer);
      
      if (isCorrect) {
        correctCount++;
        categoryScores[q.category].correct++;
      } else {
        // Log details of incorrect answers for Regla de Oro
        const selectedOptionText = q.options.find(o => o.val === selected)?.text || "No respondida";
        const correctOptionText = q.options.find(o => o.val === q.answer).text;

        incorrectList.push({
          question: q.question,
          categoryName: q.categoryName,
          selectedVal: selected || "N/A",
          selectedText: selectedOptionText,
          correctVal: q.answer,
          correctText: correctOptionText,
          explanation: q.explanation
        });
      }
    });

    const score = Math.round((correctCount / quizQuestions.length) * 100);

    // Categories boundaries
    let category = "Ayudante";
    if (score > 40 && score <= 70) {
      category = "Oficial";
    } else if (score > 70 && score <= 90) {
      category = "Oficial Especializado";
    } else if (score > 90) {
      category = "Oficial Especializado Matriculado / Responsable Técnico";
    }

    // Verdict
    let verdict = "no-apto";
    let verdictText = "NO APTO PARA OBRA";
    let verdictIcon = "❌";
    let friendlyExplanation = "";

    if (score >= 50 && score <= 70) {
      verdict = "apto-supervision";
      verdictText = "APTO CON SUPERVISIÓN";
      verdictIcon = "⚠️";
      friendlyExplanation = `
        <strong>¡Hola ${candidateData.nombre}!</strong> Completaste el cuestionario y has demostrado tener los conocimientos prácticos necesarios para una posición de <strong>Oficial</strong> en obra. 
        <br><br>
        Tu base técnica es buena, pero observamos algunos puntos débiles en reglamentaciones de la norma NAG 200 o dimensionamiento hídrico. En N3i cuidamos mucho la seguridad y calidad de nuestro equipo, por lo cual tu ingreso sugerido sería <strong>bajo la supervisión inicial</strong> de un Oficial Especializado. ¡Te animamos a leer con atención el feedback educativo que preparamos para vos al final de esta página para seguir creciendo profesionalmente!
      `;
    } else if (score > 70) {
      verdict = "apto";
      verdictText = "APTO PARA OBRA";
      verdictIcon = "✅";
      friendlyExplanation = `
        <strong>¡Excelente desempeño, ${candidateData.nombre}!</strong> Has superado con creces las expectativas de nuestra evaluación técnica, clasificando como <strong>${category}</strong>.
        <br><br>
        Demostrás un dominio sólido tanto de la teoría de reglamentos de gas (NAG 200) y plomería como de las mejores prácticas de montaje de calderas, losa radiante, lectura de planos y, sobre todo, normas de seguridad industrial en planta. Tu perfil tiene la autonomía y la solvencia necesarias para integrarse directamente a los proyectos más exigentes de N3i. ¡Felicitaciones!
      `;
    } else {
      verdict = "no-apto";
      verdictText = "NO APTO (REQUIERE INDUCCIÓN)";
      verdictIcon = "❌";
      friendlyExplanation = `
        <strong>Gracias por tu tiempo, ${candidateData.nombre}.</strong> Tras procesar la evaluación técnica, observamos que tu puntaje no alcanza los mínimos requeridos para desempeñarte de forma autónoma en obra como oficial técnico de N3i, clasificando en la categoría de <strong>Ayudante</strong>.
        <br><br>
        En nuestro rubro la seguridad industrial y el cumplimiento técnico estricto son vida o muerte. Te recomendamos revisar minuciosamente las justificaciones técnicas en la sección <strong>"Regla de Oro"</strong> al final de esta página. Te servirán como una guía de estudio detallada para capacitarte y volver a postularte con nosotros en el futuro.
      `;
    }

    // Calculate competencies percentages
    const compNormativa = Math.round((categoryScores.normativa.correct / categoryScores.normativa.total) * 100);
    const compTecnica = Math.round((categoryScores.tecnica.correct / categoryScores.tecnica.total) * 100);
    const compPlanos = Math.round((categoryScores.planos.correct / categoryScores.planos.total) * 100);
    const compSeguridad = Math.round((categoryScores.seguridad.correct / categoryScores.seguridad.total) * 100);

    // Build plain text summary of incorrect answers for the email
    let emailDetail = "";
    if (incorrectList.length === 0) {
      emailDetail = "¡El candidato respondió todas las preguntas de manera correcta!";
    } else {
      incorrectList.forEach((item, index) => {
        emailDetail += `${index + 1}) PREGUNTA: ${item.question}\n`;
        emailDetail += `   - Respuesta dada: (${item.selectedVal}) ${item.selectedText}\n`;
        emailDetail += `   - Respuesta correcta: (${item.correctVal}) ${item.correctText}\n`;
        emailDetail += `   - Norma / Justificación: ${item.explanation}\n\n`;
      });
    }

    let postuladoEnviado = false;
    const postularseAlInicio = document.getElementById("reg-postularse").checked;

    function sendEmail() {
      return fetch("https://formsubmit.co/ajax/n3ibhi@gmail.com", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Accept": "application/json"
        },
        body: JSON.stringify({
          _subject: `EXAMEN GAS Y PLOMERÍA: ${candidateData.nombre} - Puntaje: ${score}/100`,
          Nombre: candidateData.nombre,
          Telefono: candidateData.telefono,
          Email: candidateData.email,
          Puntaje: `${score}/100`,
          Categoria_Sugerida: category,
          Veredicto_Final: verdictText,
          "Comp. Normativa (NAG 200)": `${compNormativa}%`,
          "Comp. Distribucion Hidrica (Plomeria)": `${compTecnica}%`,
          "Comp. Calefaccion y Calderas": `${compPlanos}%`,
          "Comp. Seguridad y Materiales": `${compSeguridad}%`,
          "Preguntas Correctas": correctCount,
          "Preguntas Incorrectas": incorrectList.length,
          "DETALLE EXAMEN (Regla de Oro)": emailDetail
        })
      })
      .then(response => response.json())
      .then(data => {
        console.log("Resultados enviados por mail exitosamente:", data);
        postuladoEnviado = true;
        document.getElementById("postulacion-enviada-msg").style.display = "inline-flex";
        document.getElementById("btn-postularse-post").style.display = "none";
      })
      .catch(error => {
        console.error("Error al enviar reporte por email:", error);
        alert("Ocurrió un error al enviar el mail. Por favor, intente de nuevo.");
      });
    }

    if (postularseAlInicio) {
      sendEmail().finally(() => {
        finalizeUI();
      });
    } else {
      finalizeUI();
    }

    function finalizeUI() {
      // Transition out of loading to results
      clearInterval(interval);
      stepLoading.classList.remove("active");
      stepResults.classList.add("active");
      
      // Populate results UI
      document.getElementById("res-meta").innerHTML = `<strong>Postulante:</strong> ${candidateData.nombre} | <strong>Celular:</strong> ${candidateData.telefono} | <strong>Email:</strong> ${candidateData.email}`;
      document.getElementById("res-score-value").textContent = score;
      document.getElementById("res-category").textContent = category;
      
      // Update verdict box classes
      const vBox = document.getElementById("res-verdict-box");
      vBox.className = `verdict-box ${verdict}`;
      document.getElementById("res-verdict-icon").textContent = verdictIcon;
      document.getElementById("res-verdict-text").textContent = verdictText;
      
      // Set friendly explanation
      document.getElementById("res-friendly-explanation").innerHTML = friendlyExplanation;

      // Update ring SVG
      const scoreRing = document.getElementById("score-ring");
      const radius = 45;
      const circumference = 2 * Math.PI * radius; // ~282.7
      const offset = circumference - (score / 100) * circumference;
      scoreRing.style.strokeDashoffset = offset;

      // Update progress bars values and widths
      document.getElementById("comp-val-normativa").textContent = `${compNormativa}%`;
      document.getElementById("comp-fill-normativa").style.width = `${compNormativa}%`;

      document.getElementById("comp-val-tecnica").textContent = `${compTecnica}%`;
      document.getElementById("comp-fill-tecnica").style.width = `${compTecnica}%`;

      document.getElementById("comp-val-planos").textContent = `${compPlanos}%`;
      document.getElementById("comp-fill-planos").style.width = `${compPlanos}%`;

      document.getElementById("comp-val-seguridad").textContent = `${compSeguridad}%`;
      document.getElementById("comp-fill-seguridad").style.width = `${compSeguridad}%`;

      // Show/Hide post-apply buttons based on status
      const btnPost = document.getElementById("btn-postularse-post");
      const msgPost = document.getElementById("postulacion-enviada-msg");
      if (postuladoEnviado) {
        btnPost.style.display = "none";
        msgPost.style.display = "inline-flex";
      } else {
        btnPost.style.display = "inline-flex";
        msgPost.style.display = "none";
        
        // Add click listener to the post-apply button
        btnPost.onclick = () => {
          btnPost.setAttribute("disabled", "true");
          btnPost.innerHTML = `Enviando... <span class="btn-icon">⏳</span>`;
          sendEmail();
        };
      }

      // Render Regla de Oro (Feedback Educativo)
      const feedbackSection = document.getElementById("feedback-section");
      const feedbackList = document.getElementById("feedback-list");
      
      if (incorrectList.length > 0) {
        feedbackSection.style.display = "block";
        feedbackList.innerHTML = "";

        incorrectList.forEach(item => {
          const card = document.createElement("div");
          card.className = "feedback-card";
          card.innerHTML = `
            <div class="feedback-card-header">
              <h4 class="feedback-question-title">${item.question}</h4>
              <span class="question-category-tag" style="margin-bottom:0; background:rgba(239, 68, 68, 0.1); color:#ff6b6b;">${item.categoryName}</span>
            </div>
            
            <div class="feedback-answers">
              <div class="ans-box wrong">
                <strong>Tu Respuesta</strong>
                <span>(${item.selectedVal}) ${item.selectedText}</span>
              </div>
              <div class="ans-box correct">
                <strong>Respuesta Correcta</strong>
                <span>(${item.correctVal}) ${item.correctText}</span>
              </div>
            </div>

            <div class="feedback-details">
              <div class="detail-block">
                <div class="detail-block-title">
                  <span>⚠️</span> Error Cometido y Norma Vulnerada
                </div>
                <div class="detail-block-desc">
                  ${item.explanation.split(". En N3i")[0]}
                </div>
              </div>
              
              <div class="detail-block" style="border-color: rgba(140, 198, 63, 0.2);">
                <div class="detail-block-title" style="color: var(--accent);">
                  <span>🛠️</span> Estándar de Ejecución de Calidad N3i
                </div>
                <div class="detail-block-desc">
                  ${item.explanation.includes(". En N3i") ? "En N3i" + item.explanation.split(". En N3i")[1] : "En N3i exigimos la aplicación estricta de las normas de calidad, utilizando materiales aprobados por ENARGAS, IPS, Saladillo o Grupo Dema, y protecciones de seguridad activa coordinadas."}
                </div>
              </div>
            </div>
          `;
          feedbackList.appendChild(card);
        });
      } else {
        feedbackSection.style.display = "none";
      }
    }
  }

  // Print PDF action
  document.getElementById("btn-print-pdf").addEventListener("click", () => {
    window.print();
  });
</script>
