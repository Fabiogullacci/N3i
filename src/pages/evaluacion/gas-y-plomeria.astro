          Email: candidateData.email,
          Oficio: "Gas y Plomería (Postulación directa sin realizar test)",
          Comentarios: "El candidato prefirió postularse directamente sin realizar la autoevaluación técnica."
        })
      })
      .then(response => response.json())
      .then(data => {
