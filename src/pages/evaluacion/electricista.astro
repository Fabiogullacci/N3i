  };
  let currentQuestionIndex = 0;
  let userAnswers = {}; // Map of questionId -> selectedOption (A, B, C, D)

  // DOM ELEMENTS
  const stepReg = document.getElementById("step-registration");
  const stepQuiz = document.getElementById("step-quiz");
  const stepLoading = document.getElementById("step-loading");
  const stepResults = document.getElementById("step-results");

  const inputNombre = document.getElementById("reg-nombre");
  const inputTelefono = document.getElementById("reg-telefono");
  const inputEmail = document.getElementById("reg-email");
  const btnStart = document.getElementById("btn-start");

  const quizQuestionIndex = document.getElementById("quiz-question-index");
  const quizPercent = document.getElementById("quiz-percent");
  const quizProgressFill = document.getElementById("quiz-progress-fill");
  const questionCategory = document.getElementById("question-category");
  const questionText = document.getElementById("question-text");
  const optionsList = document.getElementById("options-list");
  const btnPrev = document.getElementById("btn-prev");
  const btnNext = document.getElementById("btn-next");

  const loaderMsg = document.getElementById("loader-msg");

  // INITIALIZATION AND REGISTRATION
  btnStart.addEventListener("click", () => {
    const nombre = inputNombre.value.trim();
    const telefono = inputTelefono.value.trim();
    const email = inputEmail.value.trim();

    if (!nombre || !telefono || !email) {
      alert("Por favor complete todos los datos requeridos.");
      return;
    }

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      alert("Por favor ingrese un correo electrónico válido.");
      return;
    }

    candidateData = { nombre, telefono, email };
    
    // Switch to quiz step
    stepReg.classList.remove("active");
    stepQuiz.classList.add("active");
    
    renderQuestion();
  });

  const btnDirectPostulation = document.getElementById("btn-direct-postulation");
  if (btnDirectPostulation) {
    btnDirectPostulation.addEventListener("click", () => {
      const nombre = inputNombre.value.trim();
      const telefono = inputTelefono.value.trim();
      const email = inputEmail.value.trim();

      if (!nombre || !telefono || !email) {
        alert("Por favor complete todos los datos requeridos.");
        return;
      }

      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(email)) {
        alert("Por favor ingrese un correo electrónico válido.");
        return;
      }

      candidateData = { nombre, telefono, email };

      // Switch to loading step
      stepReg.classList.remove("active");
      stepLoading.classList.add("active");
      loaderMsg.innerText = "Enviando postulación al equipo de N3i...";

      fetch("https://formsubmit.co/ajax/n3ibhi@gmail.com", {
        method: "POST",
