---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout 
  title="Evaluación Técnica - Electricista | N3i" 
  description="Examen técnico e informe de competencias para la clasificación de electricistas de N3i Engineering & Maintenance."
>
  <Header />

  <!-- Hero Section -->
  <section class="page-hero" style="background: linear-gradient(135deg, var(--bg-secondary), var(--bg-primary)); border-bottom: 1px solid var(--border-color); padding: 140px 20px 60px 20px; text-align: center;">
    <div class="container">
      <span class="section-subtitle" style="color: var(--accent);">Evaluación de Competencias</span>
      <h1 class="hero-title" style="font-size: clamp(2rem, 5vw, 3rem); margin-bottom: 15px;">Clasificación Técnica: Electricidad</h1>
      <p class="hero-subtitle" style="margin: 0 auto; max-width: 700px; color: var(--text-secondary); font-size: 1.05rem;">
        Cuestionario de evaluación técnica para determinar la categoría operativa en obras de N3i (Ayudante, Oficial, Oficial Especializado o Matriculado).
      </p>
    </div>
  </section>

  <!-- Main Container Section -->
  <section style="padding: 60px 20px; background-color: var(--bg-primary); min-height: 70vh; position: relative;">
    <div class="container">
      
      <!-- EVALUATION CARD WRAPPER -->
      <div class="eval-card" id="eval-card">
        
        <!-- STEP 1: REGISTRATION -->
        <div id="step-registration" class="step-container active">
          <div class="step-header">
            <h2 class="step-title">Registro del Postulante</h2>
            <p class="step-desc">Ingrese sus datos para comenzar la evaluación de 20 preguntas técnicas de selección múltiple.</p>
          </div>
          
          <div class="form-grid">
            <div class="form-group">
              <label for="reg-nombre">Nombre y Apellido Completo *</label>
              <input type="text" id="reg-nombre" placeholder="Ej. Carlos Alberto Gómez" class="eval-input" required />
            </div>
            <div class="form-group">
              <label for="reg-telefono">Teléfono / WhatsApp *</label>
              <input type="tel" id="reg-telefono" placeholder="Ej. 2914567890" class="eval-input" required />
            </div>
            <div class="form-group">
              <label for="reg-email">Correo Electrónico *</label>
              <input type="email" id="reg-email" placeholder="Ej. carlos.gomez@gmail.com" class="eval-input" required />
            </div>
          </div>

          <div style="margin-bottom: 25px;">
            <label class="eval-checkbox-label">
              <input type="checkbox" id="reg-postularse" checked />
              <div style="font-size: 0.92rem; color: var(--text-light); line-height: 1.4;">
                <strong>Quiero postularme a N3i con estos resultados</strong><br>
                <span style="font-size: 0.82rem; color: var(--text-secondary);">Si marcas esta opción, tus respuestas y perfil técnico se enviarán automáticamente al equipo de Ingeniería de N3i. Si la desmarcas, solo realizarás el test para medir tu nivel de forma privada.</span>
              </div>
            </label>
          </div>
          
          <div class="info-alert">
            <span class="alert-icon">💡</span>
            <div class="alert-text">
              <strong>Información de la prueba:</strong> El cuestionario mezcla teoría normativa (AEA 90364) con casos reales de obra en seguridad industrial y conexionado. Cada pregunta tiene una única respuesta correcta. Al finalizar se mostrarán los resultados y el feedback didáctico detallado. Si querés repasar antes de comenzar, podés consultar la reglamentación en la <a href="https://aea.org.ar/" target="_blank" rel="noopener noreferrer" style="color: var(--accent); text-decoration: underline; font-weight: 600;">web oficial de la AEA (Asociación Electrotécnica Argentina)</a>.
            </div>
          </div>
          
          <button class="btn btn-primary btn-full-width" id="btn-start">
            Comenzar Evaluación
            <span class="btn-icon">⚡</span>
          </button>
          
          <button class="btn btn-outline btn-full-width" id="btn-direct-postulation" style="margin-top: 15px; font-size: 0.95rem; justify-content: center; border: 1px solid var(--accent); color: #ffffff;">
            Postularse directamente (Sin realizar el test)
            <span class="btn-icon">📋</span>
          </button>
        </div>


        <!-- STEP 2: QUESTIONNAIRE (DYNAMIC) -->
        <div id="step-quiz" class="step-container">
          <div class="quiz-progress-bar-container">
            <div class="quiz-progress-meta">
              <span id="quiz-question-index">Pregunta 1 de 20</span>
              <span id="quiz-percent">0%</span>
            </div>
            <div class="quiz-progress-bar">
              <div class="quiz-progress-fill" id="quiz-progress-fill" style="width: 0%;"></div>
            </div>
          </div>
          
          <div class="question-box">
            <div class="question-category-tag" id="question-category">Normativa AEA</div>
            <h3 class="question-text" id="question-text">¿Cargando pregunta?</h3>
            
            <div class="options-list" id="options-list">
              <!-- Dynamically populated options -->
            </div>
          </div>
          
          <div class="quiz-nav">
            <button class="btn btn-outline" id="btn-prev" disabled>
              <span class="btn-icon">⬅️</span> Anterior
            </button>
            <button class="btn btn-primary" id="btn-next" disabled>
              Siguiente <span class="btn-icon">➡️</span>
            </button>
          </div>
        </div>

        <!-- STEP 3: LOADING / PROCCESSING SCREEN -->
        <div id="step-loading" class="step-container">
          <div class="loader-wrapper">
            <div class="loader-spinner"></div>
            <h3 class="loader-title">Procesando Examen Técnico</h3>
            <p class="loader-msg" id="loader-msg">Analizando normativas y diagramando la matriz de competencias...</p>
          </div>
        </div>

        <!-- STEP 4: RESULTS DASHBOARD -->
        <div id="step-results" class="step-container">
          
          <!-- PDF / Print Header (Hidden on Screen) -->
          <div class="print-only-header">
            <div class="print-brand-row">
              <div class="print-brand-logo">N3i Engineering & Maintenance</div>
              <div class="print-brand-sub">Evaluación y Clasificación Técnica de Contratistas</div>
            </div>
            <hr class="print-hr" />
          </div>

          <div class="results-header">
            <span class="section-subtitle">RESULTADOS DE LA EVALUACIÓN</span>
            <h2 class="step-title" style="font-size: 2.2rem; margin-bottom: 5px;">Informe de Aptitud Técnica</h2>
            <p style="color: var(--text-secondary); margin-bottom: 25px;" id="res-meta">Postulante: Juan Pérez | Fecha: --/--/----</p>
          </div>

          <div class="dashboard-grid">
            
            <!-- Puntaje y Clasificación -->
            <div class="dash-card score-card">
              <div class="score-circle-wrapper">
                <svg viewBox="0 0 100 100" class="score-circle-svg">
                  <circle cx="50" cy="50" r="45" class="bg-ring"></circle>
                  <circle cx="50" cy="50" r="45" class="fg-ring" id="score-ring" stroke-dasharray="283" stroke-dashoffset="283"></circle>
                </svg>
                <div class="score-text">
                  <span id="res-score-value">0</span>
                  <span class="score-max">/100</span>
                </div>
              </div>
              <div style="text-align: center; margin-top: 15px;">
                <h4 style="font-size: 0.85rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 5px;">Categoría N3i Sugerida</h4>
                <div class="category-badge" id="res-category">Calculando...</div>
              </div>
            </div>

            <!-- Veredicto Final e Interpretación Amigable -->
            <div class="dash-card verdict-card">
              <h3>Veredicto de Ingreso</h3>
              <div class="verdict-box" id="res-verdict-box">
                <span class="verdict-icon" id="res-verdict-icon">❓</span>
                <span class="verdict-text" id="res-verdict-text">Evaluando aptitud...</span>
              </div>
              <div class="verdict-explanation" id="res-friendly-explanation">
                <!-- Friendly, interpretive feedback will go here -->
              </div>
            </div>

          </div>

          <!-- Matriz de Competencias -->
          <div class="dash-card" style="margin-top: 25px;">
            <h3 style="border-bottom: 1px solid var(--border-color); padding-bottom: 12px; margin-bottom: 20px; font-size: 1.25rem;">Matriz de Competencias Técnicas</h3>
            <div class="competency-grid">
              
              <div class="comp-item">
                <div class="comp-meta">
                  <span class="comp-name">Competencia Normativa (AEA 90364-7)</span>
                  <span class="comp-value" id="comp-val-normativa">0%</span>
                </div>
                <div class="comp-bar"><div class="comp-bar-fill" id="comp-fill-normativa" style="width: 0%;"></div></div>
              </div>

              <div class="comp-item">
                <div class="comp-meta">
                  <span class="comp-name">Destreza Técnica (Tableros, Curvas y Medición)</span>
                  <span class="comp-value" id="comp-val-tecnica">0%</span>
                </div>
                <div class="comp-bar"><div class="comp-bar-fill" id="comp-fill-tecnica" style="width: 0%;"></div></div>
              </div>

              <div class="comp-item">
                <div class="comp-meta">
                  <span class="comp-name">Interpretación de Planos y Factores (FP/Dilatación)</span>
                  <span class="comp-value" id="comp-val-planos">0%</span>
                </div>
                <div class="comp-bar"><div class="comp-bar-fill" id="comp-fill-planos" style="width: 0%;"></div></div>
              </div>

              <div class="comp-item">
                <div class="comp-meta">
                  <span class="comp-name">Seguridad Industrial (Reglas de Oro/LOTO/EPPs)</span>
                  <span class="comp-value" id="comp-val-seguridad">0%</span>
                </div>
                <div class="comp-bar"><div class="comp-bar-fill" id="comp-fill-seguridad" style="width: 0%;"></div></div>
              </div>

            </div>
          </div>

          <!-- REGLA DE ORO / FEEDBACK EDUCATIVO DETALLADO -->
          <div class="feedback-section" id="feedback-section" style="display: none; margin-top: 35px;">
            <div class="feedback-section-header">
              <span class="section-subtitle" style="color: #ffb703;">SOPORTE Y CAPACITACIÓN</span>
              <h3 style="font-size: 1.5rem; color: var(--text-primary); margin-top: 5px;">Revisión de Seguridad y Normas - Regla de Oro</h3>
              <p style="color: var(--text-secondary); font-size: 0.95rem; margin-top: 5px;">
                A continuación, detallamos los errores cometidos, las normas vulneradas y el estándar de calidad N3i exigido en obra para su aprendizaje y mejora continua.
              </p>
            </div>
            
            <div id="feedback-list" class="feedback-list">
              <!-- Dynamically populated cards of incorrect answers -->
            </div>
          </div>

          <!-- Acciones finales -->
          <div class="results-actions" style="margin-top: 40px; display: flex; gap: 16px; justify-content: center; align-items: center; flex-wrap: wrap;">
            <button class="btn btn-primary" id="btn-print-pdf" style="padding: 14px 28px;">
              Descargar Informe en PDF
              <span class="btn-icon">📄</span>
            </button>
            <button class="btn btn-primary" id="btn-postularse-post" style="padding: 14px 28px; background-color: #3b82f6; display: none;">
              Enviar Postulación a N3i
              <span class="btn-icon">✉️</span>
            </button>
            <span id="postulacion-enviada-msg" style="color: var(--accent); font-weight: 600; display: none; align-items: center; gap: 8px;">
              ✓ Su postulación ha sido enviada a N3i.
            </span>
            <a href="/empleo" class="btn btn-outline" style="padding: 14px 28px;">
              Volver a Empleo
              <span class="btn-icon">💼</span>
            </a>
          </div>

        </div>

      </div>

    </div>
  </section>

  <Footer />
</Layout>

<style is:global>
  /* Base evaluacion custom colors */
  :root {
    --eval-card-bg: rgba(17, 20, 22, 0.75);
    --eval-border: rgba(255, 255, 255, 0.05);
    --eval-border-hover: rgba(140, 198, 63, 0.3);
  }

  .eval-checkbox-label {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background: rgba(140, 198, 63, 0.04);
    border: 1px solid rgba(140, 198, 63, 0.15);
    padding: 16px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .eval-checkbox-label:hover {
    background: rgba(140, 198, 63, 0.08);
    border-color: rgba(140, 198, 63, 0.3);
  }
  .eval-checkbox-label input[type="checkbox"] {
    margin-top: 4px;
    width: 18px;
    height: 18px;
    accent-color: var(--accent);
    cursor: pointer;
    flex-shrink: 0;
  }

  .eval-card {
    max-width: 900px;
    margin: 0 auto;
    background: var(--eval-card-bg);
    border: 1px solid var(--eval-border);
    border-radius: var(--radius-md, 16px);
    padding: 40px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5), 0 0 30px rgba(140, 198, 63, 0.02);
    backdrop-filter: blur(12px);
    transition: var(--transition-smooth, all 0.4s cubic-bezier(0.16, 1, 0.3, 1));
  }

  .step-container {
    display: none;
  }

  .step-container.active {
    display: block;
    animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(15px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .step-header {
    margin-bottom: 30px;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 20px;
  }

  .step-title {
    font-size: 1.8rem;
    color: var(--text-primary);
    margin-bottom: 10px;
  }

  .step-desc {
    color: var(--text-secondary);
    font-size: 0.98rem;
  }

  /* Form inputs */
  .form-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-bottom: 30px;
  }

  @media (min-width: 768px) {
    .form-grid {
      grid-template-columns: 1fr 1fr;
    }
    .form-grid .form-group:first-child {
      grid-column: span 2;
    }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-group label {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .eval-input {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm, 8px);
    padding: 12px 16px;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 1rem;
    transition: var(--transition-smooth);
  }

  .eval-input:focus {
    border-color: var(--accent);
    background: rgba(140, 198, 63, 0.03);
    box-shadow: 0 0 10px rgba(140, 198, 63, 0.1);
  }

  .btn-full-width {
    width: 100%;
    margin-top: 10px;
  }

  /* Alert box */
  .info-alert {
    display: flex;
    gap: 15px;
    background: rgba(140, 198, 63, 0.05);
    border: 1px solid rgba(140, 198, 63, 0.2);
    border-radius: var(--radius-sm, 8px);
    padding: 20px;
    margin-bottom: 30px;
    align-items: flex-start;
  }

  .alert-icon {
    font-size: 1.5rem;
    line-height: 1;
  }

  .alert-text {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Progress bar */
  .quiz-progress-bar-container {
    margin-bottom: 30px;
  }

  .quiz-progress-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 8px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .quiz-progress-bar {
    width: 100%;
    height: 8px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
    overflow: hidden;
  }

  .quiz-progress-fill {
    height: 100%;
    background: var(--accent);
    transition: width 0.3s ease;
    box-shadow: 0 0 10px var(--accent-glow);
  }

  /* Question Box */
  .question-box {
    margin-bottom: 35px;
  }

  .question-category-tag {
    display: inline-block;
    background: rgba(140, 198, 63, 0.1);
    color: var(--accent);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 15px;
  }

  .question-text {
    font-size: 1.35rem;
    line-height: 1.5;
    color: var(--text-primary);
    margin-bottom: 25px;
    font-family: var(--font-title);
  }

  /* Options list */
  .options-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .option-card {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 16px 20px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm, 8px);
    cursor: pointer;
    transition: var(--transition-smooth);
    user-select: none;
  }

  .option-card:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.15);
  }

  .option-card.selected {
    background: rgba(140, 198, 63, 0.06);
    border-color: var(--accent);
    box-shadow: 0 0 15px rgba(140, 198, 63, 0.05);
  }

  .option-card.option-dont-know {
    border-style: dashed;
    border-color: var(--text-muted);
    opacity: 0.85;
    margin-top: 15px;
    border-color: rgba(255, 255, 255, 0.15);
  }
  .option-card.option-dont-know:hover {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.35);
  }
  .option-card.option-dont-know.selected {
    background: rgba(239, 68, 68, 0.04);
    border-color: #ef4444;
    box-shadow: 0 0 15px rgba(239, 68, 68, 0.08);
  }
  .option-card.option-dont-know.selected .option-letter {
    background: #ef4444;
    border-color: #ef4444;
    color: #ffffff;
  }

  .option-letter {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-weight: 600;
    font-size: 0.9rem;
    transition: var(--transition-smooth);
    flex-shrink: 0;
  }

  .option-card.selected .option-letter {
    background: var(--accent);
    border-color: var(--accent);
    color: #000000;
  }

  .option-text-span {
    font-size: 0.98rem;
    color: var(--text-secondary);
    line-height: 1.5;
    transition: var(--transition-smooth);
  }

  .option-card.selected .option-text-span {
    color: var(--text-primary);
  }

  .quiz-nav {
    display: flex;
    justify-content: space-between;
    margin-top: 30px;
    border-top: 1px solid var(--border-color);
    padding-top: 25px;
  }

  /* Loader spinner */
  .loader-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 20px;
    text-align: center;
  }

  .loader-spinner {
    width: 60px;
    height: 60px;
    border: 4px solid rgba(140, 198, 63, 0.1);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-bottom: 25px;
    box-shadow: 0 0 15px rgba(140, 198, 63, 0.1);
  }

  .loader-title {
    font-size: 1.5rem;
    color: var(--text-primary);
    margin-bottom: 10px;
  }

  .loader-msg {
    color: var(--text-secondary);
    font-size: 0.95rem;
    max-width: 400px;
    line-height: 1.6;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* Results dashboard layout */
  .results-header {
    text-align: center;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 20px;
    margin-bottom: 30px;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 25px;
    margin-bottom: 25px;
  }

  @media (min-width: 768px) {
    .dashboard-grid {
      grid-template-columns: 320px 1fr;
    }
  }

  .dash-card {
    background: rgba(255, 255, 255, 0.015);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm, 12px);
    padding: 25px;
  }

  /* Circular score meter */
  .score-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .score-circle-wrapper {
    position: relative;
    width: 160px;
    height: 160px;
  }

  .score-circle-svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }

  .score-circle-svg circle {
    fill: none;
    stroke-width: 8;
  }

  .score-circle-svg .bg-ring {
    stroke: rgba(255, 255, 255, 0.05);
  }

  .score-circle-svg .fg-ring {
    stroke: var(--accent);
    stroke-linecap: round;
    transition: stroke-dashoffset 1s ease-in-out;
  }

  .score-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    font-family: var(--font-title);
  }

  #res-score-value {
    font-size: 2.8rem;
    font-weight: 800;
    line-height: 1;
    color: var(--text-primary);
  }

  .score-max {
    font-size: 0.95rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  .category-badge {
    display: inline-block;
    padding: 6px 16px;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 4px;
    margin-top: 5px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-family: var(--font-title);
    background-color: rgba(255, 255, 255, 0.08);
    color: var(--text-primary);
  }

  /* Veredicto card styling */
  .verdict-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .verdict-card h3 {
    font-size: 1.15rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 15px;
  }

  .verdict-box {
    display: flex;
