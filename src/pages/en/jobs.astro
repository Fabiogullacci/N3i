---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Careers | N3i Engineering & Maintenance" description="N3i technical recruitment form. Join the team of contractors and specialists.">
  <Header />

  <!-- Hero Section -->
  <section class="section" style="padding-top: 150px; text-align: center;">
    <div class="container reveal">
      <span class="section-subtitle">Join the N3i Team</span>
      <h1 class="hero-title" style="font-size: 3rem; margin-bottom: 20px;">Careers</h1>
      <p class="hero-subtitle" style="margin: 0 auto; max-width: 700px; color: var(--text-light);">
        Highly trained technicians, officers, and contractors are sought to join N3i's work teams. Complete the following technical questionnaire to evaluate the profile. A PDF resume is not required.
      </p>
    </div>
  </section>

  <!-- Formulario Section -->
  <section class="section section-alt" id="cuestionario">
    <div class="container reveal">
      <div class="form-container" style="max-width: 800px; margin: 0 auto; background: var(--card-bg); border-radius: 12px; padding: 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.05);">
        
        <form action="https://formsubmit.co/n3ibhi@gmail.com" method="POST" id="job-form">
          <!-- FormSubmit Config -->
          <input type="hidden" name="_subject" value="NEW TECHNICAL APPLICANT - N3i">
          <input type="hidden" name="_next" value="https://n3i.com.ar/en">
          <input type="hidden" name="_captcha" value="false">
          <input type="hidden" name="_template" value="table">
          
          <!-- SECCIÓN 1: Datos Personales -->
          <h3 style="color: #3FC6B4; border-bottom: 1px solid rgba(63, 198, 180, 0.3); padding-bottom: 10px; margin-bottom: 20px;">1. Personal Information</h3>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
            <div class="form-group">
              <label for="nombre">Full Name *</label>
              <input type="text" id="nombre" name="Name" class="calc-input" required>
            </div>
            <div class="form-group">
              <label for="telefono">Phone / WhatsApp *</label>
              <input type="tel" id="telefono" name="Phone" class="calc-input" required>
            </div>
          </div>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
            <div class="form-group">
              <label for="email">Email Address (Optional)</label>
              <input type="email" id="email" name="Email" class="calc-input">
            </div>
            <div class="form-group">
              <label for="ciudad">City / Residence Area *</label>
              <input type="text" id="ciudad" name="City" class="calc-input" required>
            </div>
          </div>

          <!-- SECCIÓN 2: Especialidad -->
          <h3 style="color: #3FC6B4; border-bottom: 1px solid rgba(63, 198, 180, 0.3); padding-bottom: 10px; margin-bottom: 20px;">2. Technical Profile</h3>
          
          <div class="form-group" style="margin-bottom: 25px;">
            <label style="margin-bottom: 10px; display: block;">Trades and Specialties (Check all that apply) *</label>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
              <label class="checkbox-label"><input type="checkbox" name="Trades" value="Electrical"> General / Industrial Electrical</label>
              <label class="checkbox-label"><input type="checkbox" name="Trades" value="Automation"> Industrial Automation</label>
              <label class="checkbox-label"><input type="checkbox" name="Trades" value="Plumbing"> Plumbing / Piping</label>
              <label class="checkbox-label"><input type="checkbox" name="Trades" value="GasFitter"> Certified Gas Fitter</label>
              <label class="checkbox-label"><input type="checkbox" name="Trades" value="Masonry"> General Masonry</label>
              <label class="checkbox-label"><input type="checkbox" name="Trades" value="Drywall/Painting"> Drywall / Painting</label>
              <label class="checkbox-label"><input type="checkbox" name="Trades" value="HVAC"> HVAC (Cooling / Heating)</label>
              <label class="checkbox-label"><input type="checkbox" name="Trades" value="Metalwork"> Metalwork / Sheet Metal</label>
              <label class="checkbox-label"><input type="checkbox" name="Trades" value="Networking/CCTV"> Data Networks / Alarms / CCTV (Cameras)</label>
            </div>
          </div>

          <div class="form-group" style="margin-bottom: 30px;">
            <label style="margin-bottom: 10px; display: block;">Experience Level *</label>
            <select name="Experience_Level" class="calc-select" required>
              <option value="" disabled selected>Select your level...</option>
              <option value="Helper">Helper / Entry Level</option>
              <option value="Semi-skilled">Semi-skilled (Mid-level)</option>
              <option value="Skilled">Skilled Worker</option>
              <option value="Certified">Certified / Master Technician</option>
            </select>
          </div>

          <!-- SECCIÓN 3: Logística -->
          <h3 style="color: #3FC6B4; border-bottom: 1px solid rgba(63, 198, 180, 0.3); padding-bottom: 10px; margin-bottom: 20px;">3. Logistics & Contracting</h3>
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
            <div class="form-group">
              <label>Tax Status (AFIP) *</label>
              <select name="Tax_Status" class="calc-select" required>
                <option value="Active Monotributo">Active Monotributista</option>
                <option value="In progress">In progress</option>
                <option value="None">No billing capacity</option>
              </select>
            </div>
            <div class="form-group">
              <label>Time Availability *</label>
              <select name="Availability" class="calc-select" required>
                <option value="Full-Time">Full-time (Monday to Friday)</option>
                <option value="Part-Time">Part-time</option>
                <option value="Weekends">Weekends only</option>
                <option value="Emergencies">On-call / Emergencies only (24/7)</option>
              </select>
            </div>
          </div>

          <div class="form-group" style="margin-bottom: 20px;">
            <label style="margin-bottom: 10px; display: block;">Tools *</label>
            <div style="display: flex; gap: 20px;">
              <label><input type="radio" name="Tools" value="Complete" required> Own & Complete</label>
              <label><input type="radio" name="Tools" value="Basic"> Basic</label>
              <label><input type="radio" name="Tools" value="None"> None</label>
            </div>
          </div>

          <div class="form-group" style="margin-bottom: 30px;">
            <label style="margin-bottom: 10px; display: block;">Mobility / Vehicle *</label>
            <div style="display: flex; gap: 20px; flex-wrap: wrap;">
              <label><input type="radio" name="Mobility" value="Truck/Van" required> Truck / Van</label>
              <label><input type="radio" name="Mobility" value="Car"> Car</label>
              <label><input type="radio" name="Mobility" value="Motorcycle"> Motorcycle</label>
              <label><input type="radio" name="Mobility" value="None"> No own vehicle</label>
            </div>
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
            <div class="form-group">
              <label>Insurance Coverage *</label>
              <select name="Insurance" class="calc-select" required>
                <option value="Active ART">Active Worker's Comp (ART)</option>
                <option value="Personal Accident Insurance">Personal Accident Insurance</option>
                <option value="No insurance">No insurance currently</option>
              </select>
            </div>
            <div class="form-group">
              <label>References / Past Work *</label>
              <select name="References" class="calc-select" required>
                <option value="Verifiable references">Verifiable references from clients/companies</option>
                <option value="Private work only">Private work without formal references</option>
                <option value="Beginner">Beginner / No previous experience</option>
              </select>
            </div>
          </div>

          <div class="form-group" style="margin-bottom: 40px;">
            <label for="comentarios">Additional Comments (Optional)</label>
            <textarea id="comentarios" name="Comments" class="calc-input" rows="4" placeholder="Describe key jobs, brands used, or any relevant professional details..."></textarea>
          </div>

          <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; font-size: 1.1rem; padding: 15px;">
            Submit Application
            <span class="btn-icon">📋</span>
          </button>
          
          <p style="text-align: center; font-size: 0.8rem; color: var(--text-light); margin-top: 20px;">
            By submitting this form, you agree to be contacted by N3i for potential job opportunities or service contracts.
          </p>
        </form>
      </div>
    </div>
  </section>

  <Footer />
</Layout>



<style>
  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.95rem;
    color: var(--text-light);
    cursor: pointer;
    background: rgba(255,255,255,0.02);
    padding: 10px;
    border-radius: 6px;
    border: 1px solid rgba(255,255,255,0.05);
    transition: all 0.3s ease;
  }
  .checkbox-label:hover {
    background: rgba(63, 198, 180, 0.1);
    border-color: rgba(63, 198, 180, 0.3);
  }
  input[type="checkbox"], input[type="radio"] {
    accent-color: #3FC6B4;
    width: 18px;
    height: 18px;
  }
  @media (max-width: 768px) {
    .form-group-grid, div[style*="grid-template-columns: 1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
