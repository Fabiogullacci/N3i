---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import obrasData from '../data/obras.json';

// Agrupar obras por categoría
const obrasPorCategoria = obrasData.obras.reduce((acc, obra) => {
  const cat = obra.category || 'Otras Obras';
  if (!acc[cat]) {
    acc[cat] = [];
  }
  acc[cat].push(obra);
  return acc;
}, {});
---
<Layout 
  title="Portfolio de Obras | N3i Engineering & Maintenance" 
  description="Galería de obras y proyectos recientes."
  image="/assets/img/obra_zelarrayan_1.jpg"
>
  <Header />
  <!-- Obras Destacadas Section -->
  <section class="section" id="obras">
    <div class="container">
      <div class="section-header reveal" style="margin: 0 auto 50px auto; text-align: center;">
        <span class="section-subtitle">Casos de Éxito</span>
        <h2 class="section-title">Trabajos Recientes</h2>
        <p class="section-desc">
          Galería de proyectos y mantenimientos realizados, que garantizan calidad y durabilidad en cada detalle.
        </p>
      </div>

      <div class="works-container">
        {Object.entries(obrasPorCategoria).map(([categoria, obrasGroup]) => (
          <div class="category-section" style="margin-bottom: 80px;">
            <h3 class="category-title reveal" style="font-size: 1.8rem; margin-bottom: 30px; color: var(--accent); border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px; text-transform: uppercase; letter-spacing: 1px;">
              {categoria}
            </h3>
            <div class="works-grid">
              {obrasGroup.map((obra, index) => (
                <div class="work-card reveal" style={`transition-delay: ${index * 0.1}s;`}>
                  {obra.type === 'video' ? (
                    <div class="work-video-container">
                      <video class="work-video" preload="metadata" loop muted playsinline controls>
                        <source src={obra.media[0]} type="video/mp4" />
                        Tu navegador no soporta el formato de video.
                      </video>
                    </div>
                  ) : (
                    <div class={obra.media.length === 3 ? "work-gallery-3" : (obra.media.length >= 4 ? "work-gallery" : (obra.media.length === 2 ? "work-gallery-2" : "work-gallery-1"))}>
                      <div class="work-img-container work-img-main">
                        <img src={obra.media[0]} alt={`${obra.title} - Foto Principal`} class="work-img" loading="lazy" />
                      </div>
                      {obra.media.length > 1 && (
                        <div class="work-img-container work-img-thumb-1">
                          <img src={obra.media[1]} alt="Detalle 1" class="work-img" loading="lazy" />
                        </div>
                      )}
                      {obra.media.length > 2 && (
                        <div class="work-img-container work-img-thumb-2">
                          <img src={obra.media[2]} alt="Detalle 2" class="work-img" loading="lazy" />
                        </div>
                      )}
                      {obra.media.length > 3 && (
                        <div class="work-img-container work-img-thumb-3">
                          <img src={obra.media[3]} alt="Detalle 3" class="work-img" loading="lazy" />
                        </div>
                      )}
                    </div>
                  )}
                  
                  <div class="work-content">
                    <span class="work-category" style="display:none;">{obra.category}</span>
                    <h3 class="work-title">{obra.title}</h3>
                    <p class="work-location">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                        <circle cx="12" cy="10" r="3"></circle>
                      </svg>
                      {obra.location}
                    </p>
                    <p class="work-description">
                      {obra.description}
                    </p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Abonos Mensuales de Mantenimiento Técnico Section -->
  <section class="section" id="abonos">
    <div class="container">
      <div class="section-header reveal" style="margin: 0 auto 50px auto; text-align: center;">
        <span class="section-subtitle">Soporte Continuo</span>
        <h2 class="section-title">Abonos Mensuales de Mantenimiento Técnico</h2>
        <p class="section-desc">
          Planes diseñados para garantizar la continuidad operativa de su negocio, prevenir fallas costosas y asegurar la conservación de su infraestructura.
        </p>
      </div>

      <div class="abonos-grid stagger-container">
        
        <!-- 1. Abono PyME Start -->
        <div class="abono-card reveal">
          <span class="abono-badge">Básico</span>
          <h3 class="abono-title">PyME Start</h3>
          <p class="abono-price">Para pequeños comercios, oficinas y locales comerciales.</p>
          <ul class="abono-features">
            <li><span>✓</span> 1 visita mensual programada para mantenimiento preventivo</li>
            <li><span>✓</span> Cobertura en plomería, electricidad y reparaciones menores</li>
            <li><span>✓</span> Control preventivo de iluminación y cableado</li>
            <li><span>✓</span> Atención telefónica prioritaria</li>
            <li><span>✓</span> Presupuesto bonificado en reformas mayores</li>
          </ul>
          <a href="#contacto" class="btn btn-secondary abono-btn" data-abono="PyME Start">
            Consultar Precio
            <span class="btn-icon">➔</span>
          </a>
        </div>

        <!-- 2. Abono PyME Pro (Destacado) -->
        <div class="abono-card premium-card reveal" style="transition-delay: 0.1s;">
          <span class="abono-badge premium-badge">Más Elegido</span>
          <h3 class="abono-title">PyME Pro</h3>
          <p class="abono-price">Ideal para medianas empresas, oficinas corporativas y locales de alto tránsito.</p>
          <ul class="abono-features">
            <li><span>✓</span> 2 visitas mensuales de auditoría y soporte preventivo</li>
            <li><span>✓</span> Mantenimiento de redes de datos, telefonía y conectividad WiFi</li>
            <li><span>✓</span> Limpieza periódica de desagües pluviales y canaletas en techos</li>
            <li><span>✓</span> Respuesta rápida ante urgencias técnicas en menos de 24 horas</li>
            <li><span>✓</span> 15% de descuento en mano de obra para reformas, Steel Frame y pintura</li>
          </ul>
          <a href="#contacto" class="btn btn-primary abono-btn" data-abono="PyME Pro">
            Consultar Precio
            <span class="btn-icon">➔</span>
          </a>
        </div>

        <!-- 3. Abono Industrial 360 -->
        <div class="abono-card reveal" style="transition-delay: 0.2s;">
          <span class="abono-badge">Completo</span>
          <h3 class="abono-title">Industrial 360</h3>
          <p class="abono-price">Para depósitos, naves industriales, galpones y empresas de producción.</p>
          <ul class="abono-features">
            <li><span>✓</span> Mantenimiento preventivo integral de tableros eléctricos e instalaciones de gas</li>
            <li><span>✓</span> Revisión correctiva periódica de compresores y redes neumáticas</li>
            <li><span>✓</span> Auditoría técnica de cámaras de seguridad y sistemas contra incendios PCI</li>
            <li><span>✓</span> Informes de estado firmados por profesionales matriculados (Ing. Fabio Gullacci)</li>
            <li><span>✓</span> Cobertura de urgencias y fallas críticas con respuesta prioritaria 24/7</li>
          </ul>
          <a href="#contacto" class="btn btn-secondary abono-btn" data-abono="Industrial 360">
            Consultar Precio
            <span class="btn-icon">➔</span>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- Valor & Conclusión Section -->
  <section class="section">
    <div class="container">
      <div class="value-banner reveal">
        <div class="value-banner-bg"></div>
        <div class="value-banner-content">
          <span class="section-subtitle" style="color: var(--accent);">La Diferencia N3i</span>
          <h3>La tranquilidad operativa es el compromiso diario de la firma</h3>
          <p>
            En N3i se comprende el valor del tiempo en cada organización. Por ello, la empresa se consolida como un socio confiable y ágil tanto para PyMEs comerciales como para industrias de gran envergadura. Se gestiona de forma integral todo el mantenimiento preventivo y las reformas de infraestructura para permitir el enfoque exclusivo en el crecimiento del negocio, con el respaldo de técnicos certificados, seguros vigentes (ART) y presupuestos transparentes.
          </p>
          <div class="value-banner-stats">
            <div class="stat-item">
              <h4>Atención</h4>
              <p>Integral 360°</p>
            </div>
            <div class="stat-item">
              <h4>Normas</h4>
              <p>Calidad & Seguridad</p>
            </div>
            <div class="stat-item">
              <h4>Procesos</h4>
              <p>IA & Innovación</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Clientes Section (Infinite Marquee) -->
  <section class="clients-marquee-section" id="clientes">
    <div class="container">
      <div class="clients-marquee-header reveal">
        <span class="section-subtitle">Trayectoria y Confianza</span>
        <h2 class="section-title">Empresas que confían en N3i</h2>
      </div>
    </div>
    
    <div class="marquee-container reveal">
      <div class="marquee-content">
        <span class="client-tag">Solaut SA</span>
        <span class="client-tag">Banco Comafi</span>
        <span class="client-tag">Banco Hipotecario</span>
        <span class="client-tag">Universidad Nacional del Sur</span>
        <span class="client-tag">Toyota Argentina (Bahía Blanca)</span>
        <span class="client-tag">Del Sur Exclusivos (Audi)</span>
        <span class="client-tag">Colegio de Escribanos BB</span>
        <span class="client-tag">Papierttei SA</span>
        <span class="client-tag">Rodovia SA (Axion)</span>
        <span class="client-tag">Rodo Petrol SA (Axion)</span>
        <span class="client-tag">Dietrich SRL</span>
        <span class="client-tag">Coca Cola Andina Argentina</span>
        <span class="client-tag">GM Trans SRL</span>
        <span class="client-tag">Cooperativa Electrica Monte Hermoso</span>
        <span class="client-tag">Sincrosur SA</span>
        <span class="client-tag">Del Sur Construcciones SRL</span>
        <span class="client-tag">Marini Soluciones Inmobiliarias</span>
        <span class="client-tag">CCU Clínica de Urología</span>
        <span class="client-tag">Centro de Ojos Bahía</span>
      </div>
      
      <!-- Duplicate content for seamless infinite looping -->
      <div class="marquee-content" aria-hidden="true">
        <span class="client-tag">Solaut SA</span>
        <span class="client-tag">Banco Comafi</span>
        <span class="client-tag">Banco Hipotecario</span>
        <span class="client-tag">Universidad Nacional del Sur</span>
        <span class="client-tag">Toyota Argentina (Bahía Blanca)</span>
        <span class="client-tag">Del Sur Exclusivos (Audi)</span>
        <span class="client-tag">Colegio de Escribanos BB</span>
        <span class="client-tag">Papierttei SA</span>
        <span class="client-tag">Rodovia SA (Axion)</span>
        <span class="client-tag">Rodo Petrol SA (Axion)</span>
        <span class="client-tag">Dietrich SRL</span>
        <span class="client-tag">Coca Cola Andina Argentina</span>
        <span class="client-tag">GM Trans SRL</span>
        <span class="client-tag">Cooperativa Electrica Monte Hermoso</span>
        <span class="client-tag">Sincrosur SA</span>
        <span class="client-tag">Del Sur Construcciones SRL</span>
        <span class="client-tag">Marini Soluciones Inmobiliarias</span>
        <span class="client-tag">CCU Clínica de Urología</span>
        <span class="client-tag">Centro de Ojos Bahía</span>
      </div>
    </div>

    <!-- Proveedores Section (Infinite Marquee) -->
    <div class="container" style="margin-top: 60px;">
      <div class="clients-marquee-header reveal">
        <span class="section-subtitle">Alianzas Estratégicas</span>
        <h2 class="section-title">Proveedores y aliados estratégicos</h2>
      </div>
    </div>
    
    <div class="marquee-container reveal">
      <div class="marquee-content">
        <span class="client-tag">Sincrosur</span>
        <span class="client-tag">Celsius Comercial</span>
        <span class="client-tag">Idea Luz</span>
        <span class="client-tag">Promar</span>
        <span class="client-tag">Codimat</span>
        <span class="client-tag">Gallucci Aberturas</span>
        <span class="client-tag">Herrajes Villa Mitre</span>
        <span class="client-tag">Pinturerías Coto SRL</span>
        <span class="client-tag">NetPro</span>
        <span class="client-tag">Mas Tecnología SRL</span>
        <span class="client-tag">Ferreterías Centro</span>
        <span class="client-tag">Pinturerías Fernandez</span>
        <span class="client-tag">Cahdem Aberturas</span>
        <span class="client-tag">Tenco Bahía</span>
        <span class="client-tag">Indeplac</span>
        <span class="client-tag">Dismar</span>
      </div>
      
      <!-- Duplicate content for seamless infinite looping -->
      <div class="marquee-content" aria-hidden="true">
        <span class="client-tag">Sincrosur</span>
        <span class="client-tag">Celsius Comercial</span>
        <span class="client-tag">Idea Luz</span>
        <span class="client-tag">Promar</span>
        <span class="client-tag">Codimat</span>
        <span class="client-tag">Gallucci Aberturas</span>
        <span class="client-tag">Herrajes Villa Mitre</span>
        <span class="client-tag">Pinturerías Coto SRL</span>
        <span class="client-tag">NetPro</span>
        <span class="client-tag">Mas Tecnología SRL</span>
        <span class="client-tag">Ferreterías Centro</span>
        <span class="client-tag">Pinturerías Fernandez</span>
        <span class="client-tag">Cahdem Aberturas</span>
        <span class="client-tag">Tenco Bahía</span>
        <span class="client-tag">Indeplac</span>
        <span class="client-tag">Dismar</span>
      </div>
    </div>
  </section>


  <!-- Contact Us Section -->
  <section class="section" id="contacto">
    <div class="container">
      <div class="contact-grid">
        
        <div class="contact-info reveal">
          <div>
            <span class="section-subtitle">Canales Disponibles</span>
            <h2 class="section-title">Cuéntenos qué necesita su empresa hoy</h2>
            <p class="section-desc" style="margin-bottom: 30px;">
              Ya sea una pequeña reparación de mantenimiento, un abono mensual preventivo para un local comercial o PyME, o el desarrollo de una obra de ingeniería industrial, N3i está a disposición para asesorarlo. Solicite un presupuesto sin compromiso.
            </p>
            
            <div class="contact-details">
              <!-- Tel/WP -->
              <div class="contact-detail-card">
                <div class="contact-detail-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81 2v3a2 2 0 0 1-2 2h-3a2 2 0 0 1-2-1.72"></path>
                  </svg>
                </div>
                <div class="contact-detail-text">
                  <h4>Teléfono / WhatsApp</h4>
                  <a href="https://wa.me/5492914168232" target="_blank" rel="noopener noreferrer">+54 9 291 4168232</a>
                </div>
              </div>
              
              <!-- Mail Personal -->
              <div class="contact-detail-card">
                <div class="contact-detail-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                    <polyline points="22,6 12,13 2,6"></polyline>
                  </svg>
                </div>
                <div class="contact-detail-text">
                  <h4>Correo Principal (Ing. Fabio Gullacci)</h4>
                  <a href="mailto:fabiogullacci@gmail.com">fabiogullacci@gmail.com</a>
                </div>
              </div>
              
              <!-- Mail Laboral -->
              <div class="contact-detail-card">
                <div class="contact-detail-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
                    <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
                  </svg>
                </div>
                <div class="contact-detail-text">
                  <h4>Correo Institucional / Laboral</h4>
                  <a href="mailto:n3ibhi@gmail.com">n3ibhi@gmail.com</a>
                </div>
              </div>
            </div>
          </div>
          
          <div class="contact-meta">
            <h4>N3i Engineering & Maintenance</h4>
            <p style="font-size: 0.9rem;">Bahía Blanca, Provincia de Buenos Aires, Argentina.</p>
          </div>
        </div>

        <div class="contact-form-card reveal" style="transition-delay: 0.15s;">
          <h3 style="font-size: 1.4rem; margin-bottom: 6px;">Solicitud de Presupuesto Técnico</h3>
          <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 28px;">Complete los datos del proyecto para agilizar la ingeniería de preventa.</p>
          <form id="whatsapp-contact-form">

            <!-- BLOQUE A: Datos del solicitante -->
            <div class="form-group-row">
              <div class="form-group">
                <label class="form-label" for="form-name">Nombre Completo</label>
                <input type="text" id="form-name" class="form-control" placeholder="Ej: Juan Pérez" required>
              </div>
              <div class="form-group">
                <label class="form-label" for="form-role">Cargo / Rol</label>
                <input type="text" id="form-role" class="form-control" placeholder="Ej: Gerente de Operaciones" required>
              </div>
            </div>

            <div class="form-group-row">
              <div class="form-group">
                <label class="form-label" for="form-company">Empresa / Organización</label>
                <input type="text" id="form-company" class="form-control" placeholder="Ej: Industrial SA" required>
              </div>
              <div class="form-group">
                <label class="form-label" for="form-phone">Teléfono de Contacto</label>
                <input type="tel" id="form-phone" class="form-control" placeholder="Ej: +54 9 291 400-0000" required>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="form-email">Correo Electrónico</label>
              <input type="email" id="form-email" class="form-control" placeholder="Ej: juan@empresa.com" required>
            </div>

            <!-- BLOQUE B: Categorización del Proyecto -->
            <div class="form-group">
              <label class="form-label" for="form-project-type">Categoría del Proyecto</label>
              <select id="form-project-type" class="form-control" style="background-color: #111416;" required>
                <option value="" disabled selected>Seleccione el tipo de proyecto...</option>
                <option value="Vivienda Unifamiliar (Residencial)">Vivienda Unifamiliar (Residencial)</option>
                <option value="Edificio / Complejo de Departamentos">Edificio / Complejo de Departamentos</option>
                <option value="Planta Industrial / Nave Logística">Planta Industrial / Nave Logística</option>
              </select>
            </div>

            <!-- BLOQUE C: Especialidad requerida -->
            <div class="form-group">
              <label class="form-label" for="form-service">Servicio Principal Requerido</label>
              <select id="form-service" class="form-control" style="background-color: #111416;" required>
                <option value="" disabled selected>Seleccione un servicio...</option>
                <optgroup label="Abonos de Mantenimiento Mensual">
                  <option value="Abono Mantenimiento - PyME Start">Abono Mantenimiento - PyME Start</option>
                  <option value="Abono Mantenimiento - PyME Pro">Abono Mantenimiento - PyME Pro</option>
                  <option value="Abono Mantenimiento - Industrial 360">Abono Mantenimiento - Industrial 360</option>
                </optgroup>
                <optgroup label="Mantenimiento & Servicios Industriales">
                  <option value="electricidad">Electricidad Industrial & PyMEs</option>
                  <option value="Sistemas de Gas Industrial & PyMEs">Sistemas de Gas Industrial & PyMEs</option>
                  <option value="Neumática & Aire Comprimido">Neumática & Aire Comprimido</option>
                  <option value="domotica">Automatizaciones & Domótica</option>
                  <option value="Energías Renovables & Generación de Respaldo">Energías Renovables & Generación de Respaldo</option>
                </optgroup>
                <optgroup label="Instalaciones & Redes">
                  <option value="Gestión Hídrica & Plomería">Gestión Hídrica & Plomería</option>
                  <option value="Redes de Datos, Telecomunicaciones & Conectividad">Redes de Datos & Conectividad</option>
                  <option value="cctv">Seguridad, CCTV & Sistemas de Alarmas</option>
                </optgroup>
                <optgroup label="Obras, Reformas & Pintura">
                  <option value="Ingeniería Civil & Arquitectura">Ingeniería Civil & Arquitectura</option>
                  <option value="Steel Frame, Wood Frame & Construcción en Seco">Steel Frame & Construcción en Seco</option>
                  <option value="Integridad Estructural & Reparación de Techos">Integridad Estructural & Techos</option>
                  <option value="Pintura, Revestimientos & Tratamiento de Superficies">Pintura & Revestimientos</option>
                </optgroup>
                <option value="Mantenimiento General / Otros">Mantenimiento General / Otros</option>
              </select>
            </div>

            <!-- BLOQUE D: Campos condicionales por servicio -->

            <!-- Condicional: Electricidad -->
            <div id="fields-electricidad" class="conditional-fields" style="display:none;">
              <div class="conditional-fields-header">Datos técnicos — Electricidad</div>
              <div class="form-group-row">
                <div class="form-group">
                  <label class="form-label" for="form-elec-obra">Tipo de Obra</label>
                  <select id="form-elec-obra" class="form-control" style="background-color: #111416;">
                    <option value="" disabled selected>Seleccionar...</option>
                    <option value="Obra nueva">Obra nueva</option>
                    <option value="Remodelación / Ampliación">Remodelación / Ampliación</option>
                    <option value="Mantenimiento correctivo">Mantenimiento correctivo</option>
                  </select>
                </div>
                <div class="form-group">
                  <label class="form-label" for="form-elec-potencia">Potencia Estimada (kW)</label>
                  <input type="number" id="form-elec-potencia" class="form-control" placeholder="Ej: 50" min="1">
                </div>
              </div>
            </div>

            <!-- Condicional: CCTV / Seguridad -->
            <div id="fields-cctv" class="conditional-fields" style="display:none;">
              <div class="conditional-fields-header">Datos técnicos — Seguridad & CCTV</div>
              <div class="form-group">
                <label class="form-label" for="form-cctv-puntos">Cantidad de Puntos de Monitoreo (Cámaras)</label>
                <input type="number" id="form-cctv-puntos" class="form-control" placeholder="Ej: 8" min="1">
              </div>
              <div class="form-group">
                <label class="form-label">Integración Perimetral Requerida</label>
                <div class="form-checkbox-group">
                  <label class="form-checkbox-label">
                    <input type="checkbox" id="form-cctv-perimetral" value="Sí"> Sí, incluir alarma perimetral
                  </label>
                </div>
              </div>
            </div>

            <!-- Condicional: Domótica -->
            <div id="fields-domotica" class="conditional-fields" style="display:none;">
              <div class="conditional-fields-header">Metas de Automatización</div>
              <div class="form-group">
                <label class="form-label">¿Qué sistemas desea integrar? (múltiple opción)</label>
                <div class="form-checkbox-group">
                  <label class="form-checkbox-label"><input type="checkbox" name="form-domo-metas" value="Climatización multi-zona"> Climatización multi-zona</label>
                  <label class="form-checkbox-label"><input type="checkbox" name="form-domo-metas" value="Accesos / Control de apertura"> Accesos / Control de apertura</label>
                  <label class="form-checkbox-label"><input type="checkbox" name="form-domo-metas" value="Iluminación por zonas"> Iluminación por zonas</label>
                  <label class="form-checkbox-label"><input type="checkbox" name="form-domo-metas" value="Gestión de energía"> Gestión de energía</label>
                  <label class="form-checkbox-label"><input type="checkbox" name="form-domo-metas" value="Seguridad integrada (CCTV + alarma)"> Seguridad integrada (CCTV + alarma)</label>
                </div>
              </div>
            </div>

            <!-- BLOQUE F: Descripción libre -->
            <div class="form-group">
              <label class="form-label" for="form-message">Descripción del Requerimiento</label>
              <textarea id="form-message" class="form-control" placeholder="Describa el alcance del proyecto, urgencia o cualquier detalle técnico relevante..." required></textarea>
            </div>

            <button type="submit" class="btn btn-primary" id="btn-submit-wp">
              Enviar Solicitud por WhatsApp
              <span class="btn-icon">➔</span>
            </button>
          </form>
        </div>
        
      </div>
    </div>
  </section>

  <Footer />
</Layout>