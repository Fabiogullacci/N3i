---
// src/components/CalculadoraConsumoElectrico.astro
// Simulador de Consumo Eléctrico N3i (Aesthetic Green/Lime Theme)

const categories = [
  { id: 'clima', name: '🌡️ Climatización', desc: 'Aires acondicionados y termotanques' },
  { id: 'cocina', name: '🍳 Cocina', desc: 'Heladera, hornos y electrodomésticos' },
  { id: 'tecnologia', name: '💡 Iluminación y TV', desc: 'Lámparas y equipos electrónicos' },
  { id: 'limpieza', name: '🧺 Lavado y Bombeo', desc: 'Lavarropas, plancha y bombas' }
];

const appliances = [
  // Climatización y Agua Caliente
  { id: 'aire-2500', category: 'clima', name: 'Aire Acondicionado (2500 fg)', watts: 1000, defaultHours: 5, icon: '🌬️', tip: '<strong>Climatización a 24°C:</strong> En verano, cada grado menos del aire acondicionado aumenta el consumo eléctrico entre un 7% y un 10%. Limpiá los filtros mensualmente para mantener la eficiencia.' },
  { id: 'aire-4500', category: 'clima', name: 'Aire Acondicionado (4500 fg)', watts: 1800, defaultHours: 5, icon: '❄️', tip: '<strong>Climatización a 24°C:</strong> En verano, cada grado menos del aire acondicionado aumenta el consumo eléctrico entre un 7% y un 10%. Limpiá los filtros mensualmente para mantener la eficiencia.' },
  { id: 'termotanque', category: 'clima', name: 'Termotanque Eléctrico', watts: 3000, defaultHours: 3, icon: '🚿', tip: '<strong>Termotanque con Timer:</strong> Los termotanques eléctricos calientan agua continuamente. Colocar un timer programador digital para encenderlo 2 horas antes de bañarse ahorra hasta un 40% de energía.' },

  // Cocina
  { id: 'heladera', category: 'cocina', name: 'Heladera con freezer', watts: 200, defaultHours: 24, icon: '❄️', tip: '<strong>Eficiencia en Heladera:</strong> Aunque está conectada las 24hs, el motor corre unas 10-12hs reales. Asegurate de que los burletes sellen bien, no guardes comida caliente y dejá 15cm libres en la parte trasera para ventilación.' },
  { id: 'microondas', category: 'cocina', name: 'Microondas', watts: 1200, defaultHours: 0.5, icon: '🍱', tip: '<strong>Uso de Microondas:</strong> Al tener alta potencia pero tiempos cortos, es eficiente. Sin embargo, evitá usarlo para descongelar grandes cantidades; es mejor retirar los alimentos del freezer con anticipación.' },
  { id: 'pava', category: 'cocina', name: 'Pava Eléctrica', watts: 1500, defaultHours: 0.5, icon: '🫖', tip: '<strong>Medir el agua de la Pava:</strong> Calentá solo la cantidad de agua que vas a consumir en el momento. Llenar la pava al máximo para tomar una sola taza de té consume energía innecesariamente.' },
  { id: 'horno', category: 'cocina', name: 'Horno Eléctrico', watts: 2000, defaultHours: 1, icon: '🥘', tip: '<strong>Horno Eléctrico Eficiente:</strong> Evitá abrir la puerta del horno innecesariamente mientras cocina (se pierde hasta el 20% de calor). Aprovechá el calor residual apagándolo 5 minutos antes de finalizar la cocción.' },

  // Tecnología e Iluminación
  { id: 'luces-led', category: 'tecnologia', name: 'Lámparas LED (promedio)', watts: 15, defaultHours: 6, icon: '💡', tip: '<strong>Iluminación LED Inteligente:</strong> Cambiar lámparas incandescentes o halógenas por LED de alta eficiencia reduce el consumo de iluminación en un 85%. Apagá luces en ambientes desocupados.' },
  { id: 'tv', category: 'tecnologia', name: 'Televisor (LED/Smart)', watts: 100, defaultHours: 4, icon: '📺', tip: '<strong>Consumo Standby (Vampiro):</strong> Los televisores y consolas en modo de espera siguen consumiendo energía. Conectalos a una zapatilla con interruptor para apagarlos por completo al irte a dormir.' },
  { id: 'pc', category: 'tecnologia', name: 'Computadora / Notebook', watts: 200, defaultHours: 5, icon: '💻', tip: '<strong>Ahorro en Computadoras:</strong> Configurá la suspensión automática de pantalla tras 5 minutos de inactividad. El protector de pantalla animado consume casi lo mismo que el equipo en uso.' },

  // Limpieza y Bombeo
  { id: 'lavarropas', category: 'limpieza', name: 'Lavarropas Automático', watts: 800, defaultHours: 1, icon: '👕', tip: '<strong>Lavado con Agua Fría:</strong> El 90% de la energía de un lavarropas se usa para calentar el agua. Usá programas cortos y agua fría siempre que sea posible, y cargalo siempre a su máxima capacidad recomendada.' },
  { id: 'plancha', category: 'limpieza', name: 'Plancha para ropa', watts: 1200, defaultHours: 0.5, icon: '👔', tip: '<strong>Planchado Acumulativo:</strong> La plancha consume gran cantidad de energía al calentarse inicialmente. Acumulá la ropa para planchar todo de una sola vez en lugar de encenderla por una sola prenda.' },
  { id: 'bomba', category: 'limpieza', name: 'Bomba de agua (1/2 HP)', watts: 375, defaultHours: 1, icon: '💧', tip: '<strong>Eficiencia en Bombeo:</strong> Mantené el tanque de agua y cisternas limpios y sin pérdidas. Un flotante defectuoso hace que la bomba trabaje de más, elevando drásticamente el consumo y dañando el motor.' }
];
---

<section class="section section-alt" id="calc-consumo-electrico">
  <div class="container">
    <div class="section-header reveal" style="margin: 0 auto 40px auto; text-align: center;">
      <span class="section-subtitle" style="color: var(--accent);">Electricidad y Eficiencia Energética</span>
      <h2 class="section-title">Simulador de Consumo Eléctrico</h2>
      <p class="section-desc">
        Calculá tu consumo eléctrico mensual en kWh, estimá el costo en pesos ($) según tus tarifas y recibí recomendaciones de seguridad y optimización técnica para ahorrar.
      </p>
    </div>

    <div class="elec-layout-grid">
      <!-- Columna Izquierda: Entradas de Usuario -->
      <div class="elec-input-area">
        
        <!-- Pestañas de Categorías -->
        <div class="elec-tabs card reveal">
          <div class="tabs-header-scroll">
            <div class="tabs-bar">
              {categories.map((cat, idx) => (
                <button type="button" class={`tab-btn ${idx === 0 ? 'active' : ''}`} data-tab={cat.id}>
                  {cat.name}
                </button>
              ))}
            </div>
          </div>
        </div>

        <!-- Listados de Artefactos (un panel por categoría) -->
        <div class="elec-appliances card reveal" style="margin-top: 20px;">
          {categories.map((cat, idx) => (
            <div class={`elec-tab-content ${idx === 0 ? 'active' : ''}`} id={`tab-panel-${cat.id}`}>
              <h3 style="font-size: 1.2rem; margin-bottom: 5px; color: var(--text-primary);">{cat.name}</h3>
              <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 20px;">{cat.desc}</p>
              
              <div class="appliances-list">
                {appliances.filter(app => app.category === cat.id).map(app => (
                  <div class="elec-app-item" data-id={app.id} data-watts={app.watts} data-tip={app.tip}>
                    <div class="elec-app-main">
                      <div class="elec-app-info">
                        <span class="elec-app-icon">{app.icon}</span>
                        <div>
                          <span class="elec-app-name">{app.name}</span>
                          <span class="elec-app-watts">{app.watts} W (promedio)</span>
                        </div>
                      </div>
                      <div class="app-controls">
                        <button type="button" class="btn-qty elec-minus" data-target={app.id}>-</button>
                        <input type="number" class="qty-input elec-qty" id={app.id} value="0" min="0" max="99" />
                        <button type="button" class="btn-qty elec-plus" data-target={app.id}>+</button>
                      </div>
                    </div>
                    <div class="elec-app-slider-container" id={`slider-container-${app.id}`}>
                      <div class="elec-slider-header">
                        <span>Tiempo de uso diario estimado:</span>
                        <strong class="elec-hours-display"><span id={`${app.id}-display`}>{app.defaultHours.toFixed(1)}</span> hs</strong>
                      </div>
                      <input type="range" class="elec-slider" id={`${app.id}-hours`} min="0.5" max="24" step="0.5" value={app.defaultHours} />
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Columna Derecha: Parámetros Tarifarios y Resultados -->
      <div class="elec-results-area">
        
        <!-- Configuración de Tarifas -->
        <div class="card reveal" style="margin-bottom: 20px; border-top: 3px solid var(--accent);">
          <h3 style="font-size: 1.1rem; margin-bottom: 15px; color: var(--text-primary); display: flex; align-items: center; gap: 8px;">
            <span>💵</span> Configuración de Tarifas
          </h3>
          <div class="tariff-settings-grid">
            <div class="form-group">
              <label for="elec-cost-kwh" style="font-size: 0.8rem; color: var(--text-secondary); font-weight: 600;">Costo del kWh ($):</label>
              <input type="number" id="elec-cost-kwh" class="form-control form-input" value="115" min="1" step="1" />
            </div>
            <div class="form-group">
              <label for="elec-fixed-charge" style="font-size: 0.8rem; color: var(--text-secondary); font-weight: 600;">Cargo Fijo Mensual ($):</label>
              <input type="number" id="elec-fixed-charge" class="form-control form-input" value="4500" min="0" step="1" />
            </div>
          </div>
          <span style="font-size: 0.72rem; color: var(--text-muted); display: block; margin-top: 10px; line-height: 1.3;">
            * Valores editables basados en tarifas de referencia residenciales de Argentina (Junio 2026).
          </span>
        </div>

        <!-- Diagnóstico y Resultados -->
        <div class="card reveal results-sticky" style="transition-delay: 0.1s;">
          <h3 style="color: var(--accent); border-bottom: 1px solid rgba(140,198,63,0.15); padding-bottom: 10px; margin-bottom: 20px; font-size: 1.25rem;">
            Diagnóstico de Instalación
          </h3>

          <div class="kpi-grid-two">
            <div class="result-box">
              <span class="result-label">Potencia Instalada</span>
              <div class="result-value" style="font-size: 1.5rem;"><span id="elec-res-watts">0</span> W</div>
            </div>
            <div class="result-box">
              <span class="result-label">Demanda Simultánea (70%)</span>
              <div class="result-value" style="font-size: 1.5rem; color: var(--accent);"><span id="elec-res-sim-watts">0</span> W</div>
              <span class="result-note" style="display:block; margin-top:3px; font-size:0.7rem;"><span id="elec-res-amps">0.00</span> A a 220V</span>
            </div>
          </div>

          <!-- Consumo y Costo Mensual -->
          <div class="result-box elec-primary-result" style="margin-top: 15px;">
            <span class="result-label" style="color: var(--accent);">Consumo Mensual Estimado</span>
            <div class="result-value" style="color: var(--accent); font-size: 2.1rem;"><span id="elec-res-mensual-kwh">0.0</span> <span style="font-size:1.1rem; font-weight:800;">kWh</span></div>
          </div>

          <div class="result-box elec-primary-result" style="border-color: #3fc6b4; background: rgba(63, 198, 180, 0.08); margin-top: 12px;">
            <span class="result-label" style="color: #3fc6b4;">Gasto Mensual Estimado (Pesos)</span>
            <div class="result-value" style="color: #3fc6b4; font-size: 2.1rem;">$ <span id="elec-res-costo-total">0</span></div>
            <span class="result-note" id="elec-res-costo-desc" style="font-size: 0.72rem; color: var(--text-secondary); margin-top: 5px; display:block; line-height: 1.3;"></span>
          </div>

          <!-- Huella de Carbono y Protecciones -->
          <div class="kpi-grid-two" style="margin-top: 12px;">
            <div class="result-box">
              <span class="result-label">Emisiones de CO₂</span>
              <div class="result-value" style="font-size: 1.25rem; color: #a3abb2;"><span id="elec-res-co2">0.0</span> <span style="font-size:0.8rem; font-weight:600;">kg CO₂/mes</span></div>
            </div>
            <div class="result-box" id="elec-protection-badge" style="border-left: 3px solid var(--accent); text-align: left; padding: 12px;">
              <span class="result-label" style="text-align: left;">Protección Térmica Sugerida</span>
              <span id="elec-breaker-text" style="font-weight: 700; color: var(--text-primary); font-size: 0.9rem; display: block; margin-top: 3px;">Térmica general: 16A</span>
              <span id="elec-rcd-text" style="color: var(--text-secondary); font-size: 0.72rem; display: block;">Disyuntor: 25A (30mA)</span>
            </div>
          </div>

          <!-- Alerta del Estado de Consumo -->
          <div class="result-alert" id="elec-status-alert" style="margin-top: 15px; padding: 12px 15px; border-radius: 8px; font-size: 0.82rem; line-height: 1.4;">
            <strong>Carga en tablero:</strong> <span id="elec-status-title" style="font-weight: 700;">Sin consumos</span>. <span id="elec-status-desc">Agregá electrodomésticos para calcular.</span>
          </div>

          <!-- Botones de Acción -->
          <div style="margin-top: 20px; display: flex; flex-direction: column; gap: 10px;">
            <a href="/#contacto" class="btn btn-primary" style="width: 100%; justify-content: center;">
              Solicitar Auditoría en Obra
              <span class="btn-icon">➔</span>
            </a>
            <button type="button" id="elec-btn-print" class="btn btn-outline" style="width: 100%; justify-content: center; border-color: var(--accent); color: var(--text-primary); background: transparent; padding: 12px 20px;">
              Imprimir Reporte Eléctrico
              <span class="btn-icon" style="background: transparent;">🖨️</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Sección de Analizador de Optimización Dinámica (Ingeniería de Ahorro N3i) -->
    <div class="card reveal" style="margin-top: 40px; border-top: 3px solid var(--accent);" id="elec-optimizer-section">
      <h3 style="color: var(--accent); margin-bottom: 15px; display: flex; align-items: center; gap: 10px; font-size: 1.3rem;">
        <span>🔍</span> Analizador Inteligente de Consumo & Ahorro
      </h3>
      <p style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 25px; line-height: 1.5;">
        A continuación se muestran las mayores fuentes de consumo detectadas y los consejos técnicos específicos de ingeniería eléctrica para reducir gastos de manera eficiente.
      </p>
      
      <!-- Contenedor dinámico controlado por JS -->
      <div id="elec-optimizer-container">
        <!-- Rellenado por JS: Top Consumidores y Tips -->
        <div class="elec-optimizer-placeholder" style="text-align: center; padding: 30px; color: var(--text-muted);">
          <span style="font-size: 2.5rem; display: block; margin-bottom: 10px;">⚡</span>
          Seleccioná cantidades en los electrodomésticos para realizar un análisis de tus principales gastos y recibir consejos de ahorro personalizados.
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Área de Impresión del Informe Eléctrico -->
<div id="print-area-elec" class="print-only-elec">
  <div class="print-header">
    <img src="/assets/img/logo.webp" alt="Logo N3i" width="80" />
    <div>
      <h2 style="color: var(--accent);">Reporte de Demanda Eléctrica y Consumo Mensual</h2>
      <p>N3i Engineering & Maintenance</p>
    </div>
  </div>
  <div class="print-details">
    <p><strong>Fecha:</strong> <span id="elec-print-date"></span></p>
    <p><strong>Tipo de Documento:</strong> Estimación de Carga Eléctrica, Consumos y Gastos Residenciales</p>
    <p><strong>Tensión de Red:</strong> 220 V CA - Monofásico (Factor de Simultaneidad: 70%)</p>
  </div>
  
  <table class="print-table">
    <thead>
      <tr>
        <th>Cant.</th>
        <th>Electrodoméstico / Equipo</th>
        <th>Potencia Unit.</th>
        <th>Uso Diario</th>
        <th>Consumo Mensual (kWh)</th>
        <th>Gasto Mensual ($)</th>
      </tr>
    </thead>
    <tbody id="elec-print-tbody">
      <!-- Rellenado por JS -->
    </tbody>
    <tfoot>
      <tr>
        <td colspan="4" style="text-align: right;"><strong>Potencia Total Instalada (100%):</strong></td>
        <td colspan="2"><strong id="elec-print-total-w">0 W</strong></td>
      </tr>
      <tr>
        <td colspan="4" style="text-align: right;"><strong>Demanda Simultánea Real (70%):</strong></td>
        <td colspan="2"><strong id="elec-print-sim-w" style="font-size: 1.1rem;">0 W</strong></td>
      </tr>
      <tr>
        <td colspan="4" style="text-align: right;"><strong>Corriente de Tablero a Proteger (Amperaje):</strong></td>
        <td colspan="2"><strong id="elec-print-total-amps" style="font-size: 1.1rem;">0.00 A</strong></td>
      </tr>
      <tr>
        <td colspan="4" style="text-align: right; color: var(--accent);"><strong>Consumo Total Estimado del Hogar:</strong></td>
        <td colspan="2"><strong id="elec-print-total-kwh" style="font-size: 1.15rem; color: var(--accent);">0.0 kWh/mes</strong></td>
      </tr>
      <tr style="background-color: #f9f9f9;">
        <td colspan="4" style="text-align: right; font-weight: bold;">Costo Mensual Estimado Final (Subtotal + Cargo Fijo):</td>
        <td colspan="2"><strong id="elec-print-total-cost" style="font-size: 1.25rem; color: #10b981;">$ 0.00 ARS</strong></td>
      </tr>
    </tfoot>
  </table>
  
  <div style="background: rgba(140, 198, 63, 0.08); padding: 15px; border-radius: 8px; border-left: 5px solid var(--accent); margin-bottom: 20px;">
    <h3 style="margin-top: 0; color: var(--accent); font-size: 1.1rem;">Recomendación Técnica de Protecciones (Reglamentación AEA)</h3>
    <p style="font-size: 1rem; margin-bottom: 5px;"><strong>Protección Termomagnética Sugerida:</strong> <span id="elec-print-breaker" style="font-weight: 700;"></span></p>
    <p style="font-size: 1rem; margin-bottom: 5px;"><strong>Protección Diferencial Sugerida:</strong> <span id="elec-print-rcd" style="font-weight: 700;"></span></p>
    <p style="font-size: 0.9rem; margin-top: 10px; line-height: 1.4; color: #555;" id="elec-print-status-desc"></p>
  </div>

  <div class="print-footer">
    <p style="font-size: 0.8rem; margin-top: 15px;">* Nota Técnica: Los valores reflejados son una estimación de consumo simulada en base a las horas declaradas por el usuario. El dimensionamiento definitivo de conductores (cables), distribución de fases en tableros y balance de cargas en obra debe ser proyectado por un Ingeniero o Técnico matriculado de N3i conforme a la reglamentación de la Asociación Electrotécnica Argentina (AEA).</p>
    <p style="font-size: 0.8rem; margin-top: 5px;">Para coordinar un diagnóstico presencial, el contacto está disponible en <strong>www.n3i.com.ar</strong> o al WhatsApp +54 9 291 416-8232.</p>
  </div>
</div>

<style is:global>
  /* Elec Calculator Styling Layout */
  .elec-layout-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
    align-items: start;
  }

  @media (min-width: 992px) {
    .elec-layout-grid {
      grid-template-columns: 1.8fr 1.2fr;
    }
  }

  /* Tabs Navigation Styling */
  .tabs-header-scroll {
    overflow-x: auto;
    width: 100%;
    scrollbar-width: none; /* Firefox */
  }
  .tabs-header-scroll::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  .tabs-bar {
    display: flex;
    gap: 8px;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 10px;
    min-width: max-content;
    width: 100%;
  }

  .tab-btn {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    padding: 10px 18px;
    font-family: var(--font-title);
    font-size: 0.88rem;
    font-weight: 600;
    border-radius: 20px;
    cursor: pointer;
    transition: var(--transition-smooth);
  }

  .tab-btn:hover {
    color: var(--text-primary);
    border-color: rgba(140, 198, 63, 0.3);
    background: rgba(140, 198, 63, 0.03);
  }

  .tab-btn.active {
    background-color: var(--accent);
    border-color: var(--accent);
    color: #000000;
    box-shadow: 0 4px 12px var(--accent-glow);
  }

  /* Tab Panel Transitions */
  .elec-tab-content {
    display: none;
  }

  .elec-tab-content.active {
    display: block;
    animation: fadeIn 0.4s ease forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* List of items */
  .elec-app-item {
    background: var(--bg-alt, #111416);
    padding: 16px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.03);
    transition: var(--transition-smooth);
    margin-bottom: 15px;
  }

  .elec-app-item:last-child {
    margin-bottom: 0;
  }

  .elec-app-item:hover {
    border-color: rgba(140, 198, 63, 0.2);
    background: rgba(140, 198, 63, 0.01);
  }

  .elec-app-main {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 15px;
    width: 100%;
  }

  .elec-app-info {
    display: flex;
    align-items: center;
    gap: 15px;
    flex: 1;
    min-width: 0;
  }

  .elec-app-icon {
    font-size: 1.4rem;
    background: rgba(140, 198, 63, 0.08);
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .elec-app-name {
    display: block;
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.95rem;
    line-height: 1.3;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .elec-app-watts {
    display: block;
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-top: 1px;
  }

  /* Controls and Inputs Sizing */
  .app-controls {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-color);
    padding: 4px;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .btn-qty {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    border: none;
    background: var(--accent);
    color: #000000;
    font-weight: bold;
    font-size: 1.1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-smooth);
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

