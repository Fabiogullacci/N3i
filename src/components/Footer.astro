          </div>
        </a>
        <p>
          {t.desc}
        </p>
      </div>
      
      <div>
        <h4 class="footer-links-title">{t.navTitle}</h4>
        <ul class="footer-links">
          <li><a href={t.link_inicio}>{t.inicio}</a></li>
          <li><a href={t.link_nosotros}>{t.nosotros}</a></li>
          <li><a href={t.link_servicios}>{t.servicios}</a></li>
          <li><a href={t.link_abonos}>{t.abonos}</a></li>
          <li><a href={t.link_clientes}>{t.clientes}</a></li>
          <li><a href={t.link_contacto}>{t.contacto}</a></li>
        </ul>
      </div>
      
      <div>
        <h4 class="footer-links-title">{t.contactTitle}</h4>
        <ul class="footer-links" style="gap: 16px;">
          <li style="display: flex; gap: 10px; align-items: center;">
            <span class="text-accent" style="font-weight: 800;">Wp:</span>
            <a href="https://wa.me/5492914168232" target="_blank" rel="noopener noreferrer">+54 9 291 4168232</a>
          </li>
          <li style="display: flex; gap: 10px; align-items: center;">
            <span class="text-accent" style="font-weight: 800;">Mail:</span>
            <a href="mailto:fabiogullacci@gmail.com">fabiogullacci@gmail.com</a>
          </li>
          <li style="display: flex; gap: 10px; align-items: center;">
            <span class="text-accent" style="font-weight: 800;">Mail:</span>
            <a href="mailto:n3ibhi@gmail.com">n3ibhi@gmail.com</a>
          </li>
        </ul>
      </div>
      
    </div>
    
    <div class="footer-bottom">
      <p>&copy; 2026 N3i Engineering &amp; Maintenance. {t.derechos}</p>
      <p class="footer-director">
        {t.director} <strong><em>Ing. GULLACCI, Fabio</em></strong>
        <span id="sys-ref-code" style="margin-left: 12px; opacity: 0.55; font-size: 0.75rem; font-family: monospace; color: var(--text-secondary); letter-spacing: 0.5px;" title="System Reference">Ref: N3I-...</span>
      </p>
    </div>
  </div>
</footer>

<script is:inline>
  (function() {
    const sysEl = document.getElementById('sys-ref-code');
    if (!sysEl) return;

    // Clave única para el contador de visitas
    const key = 'n3i_engineering_visitor_sessions_2026';
    const storageKey = 'n3i_last_visit_timestamp';
    const apiBase = 'https://countapi.mileshilliard.com/api/v1';
    
    // Lógica de Visitante Único (24 Horas)
    const now = Date.now();
    const lastVisit = localStorage.getItem(storageKey);
    const oneDayInMs = 24 * 60 * 60 * 1000;
    
    const isNewVisit = !lastVisit || (now - parseInt(lastVisit, 10)) > oneDayInMs;
    const endpoint = isNewVisit ? 'hit' : 'get';
    
    fetch(`${apiBase}/${endpoint}/${key}`)
      .then(response => {
        if (!response.ok) throw new Error('Network error');
        return response.json();
      })
      .then(data => {
        if (data && typeof data.value === 'number') {
          sysEl.textContent = `Ref: N3I-${data.value}`;
          if (isNewVisit) {
            localStorage.setItem(storageKey, now.toString());
          }
        } else {
          sysEl.textContent = 'Ref: N3I-2026';
        }
      })
      .catch(() => {
        sysEl.textContent = 'Ref: N3I-2026';
      });
  })();
</script>

<!-- Botón Flotante de Emergencia 24/7 (WhatsApp) -->
<a href="https://wa.me/5492914168232?text=Emergencia%20T%C3%A9cnica%2024/7%20-%20Solicito%20asistencia%20inmediata%20de%20N3i" 
