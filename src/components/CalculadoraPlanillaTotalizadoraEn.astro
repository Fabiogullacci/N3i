          <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 12px; margin-bottom: 15px;">
            <div style="display: flex; gap: 10px; align-items: center; flex: 1;">
              <span style="font-size: 1.1rem; color: #3FC6B4;">🏢</span>
              <input type="text" class="calc-input tot-group-name" value="${g.nombre}" data-g-idx="${gIdx}" style="font-weight: 700; font-size: 1rem; border: none; padding: 4px 8px; background: rgba(255,255,255,0.02); max-width: 350px; border-radius: 4px;" />
            </div>
            <button type="button" class="tot-btn-del-group btn btn-outline" data-g-idx="${gIdx}" style="border-color: rgba(198,83,83,0.3); color: #C65353; font-size: 0.75rem; padding: 5px 10px;">
              🗑️ Delete Group
            </button>
          </div>
          <div class="tot-seccionales-container" style="display: flex; flex-direction: column; gap: 20px;"></div>
          
          <div style="display: flex; gap: 10px; margin-top: 15px;">
            <button type="button" class="tot-btn-add-secc btn btn-outline" data-g-idx="${gIdx}" style="font-size: 0.8rem; padding: 6px 12px; border-color: rgba(63, 198, 180, 0.4);">
              ➕ Add Tablero Seccional
            </button>
          </div>
        `;

        const seccContainer = groupCard.querySelector('.tot-seccionales-container') as HTMLDivElement;

        g.seccionales.forEach((s, sIdx) => {
          const seccBlock = document.createElement('div');
          seccBlock.style.border = '1px solid rgba(255,255,255,0.05)';
          seccBlock.style.borderRadius = '6px';
          seccBlock.style.padding = '15px';
          seccBlock.style.background = 'rgba(0,0,0,0.15)';

          seccBlock.innerHTML = `
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
              <div style="display: flex; gap: 10px; align-items: center;">
                <span style="font-size: 0.85rem; color: var(--text-muted); font-weight: 600;">Seccional:</span>
                <input type="text" class="calc-input tot-secc-name" value="${s.nombre}" data-g-idx="${gIdx}" data-s-idx="${sIdx}" style="font-weight: 700; font-size: 0.85rem; width: 120px; border: none; padding: 2px 6px; background: rgba(255,255,255,0.03); border-radius: 4px;" />
              </div>
              <button type="button" class="tot-btn-del-secc" data-g-idx="${gIdx}" data-s-idx="${sIdx}" style="background: transparent; border: none; color: #C65353; font-size: 0.8rem; cursor: pointer;" title="Delete Seccional">
                🗑️ Delete Seccional
              </button>
            </div>

            <div style="overflow-x: auto; margin-bottom: 10px;">
              <table style="width: 100%; border-collapse: collapse; min-width: 850px; font-size: 0.8rem;">
                <thead>
                  <tr style="border-bottom: 1px solid rgba(255,255,255,0.08); text-align: left;">
                    <th style="padding: 6px 4px; color: #3FC6B4;">Circuit</th>
                    <th style="padding: 6px 4px; color: #3FC6B4; text-align: center; width: 60px;">Light</th>
                    <th style="padding: 6px 4px; color: #3FC6B4; text-align: center; width: 60px;">Recep</th>
                    <th style="padding: 6px 4px; color: #3FC6B4; text-align: center; width: 65px;">Pwr/AC</th>
                    <th style="padding: 6px 4px; color: #3FC6B4; text-align: center; width: 45px;" title="Auto Calculate">Auto</th>
                    <th style="padding: 6px 4px; color: #3FC6B4; text-align: center; width: 110px;">Power (W)</th>
                    <th style="padding: 6px 4px; color: #3FC6B4; text-align: center; width: 95px;">Curr. (A)</th>
                    <th style="padding: 6px 4px; color: #3FC6B4; text-align: center; width: 70px;">Phase</th>
                    <th style="padding: 6px 4px;">Details / Remarks</th>
                    <th style="padding: 6px 4px; text-align: center; width: 70px;">Action</th>
                  </tr>
                </thead>
                <tbody class="tot-circ-tbody"></tbody>
              </table>
            </div>
            
            <button type="button" class="tot-btn-add-circ btn btn-outline" data-g-idx="${gIdx}" data-s-idx="${sIdx}" style="font-size: 0.72rem; padding: 4px 10px; border-color: rgba(255,255,255,0.1); color: var(--text-secondary);">
              ➕ Add Circuit
            </button>
          `;

          const circTbody = seccBlock.querySelector('.tot-circ-tbody') as HTMLTableSectionElement;

          s.circuitos.forEach((c, cIdx) => {
            const tr = document.createElement('tr');
            tr.style.borderBottom = '1px solid rgba(255,255,255,0.03)';
            tr.innerHTML = `
              <td style="padding: 4px 2px;">
                <input type="text" class="tot-circ-input tot-c-tag" value="${c.tag}" style="font-weight: 700;" />
              </td>
              <td style="padding: 4px 2px; text-align: center;">
                <input type="number" class="tot-circ-input tot-c-luz" value="${c.luz}" min="0" max="99" style="text-align: center;" />
              </td>
              <td style="padding: 4px 2px; text-align: center;">
                <input type="number" class="tot-circ-input tot-c-toma" value="${c.toma}" min="0" max="99" style="text-align: center;" />
              </td>
              <td style="padding: 4px 2px; text-align: center;">
                <input type="number" class="tot-circ-input tot-c-fm" value="${c.fm}" min="0" max="99" style="text-align: center;" />
              </td>
              <td style="padding: 4px 2px; text-align: center;">
                <input type="checkbox" class="tot-c-auto" ${c.auto ? 'checked' : ''} style="cursor: pointer; width: 16px; height: 16px;" title="Auto-calculate power and current" />
              </td>
              <td style="padding: 4px 2px; text-align: center;">
                <input type="number" class="tot-circ-input tot-c-potencia" value="${c.potencia}" min="0" step="50" style="text-align: center; font-weight: 700; color: #3FC6B4;" />
              </td>
              <td style="padding: 4px 2px; text-align: center;">
                <input type="number" class="tot-circ-input tot-c-corriente" value="${c.corriente.toFixed(2)}" min="0" step="0.05" style="text-align: center;" />
              </td>
              <td style="padding: 4px 2px; text-align: center;">
                <select class="tot-circ-select tot-c-fase" style="text-align: center; font-weight:600;">
                  <option value="R" ${c.fase === 'R' ? 'selected' : ''}>R</option>
                  <option value="S" ${c.fase === 'S' ? 'selected' : ''}>S</option>
                  <option value="T" ${c.fase === 'T' ? 'selected' : ''}>T</option>
                </select>
              </td>
              <td style="padding: 4px 2px;">
                <input type="text" class="tot-circ-input tot-c-detalle" value="${c.detalle}" placeholder="Receptacles" />
              </td>
              <td style="padding: 4px 2px; text-align: center;">
                <div style="display: flex; gap: 4px; justify-content: center;">
                  <button type="button" class="tot-circ-clone" title="Clone" style="background:transparent; border:none; color:#3FC6B4; cursor:pointer; font-size:1rem;">👥</button>
                  <button type="button" class="tot-circ-delete" title="Delete" style="background:transparent; border:none; color:#C65353; cursor:pointer; font-size:1rem;">🗑️</button>
                </div>
              </td>
            `;

            const inTag = tr.querySelector('.tot-c-tag') as HTMLInputElement;
            const inLuz = tr.querySelector('.tot-c-luz') as HTMLInputElement;
            const inToma = tr.querySelector('.tot-c-toma') as HTMLInputElement;
            const inFm = tr.querySelector('.tot-c-fm') as HTMLInputElement;
            const cbAuto = tr.querySelector('.tot-c-auto') as HTMLInputElement;
            const inPot = tr.querySelector('.tot-c-potencia') as HTMLInputElement;
            const inCorr = tr.querySelector('.tot-c-corriente') as HTMLInputElement;
            const inFase = tr.querySelector('.tot-c-fase') as HTMLSelectElement;
            const inDet = tr.querySelector('.tot-c-detalle') as HTMLInputElement;

            const updateData = () => {
              c.tag = inTag.value;
              c.luz = parseInt(inLuz.value) || 0;
              c.toma = parseInt(inToma.value) || 0;
              c.fm = parseInt(inFm.value) || 0;
              c.auto = cbAuto.checked;
              
              if (c.auto) {
                c.potencia = Math.round((c.luz * 100) + (c.toma * 112.5) + (c.fm * 1500));
                inPot.value = c.potencia.toString();
                c.corriente = Math.round((c.potencia / 220) * 100) / 100;
                inCorr.value = c.corriente.toFixed(2);
                
                inPot.style.opacity = '0.75';
                inCorr.style.opacity = '0.75';
              } else {
                c.potencia = parseFloat(inPot.value) || 0;
                c.corriente = parseFloat(inCorr.value) || 0;
                
                inPot.style.opacity = '1.0';
                inCorr.style.opacity = '1.0';
              }
              
              c.fase = inFase.value;
              c.detalle = inDet.value;

              renderPreview();
            };

            inTag.addEventListener('change', updateData);
            inLuz.addEventListener('change', updateData);
            inToma.addEventListener('change', updateData);
            inFm.addEventListener('change', updateData);
            inFase.addEventListener('change', updateData);
            inDet.addEventListener('change', updateData);

            cbAuto.addEventListener('change', () => {
              updateData();
            });

            inPot.addEventListener('input', () => {
              cbAuto.checked = false;
              c.auto = false;
              c.potencia = parseFloat(inPot.value) || 0;
              c.corriente = Math.round((c.potencia / 220) * 100) / 100;
              inCorr.value = c.corriente.toFixed(2);
              inPot.style.opacity = '1.0';
              inCorr.style.opacity = '1.0';
              renderPreview();
            });

            inCorr.addEventListener('input', () => {
              cbAuto.checked = false;
              c.auto = false;
              c.corriente = parseFloat(inCorr.value) || 0;
              inPot.style.opacity = '1.0';
              inCorr.style.opacity = '1.0';
              renderPreview();
            });

            tr.querySelector('.tot-circ-clone').addEventListener('click', () => {
              const maxId = Math.max(...s.circuitos.map(item => item.id));
              s.circuitos.splice(cIdx + 1, 0, {
                id: maxId + 1,
                tag: `${c.tag}_copy`,
                luz: c.luz,
                toma: c.toma,
                fm: c.fm,
                potencia: c.potencia,
                corriente: c.corriente,
                detalle: `${c.detalle} (Copy)`,
                fase: c.fase,
                auto: c.auto
              });
              renderEditor();
              renderPreview();
            });

            tr.querySelector('.tot-circ-delete').addEventListener('click', () => {
              if (s.circuitos.length <= 1) {
                alert("The board must contain at least one circuit.");
                return;
              }
              s.circuitos.splice(cIdx, 1);
              renderEditor();
              renderPreview();
            });

            if (c.auto) {
              inPot.style.opacity = '0.75';
              inCorr.style.opacity = '0.75';
            }

            circTbody.appendChild(tr);
          });

          seccBlock.querySelector('.tot-btn-add-circ').addEventListener('click', () => {
            const nextTagIndex = s.circuitos.length + 1;
            const maxId = Math.max(...s.circuitos.map(item => item.id));
            s.circuitos.push({
              id: maxId + 1,
              tag: `circ-${nextTagIndex}`,
              luz: 0,
              toma: 1,
              fm: 0,
              potencia: 2200,
              corriente: 10,
              detalle: "Receptacles",
              fase: "R",
              auto: true
            });
            renderEditor();
            renderPreview();
          });

          const inSeccName = seccBlock.querySelector('.tot-secc-name') as HTMLInputElement;
          inSeccName.addEventListener('input', () => {
            s.nombre = inSeccName.value;
            renderPreview();
          });

          seccBlock.querySelector('.tot-btn-del-secc').addEventListener('click', () => {
            if (g.seccionales.length <= 1) {
              alert("The group must have at least one Tablero Seccional.");
              return;
            }
            g.seccionales.splice(sIdx, 1);
            renderEditor();
            renderPreview();
          });

          seccContainer.appendChild(seccBlock);
        });

        groupCard.querySelector('.tot-group-name').addEventListener('change', (e: Event) => {
          const target = e.target as HTMLInputElement;
          g.nombre = target.value;
          renderPreview();
        });

        groupCard.querySelector('.tot-btn-del-group').addEventListener('click', () => {
          if (grupos.length <= 1) {
            alert("At least one board group must exist.");
            return;
          }
          grupos.splice(gIdx, 1);
          renderEditor();
          renderPreview();
        });

        groupCard.querySelector('.tot-btn-add-secc').addEventListener('click', () => {
          const nextSId = g.seccionales.length + 1;
          const maxId = Math.max(...g.seccionales.map(item => item.id));
          g.seccionales.push({
            id: maxId + 1,
            nombre: `TS-0${nextSId}`,
            circuitos: [
              { id: maxId * 10 + 1, tag: "t-01", luz: 0, toma: 8, fm: 0, potencia: 900, corriente: 4.10, detalle: "Receptacles", fase: "R", auto: true }
            ]
          });
          renderEditor();
          renderPreview();
        });

        editorContainer.appendChild(groupCard);
      });
    }

    function renderPreview() {
      if (!previewTbody) return;
      previewTbody.innerHTML = '';

      const printTbody = document.getElementById('tot-print-tbody');
      if (printTbody) printTbody.innerHTML = '';

      let globalLuz = 0;
      let globalToma = 0;
      let globalFm = 0;
      let globalPotencia = 0;
      let globalCorriente = 0;

      let loadFaseR = 0;
      let loadFaseS = 0;
      let loadFaseT = 0;

      let totalCircuitosYSubtotales = 0;
      grupos.forEach(g => {
        g.seccionales.forEach(s => {
          totalCircuitosYSubtotales += s.circuitos.length;
        });
        totalCircuitosYSubtotales += 1;
      });

      let isFirstRow = true;

      grupos.forEach((g) => {
        let grupoLuz = 0, grupoToma = 0, grupoFm = 0, grupoPotencia = 0, grupoCorriente = 0;

        g.seccionales.forEach((s) => {
          const seccRowspan = s.circuitos.length;
          let isFirstSeccRow = true;

          s.circuitos.forEach((c) => {
            grupoLuz += c.luz;
            grupoToma += c.toma;
            grupoFm += c.fm;
            grupoPotencia += c.potencia;
            grupoCorriente += c.corriente;

            globalLuz += c.luz;
            globalToma += c.toma;
            globalFm += c.fm;
            globalPotencia += c.potencia;
            globalCorriente += c.corriente;

            if (c.fase === 'R') loadFaseR += c.potencia;
            else if (c.fase === 'S') loadFaseS += c.potencia;
            else if (c.fase === 'T') loadFaseT += c.potencia;

            const tr = document.createElement('tr');
            tr.style.borderBottom = '1px solid var(--border-color)';

            let html = '';

            if (isFirstRow) {
              html += `
                <td rowspan="${totalCircuitosYSubtotales}" style="border-right: 1px solid rgba(63, 198, 180, 0.2); border-bottom: 1px solid rgba(63, 198, 180, 0.2); padding: 10px; text-align: center; font-weight: 800; color: #3FC6B4; vertical-align: middle; background: rgba(63, 198, 180, 0.02);">
                  ${generalName}
                </td>
              `;
              isFirstRow = false;
            }

            if (isFirstSeccRow) {
              html += `
                <td rowspan="${seccRowspan}" style="border-right: 1px solid rgba(63, 198, 180, 0.15); border-bottom: 1px solid rgba(255,255,255,0.05); padding: 10px; text-align: center; font-weight: 700; color: var(--text-primary); vertical-align: middle; background: rgba(255,255,255,0.01);">
                  ${s.nombre}
                </td>
              `;
              isFirstSeccRow = false;
            }

            html += `
              <td style="border-right: 1px solid rgba(255,255,255,0.05); padding: 8px 10px; font-weight: 600;">${c.tag}</td>
              <td style="border-right: 1px solid rgba(255,255,255,0.05); padding: 8px 10px; text-align: center; color: var(--text-muted);">${c.luz || ''}</td>
              <td style="border-right: 1px solid rgba(255,255,255,0.05); padding: 8px 10px; text-align: center; color: var(--text-muted);">${c.toma || ''}</td>
              <td style="border-right: 1px solid rgba(255,255,255,0.05); padding: 8px 10px; text-align: center; color: var(--text-muted);">${c.fm || ''}</td>
              <td style="border-right: 1px solid rgba(255,255,255,0.05); padding: 8px 10px; text-align: center; font-weight: 600;">${c.potencia}</td>
              <td style="border-right: 1px solid rgba(255,255,255,0.05); padding: 8px 10px; text-align: center;">${c.corriente.toFixed(2)}</td>
              <td style="padding: 8px 10px; color: var(--text-secondary);">${c.detalle}</td>
            `;

            tr.innerHTML = html;
            previewTbody.appendChild(tr);

            if (printTbody) {
              const ptr = document.createElement('tr');
              ptr.style.borderBottom = '1px solid #000';
              let phtml = '';

              if (tr.querySelector('[rowspan="' + totalCircuitosYSubtotales + '"]')) {
                phtml += `<td rowspan="${totalCircuitosYSubtotales}" style="border: 1px solid #000; padding: 6px; text-align: center; font-weight: 800; vertical-align: middle;">${generalName}</td>`;
              }
              if (tr.querySelector('[rowspan="' + seccRowspan + '"]')) {
                phtml += `<td rowspan="${seccRowspan}" style="border: 1px solid #000; padding: 6px; text-align: center; font-weight: 700; vertical-align: middle;">${s.nombre}</td>`;
              }

              phtml += `
                <td style="border: 1px solid #000; padding: 6px; font-weight: 700;">${c.tag}</td>
                <td style="border: 1px solid #000; padding: 6px; text-align: center;">${c.luz || ''}</td>
                <td style="border: 1px solid #000; padding: 6px; text-align: center;">${c.toma || ''}</td>
                <td style="border: 1px solid #000; padding: 6px; text-align: center;">${c.fm || ''}</td>
                <td style="border: 1px solid #000; padding: 6px; text-align: center; font-weight: 700;">${c.potencia}</td>
                <td style="border: 1px solid #000; padding: 6px; text-align: center;">${c.corriente.toFixed(2)}</td>
                <td style="border: 1px solid #000; padding: 6px;">${c.detalle}</td>
              `;
              ptr.innerHTML = phtml;
              printTbody.appendChild(ptr);
            }
          });
        });

        const trTotal = document.createElement('tr');
        trTotal.style.background = 'rgba(63, 198, 180, 0.04)';
        trTotal.style.borderBottom = '1.5px solid rgba(63, 198, 180, 0.3)';
        trTotal.style.fontWeight = '800';

        const kvaGrupo = Math.round(grupoPotencia / 1000);
        const ampFaseGrupo = Math.round(grupoPotencia / 658);

        trTotal.innerHTML = `
          <td colspan="2" style="border-right: 1px solid rgba(255,255,255,0.05); padding: 8px 10px; color: #3FC6B4; text-transform: uppercase; text-align: center;">TOTALS</td>
          <td style="border-right: 1px solid rgba(255,255,255,0.05); padding: 8px 10px; text-align: center; color: #3FC6B4;">${grupoLuz}</td>
          <td style="border-right: 1px solid rgba(255,255,255,0.05); padding: 8px 10px; text-align: center; color: #3FC6B4;">${grupoToma}</td>
          <td style="border-right: 1px solid rgba(255,255,255,0.05); padding: 8px 10px; text-align: center; color: #3FC6B4;">${grupoFm}</td>
          <td style="border-right: 1px solid rgba(255,255,255,0.05); padding: 8px 10px; text-align: center; color: #3FC6B4;">${grupoPotencia}</td>
          <td style="border-right: 1px solid rgba(255,255,255,0.05); padding: 8px 10px; text-align: center; color: #3FC6B4;">${grupoCorriente.toFixed(2)}</td>
          <td style="padding: 8px 10px; color: #3FC6B4;">Total ${kvaGrupo}kVA ${ampFaseGrupo}A p/Phase.</td>
        `;
        previewTbody.appendChild(trTotal);

        if (printTbody) {
          const ptrTotal = document.createElement('tr');
          ptrTotal.style.backgroundColor = '#eaeaea';
          ptrTotal.style.fontWeight = '800';
          ptrTotal.innerHTML = `
            <td colspan="2" style="border: 1px solid #000; padding: 6px; text-align: center; text-transform: uppercase;">TOTALS</td>
            <td style="border: 1px solid #000; padding: 6px; text-align: center;">${grupoLuz}</td>
            <td style="border: 1px solid #000; padding: 6px; text-align: center;">${grupoToma}</td>
            <td style="border: 1px solid #000; padding: 6px; text-align: center;">${grupoFm}</td>
            <td style="border: 1px solid #000; padding: 6px; text-align: center;">${grupoPotencia}</td>
            <td style="border: 1px solid #000; padding: 6px; text-align: center;">${grupoCorriente.toFixed(2)}</td>
            <td style="border: 1px solid #000; padding: 6px; font-weight: 800;">Total ${kvaGrupo}kVA ${ampFaseGrupo}A p/Phase.</td>
          `;
          printTbody.appendChild(ptrTotal);
        }
      });

      const trGral = document.createElement('tr');
      trGral.style.background = 'rgba(63, 198, 180, 0.12)';
      trGral.style.borderTop = '2px solid #3FC6B4';
      trGral.style.borderBottom = '2.5px solid #3FC6B4';
      trGral.style.fontWeight = '900';
      trGral.style.fontSize = '0.85rem';

      const kvaGral = Math.round(globalPotencia / 1000);
      const ampFaseGral = Math.round(globalPotencia / 658);

      trGral.innerHTML = `
        <td colspan="3" style="border-right: 1px solid rgba(255,255,255,0.05); padding: 10px; color: #3FC6B4; text-transform: uppercase; text-align: center;">TOTALS</td>
        <td style="border-right: 1px solid rgba(255,255,255,0.05); padding: 10px; text-align: center; color: #3FC6B4;">${globalLuz}</td>
        <td style="border-right: 1px solid rgba(255,255,255,0.05); padding: 10px; text-align: center; color: #3FC6B4;">${globalToma}</td>
        <td style="border-right: 1px solid rgba(255,255,255,0.05); padding: 10px; text-align: center; color: #3FC6B4;">${globalFm}</td>
        <td style="border-right: 1px solid rgba(255,255,255,0.05); padding: 10px; text-align: center; color: #3FC6B4;">${globalPotencia}</td>
        <td style="border-right: 1px solid rgba(255,255,255,0.05); padding: 10px; text-align: center; color: #3FC6B4;">${globalCorriente.toFixed(2)}</td>
        <td style="padding: 10px; color: #3FC6B4;">Total ${kvaGral}kVA ${ampFaseGral}A p/Phase.</td>
      `;
      previewTbody.appendChild(trGral);

      if (printTbody) {
        const ptrGral = document.createElement('tr');
        ptrGral.style.backgroundColor = '#d5d5d5';
        ptrGral.style.fontWeight = '900';
        ptrGral.innerHTML = `
          <td colspan="3" style="border: 1.5px solid #000; padding: 8px; text-align: center; text-transform: uppercase;">TOTALS</td>
          <td style="border: 1.5px solid #000; padding: 8px; text-align: center;">${globalLuz}</td>
          <td style="border: 1.5px solid #000; padding: 8px; text-align: center;">${globalToma}</td>
          <td style="border: 1.5px solid #000; padding: 8px; text-align: center;">${globalFm}</td>
          <td style="border: 1.5px solid #000; padding: 8px; text-align: center;">${globalPotencia}</td>
          <td style="border: 1.5px solid #000; padding: 8px; text-align: center;">${globalCorriente.toFixed(2)}</td>
          <td style="border: 1.5px solid #000; padding: 8px; font-weight: 900;">Total ${kvaGral}kVA ${ampFaseGral}A p/Phase.</td>
        `;
        printTbody.appendChild(ptrGral);
      }

      if (rPotInst) rPotInst.textContent = `${globalPotencia.toLocaleString('en-US')} W`;
      if (rPotKva) rPotKva.textContent = `${(globalPotencia / 1000).toFixed(1)} kVA`;

      let sumRecomendado = 'Monofásico';
      let sumDesc = 'Standard single-phase utility connection (L + N, 32A fuse).';
      if ((globalPotencia / 1000) > 7.0) {
        sumRecomendado = 'Trifásico';
        sumDesc = 'Three-phase supply connection required. Exceeds the 7.0 kVA limit defined by local utility EDES for single-phase lines.';
      }

      if (rSuministro) {
        rSuministro.textContent = sumRecomendado === 'Trifásico' ? 'THREE-PHASE' : 'SINGLE-PHASE';
        rSuministro.style.color = sumRecomendado === 'Trifásico' ? '#00d2ff' : '#3FC6B4';
      }
      if (rSuministroDesc) rSuministroDesc.textContent = sumDesc;

      if (rAlertEdes) {
        if (sumRecomendado === 'Trifásico') {
          rAlertEdes.style.display = 'block';
          rAlertEdes.innerHTML = `⚠️ <strong>Utility EDES (Bahía Blanca):</strong> Total simultaneous load (${(globalPotencia / 1000).toFixed(1)} kVA) exceeds the 7.0 kVA single-phase threshold. You must build a three-phase connection pillar with minimum $4\\times10\\text{ mm²}$ concentric wire and submit certified professional documentation.`;
        } else {
          rAlertEdes.style.display = 'none';
        }
      }

      if (rValFaseR) rValFaseR.textContent = `${loadFaseR.toLocaleString('en-US')} W`;
      if (rValFaseS) rValFaseS.textContent = `${loadFaseS.toLocaleString('en-US')} W`;
      if (rValFaseT) rValFaseT.textContent = `${loadFaseT.toLocaleString('en-US')} W`;

      const ampR = loadFaseR / 220;
      const ampS = loadFaseS / 220;
      const ampT = loadFaseT / 220;

      if (rAmpFaseR) rAmpFaseR.textContent = `${ampR.toFixed(1)} A`;
      if (rAmpFaseS) rAmpFaseS.textContent = `${ampS.toFixed(1)} A`;
      if (rAmpFaseT) rAmpFaseT.textContent = `${ampT.toFixed(1)} A`;

      const sumFases = loadFaseR + loadFaseS + loadFaseT;
      if (sumFases > 0) {
        const avgLoad = sumFases / 3;
        const diffR = Math.abs(loadFaseR - avgLoad);
        const diffS = Math.abs(loadFaseS - avgLoad);
        const diffT = Math.abs(loadFaseT - avgLoad);
        const maxDiff = Math.max(diffR, diffS, diffT);
        const unbalancePerc = (maxDiff / avgLoad) * 100;

        if (rFasesStatusText) {
          if (unbalancePerc < 15) {
            rFasesStatusText.textContent = `${unbalancePerc.toFixed(1)}% (Balanced)`;
            rFasesStatusText.style.color = '#8CC63F';
            if (rFasesIndicator) rFasesIndicator.style.backgroundColor = '#8CC63F';
          } else if (unbalancePerc < 30) {
            rFasesStatusText.textContent = `${unbalancePerc.toFixed(1)}% (Mild Unbalance)`;
            rFasesStatusText.style.color = '#ffd700';
            if (rFasesIndicator) rFasesIndicator.style.backgroundColor = '#ffd700';
          } else {
            rFasesStatusText.textContent = `${unbalancePerc.toFixed(1)}% (Critical Unbalance)`;
            rFasesStatusText.style.color = '#C65353';
            if (rFasesIndicator) rFasesIndicator.style.backgroundColor = '#C65353';
          }
        }
      } else {
        if (rFasesStatusText) rFasesStatusText.textContent = '0.0% (No Load)';
        if (rFasesIndicator) rFasesIndicator.style.backgroundColor = '#555';
      }

      const pPotTotal = document.getElementById('tot-print-pot-total');
      const pResumenFase = document.getElementById('tot-print-resumen-fase');
      const pTipoSum = document.getElementById('tot-print-tipo-suministro');

      if (pPotTotal) pPotTotal.textContent = `${globalPotencia.toLocaleString('en-US')}`;
      if (pResumenFase) pResumenFase.textContent = `${kvaGral}kVA ${ampFaseGral}A p/Phase.`;
      if (pTipoSum) pTipoSum.textContent = sumRecomendado === 'Trifásico' ? 'Three-Phase' : 'Single-Phase';

      calcularIcc();
    }

    function calcularIcc() {
      if (!iIccDistancia || !rValIcc) return;

      const dist = parseFloat(iIccDistancia.value) || 15;
      const seccion = parseFloat(sIccSeccion.value) || 10;
      
      const rCable = (2 * 0.018 * dist) / seccion;
      const zTotal = 0.035 + rCable;
      const icc = 220 / zTotal;
      const iccK = icc / 1000;

      rValIcc.textContent = `${iccK.toFixed(2)} kA`;

      const rIccRec = document.getElementById('tot-val-icc-rec');
      if (rIccRec) {
        if (iccK > 4.5) {
          rIccRec.innerHTML = `Suggested breaker breaking capacity: <strong>≥ 6.0 kA</strong> (High short circuit risk, feeder close to utility transformer).`;
          rIccRec.style.color = '#C65353';
        } else {
          rIccRec.innerHTML = `Suggested breaker breaking capacity: <strong>≥ 4.5 kA</strong> (Standard residential utility threshold).`;
          rIccRec.style.color = 'var(--text-muted)';
        }
      }
    }

    const btnCopyCad = document.getElementById('tot-btn-copy-cad');
    if (btnCopyCad) {
      btnCopyCad.addEventListener('click', () => {
        let text = "BOARDS\t\tCircuit\tNo. Outlets\t\t\tPOWER\tCURRENT\tDETAILS / REMARKS\r\n";
        text += "Gen\tSub\t\tLight\tRecep\tPwr/AC\t(W)\t(A)\t\r\n";

        grupos.forEach((g) => {
          let grupoLuz = 0, grupoToma = 0, grupoFm = 0, grupoPotencia = 0, grupoCorriente = 0;

          g.seccionales.forEach((s) => {
            s.circuitos.forEach((c) => {
              grupoLuz += c.luz;
              grupoToma += c.toma;
              grupoFm += c.fm;
              grupoPotencia += c.potencia;
              grupoCorriente += c.corriente;

              const cLuz = c.luz ? c.luz.toString() : "";
              const cToma = c.toma ? c.toma.toString() : "";
              const cFm = c.fm ? c.fm.toString() : "";

              text += `${generalName}\t${s.nombre}\t${c.tag}\t${cLuz}\t${cToma}\t${cFm}\t${c.potencia}\t${c.corriente.toFixed(2)}\t${c.detalle}\r\n`;
            });
          });

          const kvaGrupo = Math.round(grupoPotencia / 1000);
          const ampFaseGrupo = Math.round(grupoPotencia / 658);

          text += `\tTOTALS\t\t${grupoLuz}\t${grupoToma}\t${grupoFm}\t${grupoPotencia}\t${grupoCorriente.toFixed(2)}\tTotal ${kvaGrupo}kVA ${ampFaseGrupo}A p/Phase.\r\n`;
        });

        let totalLuz = 0, totalToma = 0, totalFm = 0, totalPotencia = 0, totalCorriente = 0;
        grupos.forEach(g => {
          g.seccionales.forEach(s => {
            s.circuitos.forEach(c => {
              totalLuz += c.luz;
              totalToma += c.toma;
              totalFm += c.fm;
              totalPotencia += c.potencia;
              totalCorriente += c.corriente;
            });
          });
        });

        const kvaGral = Math.round(totalPotencia / 1000);
        const ampFaseGral = Math.round(totalPotencia / 658);

        text += `TOTALS\t\t\t${totalLuz}\t${totalToma}\t${totalFm}\t${totalPotencia}\t${totalCorriente.toFixed(2)}\tTotal ${kvaGral}kVA ${ampFaseGral}A p/Phase.\r\n`;

        navigator.clipboard.writeText(text).then(() => {
          const originalText = btnCopyCad.innerHTML;
          btnCopyCad.innerHTML = "Copied for AutoCAD! 🚀";
          setTimeout(() => {
            btnCopyCad.innerHTML = originalText;
          }, 2000);
        }).catch(err => {
          alert("Clipboard error: " + err);
        });
      });
    }

    const btnCsv = document.getElementById('tot-btn-csv');
    if (btnCsv) {
      btnCsv.addEventListener('click', () => {
        let csvContent = "data:text/csv;charset=utf-8,";
        csvContent += "Gen Board,Sub Board,Circuit,Outlets Light,Outlets Recep,Outlets Power/AC,Power (W),Current (A),Details / Remarks\r\n";

        grupos.forEach((g) => {
          let grupoLuz = 0, grupoToma = 0, grupoFm = 0, grupoPotencia = 0, grupoCorriente = 0;

          g.seccionales.forEach((s) => {
            s.circuitos.forEach((c) => {
              grupoLuz += c.luz;
              grupoToma += c.toma;
              grupoFm += c.fm;
              grupoPotencia += c.potencia;
              grupoCorriente += c.corriente;

              csvContent += `"${generalName}","${s.nombre}","${c.tag}",${c.luz || ''},${c.toma || ''},${c.fm || ''},${c.potencia},${c.corriente.toFixed(2)},"${c.detalle}"\r\n`;
            });
          });

          const kvaGrupo = Math.round(grupoPotencia / 1000);
          const ampFaseGrupo = Math.round(grupoPotencia / 658);

          csvContent += `,"TOTALS",,${grupoLuz},${grupoToma},${grupoFm},${grupoPotencia},${grupoCorriente.toFixed(2)},"Total ${kvaGrupo}kVA ${ampFaseGrupo}A p/Phase."\r\n`;
        });

        let totalLuz = 0, totalToma = 0, totalFm = 0, totalPotencia = 0, totalCorriente = 0;
        grupos.forEach(g => {
          g.seccionales.forEach(s => {
            s.circuitos.forEach(c => {
              totalLuz += c.luz;
              totalToma += c.toma;
              totalFm += c.fm;
              totalPotencia += c.potencia;
              totalCorriente += c.corriente;
            });
          });
        });

        const kvaGral = Math.round(totalPotencia / 1000);
        const ampFaseGral = Math.round(totalPotencia / 658);

        csvContent += `"TOTALS",,,,${totalLuz},${totalToma},${totalFm},${totalPotencia},${totalCorriente.toFixed(2)},"Total ${kvaGral}kVA ${ampFaseGral}A p/Phase."\r\n`;

        const encodedUri = encodeURI(csvContent);
        const link = document.createElement("a");
        link.setAttribute("href", encodedUri);
        link.setAttribute("download", `Load_Sheet_${generalName.replace(/\s+/g, '_')}.csv`);
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
      });
    }

    const btnPrint = document.getElementById('tot-btn-print');
    if (btnPrint) {
      btnPrint.addEventListener('click', () => {
        const pDate = document.getElementById('tot-print-fecha');
        if (pDate) {
          const today = new Date();
          pDate.textContent = today.toLocaleDateString('en-US') + ' ' + today.toLocaleTimeString('en-US');
        }

        document.body.classList.add('printing-tot');
        window.print();
        window.addEventListener('afterprint', () => document.body.classList.remove('printing-tot'), { once: true });
      });
    }

    renderEditor();
    renderPreview();
  });
</script>

