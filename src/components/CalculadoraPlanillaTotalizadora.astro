---
// src/components/CalculadoraPlanillaTotalizadora.astro
// Generador de Planilla Totalizadora Reglamentaria Bahía Blanca (Colegio/Electromecánica) - Theme Teal (#3FC6B4)
---
<section class="section section-alt" id="calc-planilla-totalizadora">
  <div class="container">
    <div class="section-header reveal" style="margin: 0 auto 40px auto; text-align: center;">
      <span class="section-subtitle" style="color: #3FC6B4;">Ingeniería Eléctrica y Normativa</span>
      <h2 class="section-title">Planilla Totalizadora Eléctrica (Colegio/Municipio)</h2>
      <p class="section-desc">
        Cree, edite y dimensione la planilla de cargas y circuitos según el formato homologado exigido por el Colegio de Ingenieros y el Departamento de Electromecánica de Bahía Blanca.
      </p>
    </div>

    <!-- Panel Superior: Nombre del Tablero General -->
    <div class="card reveal" style="border-top: 3px solid #3FC6B4; margin-bottom: 25px; padding: 20px;">
      <div style="display: flex; gap: 20px; flex-wrap: wrap; align-items: flex-end;">
        <div class="form-group" style="flex: 1; min-width: 250px; margin-bottom: 0;">
          <label for="tot-general-name" style="font-weight: 700; color: #3FC6B4;">Tablero General (TG) / Nombre de la Obra</label>
          <input type="text" id="tot-general-name" class="calc-input" value="TG Protecciones (Edificio Chiclana 680)" style="font-weight: 700; font-size: 1.1rem; border-color: rgba(63, 198, 180, 0.3);" />
        </div>
        <div style="display: flex; gap: 10px;">
          <button type="button" id="tot-btn-add-group" class="btn btn-outline" style="border-color: #3FC6B4; color: var(--text-primary); font-size: 0.85rem; padding: 10px 16px;">
            <span>➕</span> Agregar Grupo/Sector
          </button>
          <button type="button" id="tot-btn-reset-full" class="btn btn-outline" style="border-color: rgba(255,255,255,0.1); color: var(--text-muted); font-size: 0.85rem; padding: 10px 16px;">
            <span>🔄</span> Restablecer Ejemplo
          </button>
        </div>
      </div>
    </div>

    <!-- EDITOR DE GRUPOS Y CIRCUITOS -->
    <div id="tot-editor-container" class="reveal" style="margin-bottom: 30px;">
      <!-- Rellenado dinámicamente por JS en modo edición estructurada -->
    </div>

    <!-- VISTA PREVIA DE LA PLANILLA REGLAMENTARIA (HOMOLOGADA) -->
    <div class="card reveal" style="border-top: 3px solid #3FC6B4; margin-bottom: 30px; padding: 25px;">
      <h3 style="color: #3FC6B4; border-bottom: 1px solid rgba(63, 198, 180, 0.15); padding-bottom: 12px; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
        <span>📋 Vista Previa de Planilla Reglamentaria</span>
        <span style="font-size: 0.8rem; background: rgba(63, 198, 180, 0.1); padding: 4px 10px; border-radius: 20px; color: #3FC6B4; border: 1px solid rgba(63, 198, 180, 0.2);">Formato Homologado Colegio</span>
      </h3>

      <div style="overflow-x: auto; margin-bottom: 20px; border: 1px solid var(--border-color); border-radius: 8px; background: rgba(0,0,0,0.25);">
        <table class="planilla-table" style="width: 100%; border-collapse: collapse; min-width: 950px; text-align: left; font-size: 0.82rem; color: var(--text-primary);">
          <thead>
            <tr style="background: rgba(63, 198, 180, 0.08); border-bottom: 1px solid rgba(63, 198, 180, 0.25);">
              <th colspan="2" style="padding: 10px; text-align: center; color: #3FC6B4; border-right: 1px solid rgba(63, 198, 180, 0.2); font-weight: 700;">TABLEROS</th>
              <th rowspan="2" style="padding: 10px; color: #3FC6B4; border-right: 1px solid rgba(63, 198, 180, 0.2); font-weight: 700; width: 100px;">Circuito</th>
              <th colspan="3" style="padding: 10px; text-align: center; color: #3FC6B4; border-right: 1px solid rgba(63, 198, 180, 0.2); font-weight: 700;">Nº Bocas</th>
              <th rowspan="2" style="padding: 10px; text-align: center; color: #3FC6B4; border-right: 1px solid rgba(63, 198, 180, 0.2); font-weight: 700; width: 110px;">POTENCIA (W)</th>
              <th rowspan="2" style="padding: 10px; text-align: center; color: #3FC6B4; border-right: 1px solid rgba(63, 198, 180, 0.2); font-weight: 700; width: 100px;">INTENSIDAD (A)</th>
              <th rowspan="2" style="padding: 10px; color: #3FC6B4; font-weight: 700;">DETALLE / OBSERVACIONES</th>
            </tr>
            <tr style="background: rgba(63, 198, 180, 0.04); border-bottom: 1px solid rgba(63, 198, 180, 0.2);">
              <th style="padding: 6px 10px; text-align: center; color: #3FC6B4; border-right: 1px solid rgba(63, 198, 180, 0.15); font-size: 0.75rem; font-weight: 600; width: 150px;">Gral</th>
              <th style="padding: 6px 10px; text-align: center; color: #3FC6B4; border-right: 1px solid rgba(63, 198, 180, 0.2); font-size: 0.75rem; font-weight: 600; width: 100px;">Secc</th>
              <th style="padding: 6px 10px; text-align: center; color: #3FC6B4; border-right: 1px solid rgba(63, 198, 180, 0.15); font-size: 0.75rem; font-weight: 600; width: 60px;">Luz</th>
              <th style="padding: 6px 10px; text-align: center; color: #3FC6B4; border-right: 1px solid rgba(63, 198, 180, 0.15); font-size: 0.75rem; font-weight: 600; width: 60px;">Toma</th>
              <th style="padding: 6px 10px; text-align: center; color: #3FC6B4; border-right: 1px solid rgba(63, 198, 180, 0.2); font-size: 0.75rem; font-weight: 600; width: 65px;">FM/AA</th>
            </tr>
          </thead>
          <tbody id="planilla-preview-tbody">
            <!-- Rellenado dinámicamente con rowspans -->
          </tbody>
        </table>
      </div>

      <!-- Botones de Acción / Descarga -->
      <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-top: 20px;">
        <button type="button" id="tot-btn-copy-cad" class="btn btn-primary" style="flex: 1.5; min-width: 200px; justify-content: center; background: #3FC6B4; color: #000; box-shadow: 0 4px 15px rgba(63, 198, 180, 0.3); font-weight: 700;">
          Copiar para AutoCAD (Tabla) 📋
        </button>
        <button type="button" id="tot-btn-csv" class="btn btn-outline" style="flex: 1; min-width: 140px; border-color: rgba(255,255,255,0.1); justify-content: center;">
          Descargar Excel (CSV) 📊
        </button>
        <button type="button" id="tot-btn-print" class="btn btn-outline" style="flex: 1; min-width: 140px; border-color: #3FC6B4; color: var(--text-primary); background: transparent; justify-content: center;">
          Imprimir Memoria Técnica 🖨️
        </button>
      </div>
    </div>

    <!-- Panel de Notas / Observaciones Generales de la Obra -->
    <div class="card reveal" style="border-top: 3px solid #3FC6B4; margin-bottom: 25px; padding: 20px;">
      <label for="tot-general-notes" style="font-weight: 700; color: #3FC6B4; display: block; margin-bottom: 10px;">📝 Notas / Observaciones Generales (Se incluirán al pie de la Memoria Técnica de obra)</label>
      <textarea id="tot-general-notes" class="calc-input" rows="3" style="width: 100%; height: auto; resize: vertical; font-family: inherit; font-size: 0.9rem; border-color: rgba(63, 198, 180, 0.15);" placeholder="Ej: La caída de tensión máxima admitida desde la acometida hasta el tablero seccional más alejado no superará el 3%. Las protecciones y conductores cumplen con la norma AEA 90364-7-771."></textarea>
    </div>

    <!-- Diagnósticos Eléctricos Opcionales -->
    <div class="calculator-grid">
      <!-- Balanceo de Fases -->
      <div class="card reveal" style="border-top: 3px solid #3FC6B4;">
        <h3 style="color: #3FC6B4; border-bottom: 1px solid rgba(63, 198, 180, 0.15); padding-bottom: 10px; margin-bottom: 20px;">
          ⚖️ Balanceo de Fases (Diagnóstico)
        </h3>
        <p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 20px; line-height: 1.4;">
          Distribuya las cargas monofásicas en fases <strong>R, S y T</strong> en el menú del editor de circuitos para minimizar el desequilibrio y evitar penalizaciones de la distribuidora.
        </p>

        <div class="kpi-grid-three" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 20px;">
          <div class="result-box" style="text-align: center; padding: 12px 8px;">
            <span class="result-label" style="font-weight: 700; color: #ff3366;">Fase R</span>
            <div id="tot-val-faseR" style="font-size: 1.15rem; font-weight: 800; margin-top: 5px;">0 W</div>
            <small id="tot-amp-faseR" style="color: var(--text-muted); font-size: 0.72rem;">0.0 A</small>
          </div>
          <div class="result-box" style="text-align: center; padding: 12px 8px;">
            <span class="result-label" style="font-weight: 700; color: #00d2ff;">Fase S</span>
            <div id="tot-val-faseS" style="font-size: 1.15rem; font-weight: 800; margin-top: 5px;">0 W</div>
            <small id="tot-amp-faseS" style="color: var(--text-muted); font-size: 0.72rem;">0.0 A</small>
          </div>
          <div class="result-box" style="text-align: center; padding: 12px 8px;">
            <span class="result-label" style="font-weight: 700; color: #ffd700;">Fase T</span>
            <div id="tot-val-faseT" style="font-size: 1.15rem; font-weight: 800; margin-top: 5px;">0 W</div>
            <small id="tot-amp-faseT" style="color: var(--text-muted); font-size: 0.72rem;">0.0 A</small>
          </div>
        </div>

        <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 8px; padding: 12px 15px; display: flex; justify-content: space-between; align-items: center;">
          <div>
            <span style="font-size: 0.8rem; color: var(--text-secondary); display: block;">Desequilibrio entre Fases:</span>
            <strong id="tot-fases-status-text" style="font-size: 0.95rem; color: var(--text-primary); margin-top: 3px; display: block;">0.0% (Equilibrado)</strong>
          </div>
          <div id="tot-fases-indicator" style="width: 18px; height: 18px; border-radius: 50%; background-color: #8CC63F; box-shadow: 0 0 10px rgba(140, 198, 63, 0.3);"></div>
        </div>
      </div>

      <!-- Acometida Sugerida y Alertas de EDES -->
      <div class="card reveal" style="border-top: 3px solid #3FC6B4;">
        <h3 style="color: #3FC6B4; border-bottom: 1px solid rgba(63, 198, 180, 0.15); padding-bottom: 10px; margin-bottom: 20px;">
          ⚡ Suministro y Red de Distribución
        </h3>

        <div class="result-box elec-primary-result" style="margin-bottom: 15px; border-color: #3FC6B4; background: rgba(63, 198, 180, 0.08);">
          <span class="result-label" style="color: #3FC6B4;">Potencia Total Instalada (TG)</span>
          <div id="tot-res-potencia-instalada" style="font-size: 2rem; font-weight: 800; color: #3FC6B4; line-height: 1;">0 W</div>
          <span id="tot-res-potencia-kva" class="result-note" style="display: block; margin-top: 6px; font-size: 0.8rem; color: var(--text-secondary); font-weight: 600;">0.00 kVA</span>
        </div>

        <div class="result-box" style="margin-bottom: 15px; text-align: center; padding: 12px;">
          <span style="font-size: 0.78rem; color: var(--text-secondary); display: block; margin-bottom: 4px;">Suministro Recomendado (Acometida):</span>
          <strong id="tot-res-suministro" style="font-size: 1.25rem; color: #00d2ff; text-transform: uppercase;">TRIFÁSICO</strong>
          <small id="tot-res-suministro-desc" style="color: var(--text-muted); font-size: 0.7rem; display: block; margin-top: 4px; line-height: 1.3;">Obligatorio por superar los límites de acometida monofásica.</small>
        </div>

        <div class="result-alert" id="tot-alert-edes" style="padding: 12px; border-radius: 8px; font-size: 0.8rem; line-height: 1.45; border-left: 4px solid #00d2ff; background: rgba(0, 210, 255, 0.05); display: block;">
          <!-- Cargado por JS -->
        </div>
      </div>
    </div>

    <!-- Cálculo Auxiliar de Icc -->
    <div class="card reveal" style="border-top: 3px solid #3FC6B4; margin-top: 25px; padding: 20px;">
      <h4 style="color: var(--text-primary); font-size: 1rem; display: flex; align-items: center; gap: 8px; cursor: pointer; margin: 0;" id="tot-toggle-icc">
        <span>⚡</span> Cálculo Auxiliar de Cortocircuito Presunta (I<sub>cc</sub>) <span style="font-size: 0.75rem; color: #3FC6B4; margin-left: auto;">[Ver Parámetros]</span>
      </h4>
      
      <div id="tot-icc-container" style="display: none; padding-top: 15px; border-top: 1px solid rgba(255,255,255,0.05); margin-top: 15px;">
        <div class="form-group-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 15px;">
          <div class="form-group">
            <label style="font-size: 0.75rem;">Distancia al Medidor / Acometida (m)</label>
            <input type="number" id="tot-icc-distancia" class="calc-input" value="15" min="1" step="1" />
          </div>
          <div class="form-group">
            <label style="font-size: 0.75rem;">Sección Alimentador General (mm²)</label>
            <select id="tot-icc-seccion" class="calc-select">
              <option value="4">4 mm²</option>
              <option value="6">6 mm² (Recomendado Monofásico)</option>
              <option value="10" selected>10 mm² (Recomendado Trifásico)</option>
              <option value="16">16 mm²</option>
              <option value="25">25 mm²</option>
            </select>
          </div>
          <div class="form-group">
            <label style="font-size: 0.75rem;">I<sub>cc</sub> Calculada en bornes:</label>
            <div id="tot-val-icc" style="font-size: 1.25rem; font-weight: 800; color: var(--text-primary); margin-top: 5px;">0.00 kA</div>
          </div>
        </div>
        <small id="tot-val-icc-rec" style="color: var(--text-muted); font-size: 0.75rem; display: block; line-height: 1.3;">Poder de ruptura sugerido en térmicas: ≥ 4.5 kA.</small>
      </div>
    </div>

    <!-- Sección Informativa -->
    <div class="card reveal" style="margin-top: 35px; border-top: 3px solid #3FC6B4;">
      <h3 style="color: #3FC6B4; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; font-size: 1.25rem;">
        <span>💡</span> Criterios del Colegio de Ingenieros y Electromecánica (Bahía Blanca)
      </h3>
      <div class="gas-tips-grid">
        <div class="gas-tip-card">
          <div class="gas-tip-icon" style="color: #3FC6B4;">⚡</div>
          <div>
            <h4 class="gas-tip-title">Límite Monofásico EDES</h4>
            <p class="gas-tip-desc">Toda instalación con una potencia o demanda superior a <strong>7.0 kW / 7.0 kVA</strong> debe ser alimentada con suministro trifásico (380V) con cable concéntrico de acometida de 4x10 mm² mínimo.</p>
          </div>
        </div>
        <div class="gas-tip-card">
          <div class="gas-tip-icon" style="color: #3FC6B4;">📐</div>
          <div>
            <h4 class="gas-tip-title">Bocas y Asignación de Potencia</h4>
            <p class="gas-tip-desc">Para iluminación se asumen comúnmente 100W/150W por boca o según proyecto específico. Para tomacorrientes comunes, se estipula una potencia base por circuito o proporcional a la cantidad de bocas según proyecto.</p>
          </div>
        </div>
        <div class="gas-tip-card">
          <div class="gas-tip-icon" style="color: #3FC6B4;">⚖️</div>
          <div>
            <h4 class="gas-tip-title">Corriente Equivalente por Fase</h4>
            <p class="gas-tip-desc">La intensidad totalizadora por fase en acometidas trifásicas equilibradas se obtiene mediante la fórmula trifásica de potencia: I<sub>fase</sub> = Potencia (W) / (1.732 x 380) ≈ Potencia / 658.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ÁREA DE IMPRESIÓN EXCLUSIVA (MEMORIA TÉCNICA FORMATO MUNICIPAL) -->
<div id="print-area-tot" class="print-only-tot">
  <div class="print-header" style="border-bottom: 2px solid #3FC6B4; padding-bottom: 10px; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center;">
    <div>
      <h2 style="color: #000; margin: 0; font-size: 1.3rem; font-weight: 800;">PLANTILLA TOTALIZADORA ELECTRICA</h2>
      <p id="tot-print-general-title" style="margin: 3px 0 0 0; color: #333; font-size: 0.95rem; font-weight: 700;">Edificio Chiclana 680</p>
    </div>
    <img src="/assets/img/logo.webp" alt="Logo N3i" width="70" style="filter: grayscale(1);" />
  </div>

  <table class="print-table" style="width: 100%; border-collapse: collapse; margin-bottom: 15px; font-size: 0.72rem; border: 1.5px solid #000;">
    <thead>
      <tr style="background-color: #eaeaea; border-bottom: 1.5px solid #000;">
        <th colspan="2" style="border: 1px solid #000; padding: 5px; text-align: center; font-weight: 800;">TABLEROS</th>
        <th rowspan="2" style="border: 1px solid #000; padding: 5px; text-align: center; font-weight: 800; width: 70px;">Circuito</th>
        <th colspan="3" style="border: 1px solid #000; padding: 5px; text-align: center; font-weight: 800;">Nº Bocas</th>
        <th rowspan="2" style="border: 1px solid #000; padding: 5px; text-align: center; font-weight: 800; width: 85px;">POTENCIA (W)</th>
        <th rowspan="2" style="border: 1px solid #000; padding: 5px; text-align: center; font-weight: 800; width: 80px;">INTENSIDAD (A)</th>
        <th rowspan="2" style="border: 1px solid #000; padding: 5px; text-align: left; font-weight: 800;">DETALLE / OBSERVACIONES</th>
      </tr>
      <tr style="background-color: #eaeaea; border-bottom: 1.5px solid #000;">
        <th style="border: 1px solid #000; padding: 3px; text-align: center; font-weight: 700; width: 100px;">Gral</th>
        <th style="border: 1px solid #000; padding: 3px; text-align: center; font-weight: 700; width: 70px;">Secc</th>
        <th style="border: 1px solid #000; padding: 3px; text-align: center; font-weight: 700; width: 40px;">Luz</th>
        <th style="border: 1px solid #000; padding: 3px; text-align: center; font-weight: 700; width: 40px;">Toma</th>
        <th style="border: 1px solid #000; padding: 3px; text-align: center; font-weight: 700; width: 40px;">FMAA</th>
      </tr>
    </thead>
    <tbody id="tot-print-tbody" style="border: 1px solid #000;">
      <!-- Rellenado por JS -->
    </tbody>
  </table>

  <!-- Observaciones Generales en la Impresión -->
  <div style="border: 1px solid #000; padding: 8px; border-radius: 4px; background-color: #fafafa; margin-bottom: 15px; font-size: 0.72rem; line-height: 1.35;" id="tot-print-notes-container">
    <strong>Observaciones Generales:</strong> <span id="tot-print-notes-val">Ninguna.</span>
  </div>

  <div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 20px; margin-top: 10px; font-size: 0.75rem;">
    <div style="border: 1px solid #000; padding: 10px; background-color: #fcfcfc;">
      <h4 style="margin: 0 0 8px 0; color: #000; font-weight: 800;">Resumen del Proyecto:</h4>
      <p style="margin: 0 0 4px 0;"><strong>Potencia Total Instalada:</strong> <span id="tot-print-pot-total">-</span> W</p>
      <p style="margin: 0 0 4px 0;"><strong>Demanda Equivalente por Fase:</strong> <span id="tot-print-resumen-fase">-</span></p>
      <p style="margin: 0 0 4px 0;"><strong>Suministro Recomendado:</strong> <span id="tot-print-tipo-suministro">-</span></p>
      <p style="margin: 0;"><strong>Fecha de Generación:</strong> <span id="tot-print-fecha"></span></p>
    </div>
    <div style="border: 1px solid #000; padding: 10px; display: flex; flex-direction: column; justify-content: space-between; height: 110px;">
      <span style="font-size: 0.7rem; color: #333; line-height: 1.3;">
        <strong>Certificación:</strong> Esta planilla de cargas y dimensionamiento ha sido generada siguiendo la normativa de la AEA 90364-7-771 y los requerimientos del Municipio de Bahía Blanca.
      </span>
      <div style="display: flex; justify-content: space-between; border-top: 1px solid #000; padding-top: 6px; margin-top: 5px;">
        <span style="font-size: 0.7rem; font-weight: 700;">Firma de Profesional Matriculado:</span>
        <span style="border-bottom: 1px dashed #000; width: 100px; height: 12px;"></span>
      </div>
    </div>
  </div>

  <div style="margin-top: 25px; border-top: 1px solid #000; padding-top: 8px; font-size: 0.65rem; color: #333; text-align: center;">
    <p>N3i Engineering & Maintenance · www.n3i.com.ar · Bahía Blanca, Argentina</p>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Variable global para almacenar los datos del proyecto
    let generalName = "TG Protecciones (Edificio Chiclana 680)";
    let generalNotes = "La caída de tensión máxima admitida desde la acometida hasta el tablero seccional más alejado no superará el 3%. Las protecciones y conductores cumplen con la norma AEA 90364-7-771.";
    
    // Inicializar con los datos de Chiclana 680 de la captura
    let grupos = [
      {
        id: 1,
        nombre: "TS00 y subtableros",
        seccionales: [
          {
            id: 11,
            nombre: "TS00",
            circuitos: [
              { id: 111, tag: "t-01", luz: 0, toma: 8, fm: 0, potencia: 900, corriente: 4.10, detalle: "Tomacorrientes", fase: "R", auto: true },
              { id: 112, tag: "t-02", luz: 0, toma: 8, fm: 0, potencia: 900, corriente: 4.10, detalle: "Tomacorrientes", fase: "S", auto: true },
              { id: 113, tag: "l-01", luz: 10, toma: 0, fm: 0, potencia: 1000, corriente: 4.50, detalle: "Iluminacion", fase: "T", auto: true },
              { id: 114, tag: "l-02", luz: 10, toma: 0, fm: 0, potencia: 1000, corriente: 4.50, detalle: "Iluminacion", fase: "R", auto: true },
              { id: 115, tag: "l-03", luz: 10, toma: 0, fm: 0, potencia: 1000, corriente: 4.50, detalle: "Iluminacion", fase: "S", auto: true },
              { id: 116, tag: "l-LE", luz: 6, toma: 0, fm: 0, potencia: 600, corriente: 2.70, detalle: "Iluminacion Emergencia", fase: "T", auto: true },
              { id: 117, tag: "AAC-P0", luz: 0, toma: 0, fm: 2, potencia: 11000, corriente: 50.00, detalle: "Sistema Techo Dual Inverter 11kVA", fase: "R", auto: false }
            ]
          },
