---
// src/components/CalculadoraConsumoElectricoEn.astro
// N3i Electrical Consumption Simulator (Aesthetic Green/Lime Theme) - English Version

const categories = [
  { id: 'clima', name: '🌡️ HVAC & Heating', desc: 'Air conditioners and water heaters' },
  { id: 'cocina', name: '🍳 Kitchen & Cooling', desc: 'Refrigerator, ovens, and kitchen appliances' },
  { id: 'tecnologia', name: '💡 Lighting & Tech', desc: 'Light bulbs and electronic devices' },
  { id: 'limpieza', name: '🧺 Laundry & Pumping', desc: 'Washing machines, irons, and water pumps' }
];

const appliances = [
  // HVAC and Hot Water
  { id: 'aire-2500', category: 'clima', name: 'Air Conditioner (10,000 BTU)', watts: 1000, defaultHours: 5, icon: '🌬️', tip: '<strong>HVAC at 24°C (75°F):</strong> In summer, each degree below 24°C increases cooling energy consumption by 7% to 10%. Clean filters monthly to maintain peak operating efficiency.' },
  { id: 'aire-4500', category: 'clima', name: 'Air Conditioner (18,000 BTU)', watts: 1800, defaultHours: 5, icon: '❄️', tip: '<strong>HVAC at 24°C (75°F):</strong> In summer, each degree below 24°C increases cooling energy consumption by 7% to 10%. Clean filters monthly to maintain peak operating efficiency.' },
  { id: 'termotanque', category: 'clima', name: 'Electric Water Heater', watts: 3000, defaultHours: 3, icon: '🚿', tip: '<strong>Water Heater Timer:</strong> Electric water heaters heat water continuously. Installing a digital timer program to turn it on 2 hours before bathing saves up to 40% in water heating energy.' },

  // Kitchen
  { id: 'heladera', category: 'cocina', name: 'Refrigerator with freezer', watts: 200, defaultHours: 24, icon: '❄️', tip: '<strong>Fridge Efficiency:</strong> Although plugged in 24/7, the compressor runs about 10-12 real hours daily. Ensure door gaskets seal tightly, avoid storing hot food, and leave 15cm (6 in) of rear clearance for ventilation.' },
  { id: 'microondas', category: 'cocina', name: 'Microwave', watts: 1200, defaultHours: 0.5, icon: '🍱', tip: '<strong>Microwave Usage:</strong> High power but short running times make microwaves highly efficient. Avoid using them to defrost large batches of food; it is better to thaw items in the fridge beforehand.' },
  { id: 'pava', category: 'cocina', name: 'Electric Kettle', watts: 1500, defaultHours: 0.5, icon: '🫖', tip: '<strong>Measure Kettle Water:</strong> Only heat the volume of water you will immediately use. Filling the kettle to the maximum to make a single cup of tea wastes significant electrical energy.' },
  { id: 'horno', category: 'cocina', name: 'Electric Oven', watts: 2000, defaultHours: 1, icon: '🥘', tip: '<strong>Efficient Oven Use:</strong> Avoid opening the oven door while cooking (up to 20% of heat escapes). Turn the oven off 5 minutes before the cooking cycle ends to utilize residual heat.' },

  // Tech & Lighting
  { id: 'luces-led', category: 'tecnologia', name: 'LED Bulbs (average)', watts: 15, defaultHours: 6, icon: '💡', tip: '<strong>LED Retrofit:</strong> Replacing old incandescent or halogen bulbs with high-efficiency LEDs reduces lighting consumption by 85%. Remember to turn off lights in unoccupied rooms.' },
  { id: 'tv', category: 'tecnologia', name: 'Television (LED/Smart)', watts: 100, defaultHours: 4, icon: '📺', tip: '<strong>Standby Vampire Load:</strong> TVs and gaming consoles in standby mode still draw electric current. Connect them to a switched power strip to shut them down completely before going to bed.' },
  { id: 'pc', category: 'tecnologia', name: 'Computer / Laptop', watts: 200, defaultHours: 5, icon: '💻', tip: '<strong>Computer Power Saving:</strong> Configure your screen to turn off after 5 minutes of inactivity. Animated screen savers consume almost the same amount of power as regular active computer usage.' },

  // Cleaning & Pumping
  { id: 'lavarropas', category: 'limpieza', name: 'Washing Machine', watts: 800, defaultHours: 1, icon: '👕', tip: '<strong>Wash in Cold Water:</strong> 90% of a washing machine\'s electricity is used to heat the water. Use short cycles and cold washes whenever possible, and run loads at recommended maximum capacity.' },
  { id: 'plancha', category: 'limpieza', name: 'Clothes Iron', watts: 1200, defaultHours: 0.5, icon: '👔', tip: '<strong>Iron in Batches:</strong> Clothes irons draw heavy current during their initial warm-up phase. Accumulate clothes to iron everything at once rather than heating the iron for a single item.' },
  { id: 'bomba', category: 'limpieza', name: 'Water Pump (1/2 HP)', watts: 375, defaultHours: 1, icon: '💧', tip: '<strong>Water Pumping Efficiency:</strong> Keep cisterns and water tanks clean and leak-free. A faulty float switch makes the pump run continuously, causing high power bills and risking pump motor failure.' }
];
---

<section class="section section-alt" id="calc-consumo-electrico">
  <div class="container">
    <div class="section-header reveal" style="margin: 0 auto 40px auto; text-align: center;">
      <span class="section-subtitle" style="color: var(--accent);">Electricity & Energy Efficiency</span>
      <h2 class="section-title">Electricity Consumption Simulator</h2>
      <p class="section-desc">
        Calculate your monthly electricity consumption in kWh, estimate bills in pesos ($) based on local rates, and receive safety suggestions and optimization tips to lower costs.
      </p>
    </div>

    <div class="elec-layout-grid">
      <!-- Left Column: User Inputs -->
      <div class="elec-input-area">
        
        <!-- Category Tabs -->
        <div class="elec-tabs card reveal">
          <div class="tabs-header-scroll">
            <div class="tabs-bar">
              {categories.map((cat, idx) => (
                <button type="button" class={`tab-btn ${idx === 0 ? 'active' : ''}`} data-tab={cat.id}>
                  {cat.name}
                </button>
              ))}
            </div>
          </div>
        </div>

        <!-- Appliance Panels (one per category) -->
        <div class="elec-appliances card reveal" style="margin-top: 20px;">
          {categories.map((cat, idx) => (
            <div class={`elec-tab-content ${idx === 0 ? 'active' : ''}`} id={`tab-panel-${cat.id}`}>
              <h3 style="font-size: 1.2rem; margin-bottom: 5px; color: var(--text-primary);">{cat.name}</h3>
              <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 20px;">{cat.desc}</p>
              
              <div class="appliances-list">
                {appliances.filter(app => app.category === cat.id).map(app => (
                  <div class="elec-app-item" data-id={app.id} data-watts={app.watts} data-tip={app.tip}>
                    <div class="elec-app-main">
                      <div class="elec-app-info">
                        <span class="elec-app-icon">{app.icon}</span>
                        <div>
                          <span class="elec-app-name">{app.name}</span>
                          <span class="elec-app-watts">{app.watts} W (average)</span>
                        </div>
                      </div>
                      <div class="app-controls">
                        <button type="button" class="btn-qty elec-minus" data-target={app.id}>-</button>
                        <input type="number" class="qty-input elec-qty" id={app.id} value="0" min="0" max="99" />
                        <button type="button" class="btn-qty elec-plus" data-target={app.id}>+</button>
                      </div>
                    </div>
                    <div class="elec-app-slider-container" id={`slider-container-${app.id}`}>
                      <div class="elec-slider-header">
                        <span>Est. daily operating time:</span>
                        <strong class="elec-hours-display"><span id={`${app.id}-display`}>{app.defaultHours.toFixed(1)}</span> hrs</strong>
                      </div>
                      <input type="range" class="elec-slider" id={`${app.id}-hours`} min="0.5" max="24" step="0.5" value={app.defaultHours} />
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right Column: Rates & Results -->
      <div class="elec-results-area">
        
        <!-- Tariff Settings -->
        <div class="card reveal" style="margin-bottom: 20px; border-top: 3px solid var(--accent);">
          <h3 style="font-size: 1.1rem; margin-bottom: 15px; color: var(--text-primary); display: flex; align-items: center; gap: 8px;">
            <span>💵</span> Tariff Settings
          </h3>
          <div class="tariff-settings-grid">
            <div class="form-group">
              <label for="elec-cost-kwh" style="font-size: 0.8rem; color: var(--text-secondary); font-weight: 600;">kWh Cost ($):</label>
              <input type="number" id="elec-cost-kwh" class="form-control form-input" value="115" min="1" step="1" />
            </div>
            <div class="form-group">
              <label for="elec-fixed-charge" style="font-size: 0.8rem; color: var(--text-secondary); font-weight: 600;">Fixed Monthly Charge ($):</label>
              <input type="number" id="elec-fixed-charge" class="form-control form-input" value="4500" min="0" step="1" />
            </div>
          </div>
          <span style="font-size: 0.72rem; color: var(--text-muted); display: block; margin-top: 10px; line-height: 1.3;">
            * Editable values based on Argentine reference residential utility rates (June 2026).
          </span>
        </div>

        <!-- Diagnostics & Results -->
        <div class="card reveal results-sticky" style="transition-delay: 0.1s;">
          <h3 style="color: var(--accent); border-bottom: 1px solid rgba(140,198,63,0.15); padding-bottom: 10px; margin-bottom: 20px; font-size: 1.25rem;">
            Installation Diagnostics
          </h3>

          <div class="kpi-grid-two">
            <div class="result-box">
              <span class="result-label">Installed Load</span>
              <div class="result-value" style="font-size: 1.5rem;"><span id="elec-res-watts">0</span> W</div>
            </div>
            <div class="result-box">
              <span class="result-label">Simultaneous Demand (70%)</span>
              <div class="result-value" style="font-size: 1.5rem; color: var(--accent);"><span id="elec-res-sim-watts">0</span> W</div>
              <span class="result-note" style="display:block; margin-top:3px; font-size:0.7rem;"><span id="elec-res-amps">0.00</span> A at 220V</span>
            </div>
          </div>

          <!-- Monthly Consumption & Cost -->
          <div class="result-box elec-primary-result" style="margin-top: 15px;">
            <span class="result-label" style="color: var(--accent);">Est. Monthly Consumption</span>
            <div class="result-value" style="color: var(--accent); font-size: 2.1rem;"><span id="elec-res-mensual-kwh">0.0</span> <span style="font-size:1.1rem; font-weight:800;">kWh</span></div>
          </div>

          <div class="result-box elec-primary-result" style="border-color: #3fc6b4; background: rgba(63, 198, 180, 0.08); margin-top: 12px;">
            <span class="result-label" style="color: #3fc6b4;">Est. Monthly Gasto (Boleta)</span>
            <div class="result-value" style="color: #3fc6b4; font-size: 2.1rem;">$ <span id="elec-res-costo-total">0</span></div>
            <span class="result-note" id="elec-res-costo-desc" style="font-size: 0.72rem; color: var(--text-secondary); margin-top: 5px; display:block; line-height: 1.3;"></span>
          </div>

          <!-- Carbon Footprint & Protection Breakers -->
          <div class="kpi-grid-two" style="margin-top: 12px;">
            <div class="result-box">
              <span class="result-label">CO₂ Footprint</span>
              <div class="result-value" style="font-size: 1.25rem; color: #a3abb2;"><span id="elec-res-co2">0.0</span> <span style="font-size:0.8rem; font-weight:600;">kg CO₂/mo</span></div>
            </div>
            <div class="result-box" id="elec-protection-badge" style="border-left: 3px solid var(--accent); text-align: left; padding: 12px;">
              <span class="result-label" style="text-align: left;">Suggested Breakers</span>
              <span id="elec-breaker-text" style="font-weight: 700; color: var(--text-primary); font-size: 0.9rem; display: block; margin-top: 3px;">Main MCB: 16A</span>
              <span id="elec-rcd-text" style="color: var(--text-secondary); font-size: 0.72rem; display: block;">RCD/GFCI: 25A (30mA)</span>
            </div>
          </div>

          <!-- Load Status Alert -->
          <div class="result-alert" id="elec-status-alert" style="margin-top: 15px; padding: 12px 15px; border-radius: 8px; font-size: 0.82rem; line-height: 1.4;">
            <strong>Panel Load:</strong> <span id="elec-status-title" style="font-weight: 700;">No load</span>. <span id="elec-status-desc">Add appliances to perform electrical calculations.</span>
          </div>

          <!-- Action Buttons -->
          <div style="margin-top: 20px; display: flex; flex-direction: column; gap: 10px;">
            <a href="/en#contacto" class="btn btn-primary" style="width: 100%; justify-content: center;">
              Request On-Site Audit
              <span class="btn-icon">➔</span>
            </a>
            <button type="button" id="elec-btn-print" class="btn btn-outline" style="width: 100%; justify-content: center; border-color: var(--accent); color: var(--text-primary); background: transparent; padding: 12px 20px;">
              Print Electrical Report
              <span class="btn-icon" style="background: transparent;">🖨️</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Smart Optimization & Saving Analyzer (Engineering Tips) -->
    <div class="card reveal" style="margin-top: 40px; border-top: 3px solid var(--accent);" id="elec-optimizer-section">
      <h3 style="color: var(--accent); margin-bottom: 15px; display: flex; align-items: center; gap: 10px; font-size: 1.3rem;">
        <span>🔍</span> Intelligent Consumption & Savings Analyzer
      </h3>
      <p style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 25px; line-height: 1.5;">
        Below are your highest sources of monthly power usage, followed by specific engineering suggestions to optimize efficiency and lower your utility bills.
      </p>
      
      <!-- Dynamic Container -->
      <div id="elec-optimizer-container">
        <div class="elec-optimizer-placeholder" style="text-align: center; padding: 30px; color: var(--text-muted);">
          <span style="font-size: 2.5rem; display: block; margin-bottom: 10px;">⚡</span>
          Select appliance quantities to view your top energy consumers and receive customized savings suggestions in real-time.
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Hidden Electrical Report Print Area -->
<div id="print-area-elec" class="print-only-elec">
  <div class="print-header">
    <img src="/assets/img/logo.webp" alt="Logo N3i" width="80" />
    <div>
      <h2 style="color: var(--accent);">Electrical Demand & Monthly Consumption Report</h2>
      <p>N3i Engineering & Maintenance</p>
    </div>
  </div>
  <div class="print-details">
    <p><strong>Date:</strong> <span id="elec-print-date"></span></p>
    <p><strong>Document Type:</strong> Electrical Load, Consumption & Bill Estimation (Residential)</p>
    <p><strong>Grid Voltage:</strong> 220 V AC - Single Phase (70% Simultaneity Factor)</p>
  </div>
  
  <table class="print-table">
    <thead>
      <tr>
        <th>Qty.</th>
        <th>Appliance / Equipment</th>
        <th>Unit Watts</th>
        <th>Daily Use</th>
        <th>Monthly Consumption (kWh)</th>
        <th>Monthly Cost ($)</th>
      </tr>
    </thead>
    <tbody id="elec-print-tbody">
      <!-- Populated by JS -->
    </tbody>
    <tfoot>
      <tr>
        <td colspan="4" style="text-align: right;"><strong>Total Installed Load (100%):</strong></td>
        <td colspan="2"><strong id="elec-print-total-w">0 W</strong></td>
      </tr>
      <tr>
        <td colspan="4" style="text-align: right;"><strong>Estimated Real Simultaneous Demand (70%):</strong></td>
        <td colspan="2"><strong id="elec-print-sim-w" style="font-size: 1.1rem;">0 W</strong></td>
      </tr>
      <tr>
        <td colspan="4" style="text-align: right;"><strong>Breaker Ampere Load to Protect:</strong></td>
        <td colspan="2"><strong id="elec-print-total-amps" style="font-size: 1.1rem;">0.00 A</strong></td>
      </tr>
      <tr>
        <td colspan="4" style="text-align: right; color: var(--accent);"><strong>Estimated Total Energy Consumption:</strong></td>
        <td colspan="2"><strong id="elec-print-total-kwh" style="font-size: 1.15rem; color: var(--accent);">0.0 kWh/mo</strong></td>
      </tr>
      <tr style="background-color: #f9f9f9;">
        <td colspan="4" style="text-align: right; font-weight: bold;">Estimated Monthly Bill (Usage Subtotal + Fixed Charge):</td>
        <td colspan="2"><strong id="elec-print-total-cost" style="font-size: 1.25rem; color: #10b981;">$ 0.00 ARS</strong></td>
      </tr>
    </tfoot>
  </table>
  
  <div style="background: rgba(140, 198, 63, 0.08); padding: 15px; border-radius: 8px; border-left: 5px solid var(--accent); margin-bottom: 20px;">
    <h3 style="margin-top: 0; color: var(--accent); font-size: 1.1rem;">Technical Breaker Recommendations (AEA Standards)</h3>
    <p style="font-size: 1rem; margin-bottom: 5px;"><strong>Suggested Main MCB (Thermomagnetic):</strong> <span id="elec-print-breaker" style="font-weight: 700;"></span></p>
    <p style="font-size: 1rem; margin-bottom: 5px;"><strong>Suggested RCD/GFCI (Diferencial):</strong> <span id="elec-print-rcd" style="font-weight: 700;"></span></p>
    <p style="font-size: 0.9rem; margin-top: 10px; line-height: 1.4; color: #555;" id="elec-print-status-desc"></p>
  </div>

  <div class="print-footer">
    <p style="font-size: 0.8rem; margin-top: 15px;">* Technical Note: The values shown are simulated estimates based on user-declared hours. The final sizing of conductors (cables), phase distribution in electrical panels, and load balancing on-site must be designed by a certified N3i Engineer or Installer in compliance with the regulations of the Argentine Electrotechnical Association (AEA) or equivalent local codes.</p>
    <p style="font-size: 0.8rem; margin-top: 5px;">To schedule a technical audit or inspections, technical contact is available at <strong>www.n3i.com.ar</strong> or via WhatsApp at +54 9 291 416-8232.</p>
  </div>
</div>

<style is:global>
  /* Elec Calculator Styling Layout */
  .elec-layout-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
    align-items: start;
  }

  @media (min-width: 992px) {
    .elec-layout-grid {
      grid-template-columns: 1.8fr 1.2fr;
    }
  }

  /* Tabs Navigation Styling */
  .tabs-header-scroll {
    overflow-x: auto;
    width: 100%;
    scrollbar-width: none; /* Firefox */
  }
  .tabs-header-scroll::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  .tabs-bar {
    display: flex;
    gap: 8px;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 10px;
    min-width: max-content;
    width: 100%;
  }

  .tab-btn {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    padding: 10px 18px;
    font-family: var(--font-title);
    font-size: 0.88rem;
    font-weight: 600;
    border-radius: 20px;
    cursor: pointer;
    transition: var(--transition-smooth);
  }

  .tab-btn:hover {
    color: var(--text-primary);
    border-color: rgba(140, 198, 63, 0.3);
    background: rgba(140, 198, 63, 0.03);
  }

  .tab-btn.active {
    background-color: var(--accent);
    border-color: var(--accent);
    color: #000000;
    box-shadow: 0 4px 12px var(--accent-glow);
  }

  /* Tab Panel Transitions */
  .elec-tab-content {
    display: none;
  }

  .elec-tab-content.active {
    display: block;
    animation: fadeIn 0.4s ease forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* List of items */
  .elec-app-item {
    background: var(--bg-alt, #111416);
    padding: 16px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.03);
    transition: var(--transition-smooth);
    margin-bottom: 15px;
  }

  .elec-app-item:last-child {
    margin-bottom: 0;
  }

  .elec-app-item:hover {
    border-color: rgba(140, 198, 63, 0.2);
    background: rgba(140, 198, 63, 0.01);
  }

  .elec-app-main {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 15px;
    width: 100%;
  }

  .elec-app-info {
    display: flex;
    align-items: center;
    gap: 15px;
    flex: 1;
    min-width: 0;
  }

  .elec-app-icon {
    font-size: 1.4rem;
    background: rgba(140, 198, 63, 0.08);
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .elec-app-name {
    display: block;
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.95rem;
    line-height: 1.3;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .elec-app-watts {
    display: block;
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-top: 1px;
  }

  /* Controls and Inputs Sizing */
  .app-controls {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-color);
    padding: 4px;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .btn-qty {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    border: none;
    background: var(--accent);
    color: #000000;
    font-weight: bold;
    font-size: 1.1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-smooth);
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

  .btn-qty:hover {
    background: var(--accent-hover);
    transform: scale(1.05);
  }

  .qty-input {
    width: 32px;
    text-align: center;
    border: none;
    background: transparent !important;
    font-weight: bold;
    font-size: 0.95rem;
    color: var(--text-primary) !important;
    -moz-appearance: textfield;
    -webkit-appearance: none;
    appearance: none;
    padding: 0;
    margin: 0;
  }

  .qty-input::-webkit-outer-spin-button,
  .qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* Slider controls */
  .elec-app-slider-container {
    margin-top: 15px;
    padding-top: 15px;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    display: none; /* Se activa con JS */
  }

  .elec-app-slider-container.active {
    display: block;
    animation: slideDown 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes slideDown {
    from { opacity: 0; max-height: 0; overflow: hidden; margin-top: 0; padding-top: 0; }
    to { opacity: 1; max-height: 100px; margin-top: 15px; padding-top: 15px; }
  }

  .elec-slider-header {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    margin-bottom: 8px;
    color: var(--text-secondary);
  }

  .elec-hours-display {
    color: var(--accent);
  }

  .elec-slider {
    width: 100%;
    accent-color: var(--accent);
    background: rgba(255, 255, 255, 0.08);
    height: 6px;
    border-radius: 3px;
    cursor: pointer;
  }

  /* Mobile Responsive Tweaks for Cards & Controls */
  @media (max-width: 576px) {
    .card {
      padding: 16px !important;
    }
    .elec-tabs {
      padding: 10px !important;
    }
    .tab-btn {
      padding: 8px 12px;
      font-size: 0.78rem;
    }
  }

  /* ── Mobile: idéntico al patrón del Simulador de Gas ── */
  @media (max-width: 520px) {
    .elec-app-item {
      padding: 12px;
    }

    .elec-app-main {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      width: 100%;
    }

    .elec-app-info {
      flex: 1;
      gap: 10px;
      min-width: 0;
    }

    .app-controls {
      gap: 4px;
      padding: 4px;
      flex-shrink: 0;
    }

    .elec-app-icon {
      width: 36px;
      height: 36px;
      font-size: 1.2rem;
      flex-shrink: 0;
    }

    .elec-app-name {
      font-size: 0.85rem;
      line-height: 1.3;
      word-break: break-word;
      overflow-wrap: break-word;
    }

    .elec-app-watts {
      font-size: 0.73rem;
    }

    .btn-qty {
      width: 28px;
      height: 28px;
      font-size: 0.9rem;
      border-radius: 6px;
    }

    .qty-input {
      width: 32px;
      font-size: 0.9rem;
    }

    .tariff-settings-grid,
    .kpi-grid-two {
      grid-template-columns: 1fr;
    }
  }

  .results-sticky {
    position: sticky;
    top: 100px;
  }

  @media (max-width: 991px) {
    .results-sticky {
      position: static !important;
    }
  }

  /* Tariff Settings */
  .tariff-settings-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
  }

  /* KPI Grid */
  .kpi-grid-two {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .elec-primary-result {
    background: linear-gradient(135deg, rgba(140, 198, 63, 0.1) 0%, rgba(140, 198, 63, 0.02) 100%);
    border: 1px solid var(--accent) !important;
  }

  /* Optimization Dynamic layout */
  .elec-opt-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-top: 15px;
  }

  @media (min-width: 768px) {
    .elec-opt-grid {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    }
  }

  .elec-opt-card {
    display: flex;
    gap: 15px;
    background: rgba(255, 255, 255, 0.01);
    padding: 16px;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    transition: var(--transition-smooth);
    position: relative;
    overflow: hidden;
  }

  .elec-opt-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--accent);
  }

  .elec-opt-card:hover {
    border-color: rgba(140, 198, 63, 0.25);
    background: rgba(140, 198, 63, 0.02);
    transform: translateY(-2px);
  }

  .elec-opt-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    background: rgba(255, 255, 255, 0.03);
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
  }

  .elec-opt-share-badge {
    position: absolute;
    top: 15px;
    right: 15px;
    background: rgba(140, 198, 63, 0.15);
    color: var(--accent);
    padding: 2px 8px;
    font-size: 0.7rem;
    font-weight: 700;
    border-radius: 10px;
  }

  .elec-opt-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 5px;
    padding-right: 45px; /* Prevent badge overlap */
  }

  .elec-opt-desc {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  /* Print Styles for Elec Calculator */
  .print-only-elec {
    display: none;
  }

  @media print {
    body.printing-elec .header,
    body.printing-elec .footer,
    body.printing-elec .section-header,
    body.printing-elec .elec-layout-grid,
    body.printing-elec #elec-optimizer-section,
    body.printing-elec .section {
      display: none !important;
    }

    body.printing-elec .print-only-elec {
      display: block !important;
      font-family: Arial, sans-serif;
      color: #000 !important;
      background: #fff !important;
      padding: 1.5cm;
    }

    .print-only-elec .print-header {
      display: flex;
      align-items: center;
      border-bottom: 2px solid #8CC63F;
      padding-bottom: 15px;
      margin-bottom: 20px;
      gap: 20px;
    }

    .print-only-elec .print-header h2 {
      margin: 0;
      font-size: 1.4rem;
      color: #222;
    }

    .print-only-elec .print-header p {
      margin: 3px 0 0 0;
      color: #555;
    }

    .print-only-elec .print-details {
      margin-bottom: 20px;
      font-size: 0.85rem;
      color: #333;
    }

    .print-only-elec .print-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 20px;
      font-size: 0.85rem;
    }

    .print-only-elec .print-table th,
    .print-only-elec .print-table td {
      border: 1px solid #ddd;
      padding: 8px;
      text-align: left;
    }

    .print-only-elec .print-table th {
      background-color: #f5f5f5;
      color: #222;
    }

    .print-only-elec .print-footer {
      border-top: 1px solid #ddd;
      padding-top: 15px;
      font-size: 0.78rem;
      color: #444;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Tab switching
    const tabButtons = document.querySelectorAll('.tab-btn');
    const tabPanels = document.querySelectorAll('.elec-tab-content');

    tabButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const tabId = btn.getAttribute('data-tab');
        
        // Find buttons in this component only
        const siblingButtons = btn.closest('.elec-input-area')?.querySelectorAll('.tab-btn');
        const siblingPanels = btn.closest('.elec-input-area')?.querySelectorAll('.elec-tab-content');
        
        if (siblingButtons && siblingPanels) {
          siblingButtons.forEach(b => b.classList.remove('active'));
          siblingPanels.forEach(p => p.classList.remove('active'));
          
          btn.classList.add('active');
          const targetPanel = btn.closest('.elec-input-area')?.querySelector(`#tab-panel-${tabId}`);
          if (targetPanel) {
            targetPanel.classList.add('active');
          }
        }
      });
    });

    // 2. DOM Elements
    const costKwhInput = document.getElementById('elec-cost-kwh') as HTMLInputElement;
    const fixedChargeInput = document.getElementById('elec-fixed-charge') as HTMLInputElement;

    const resWatts = document.getElementById('elec-res-watts');
    const resSimWatts = document.getElementById('elec-res-sim-watts');
    const resAmps = document.getElementById('elec-res-amps');
    const resMensualKwh = document.getElementById('elec-res-mensual-kwh');
    const resCostoTotal = document.getElementById('elec-res-costo-total');
    const resCostoDesc = document.getElementById('elec-res-costo-desc');
    const resCo2 = document.getElementById('elec-res-co2');

    const breakerText = document.getElementById('elec-breaker-text');
    const rcdText = document.getElementById('elec-rcd-text');
    const statusAlert = document.getElementById('elec-status-alert');
    const statusTitle = document.getElementById('elec-status-title');
    const statusDesc = document.getElementById('elec-status-desc');

    const optimizerContainer = document.getElementById('elec-optimizer-container');
    const btnPrint = document.getElementById('elec-btn-print');

    // 3. Inputs & Sliders
    const qtyInputs = document.querySelectorAll('.elec-qty');
    const btnMinus = document.querySelectorAll('.elec-minus');
    const btnPlus = document.querySelectorAll('.elec-plus');
    const sliders = document.querySelectorAll('.elec-slider');

    const VOLTAGE = 220;
    const SIMULTANEITY_FACTOR = 0.7;

    function formatNumber(num: number, decimals: number = 0): string {
      return num.toLocaleString('en-US', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
    }

    function toggleSliderVisibility(id: string, qty: number) {
      const container = document.getElementById(`slider-container-${id}`);
      if (container) {
        if (qty > 0) {
          container.classList.add('active');
        } else {
          container.classList.remove('active');
        }
      }
    }

    btnMinus.forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-target');
        if (!id) return;
        const input = document.getElementById(id) as HTMLInputElement;
        if (input && parseInt(input.value) > 0) {
          input.value = (parseInt(input.value) - 1).toString();
          toggleSliderVisibility(id, parseInt(input.value));
          calculateElectrical();
        }
      });
    });

    btnPlus.forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-target');
        if (!id) return;
        const input = document.getElementById(id) as HTMLInputElement;
        if (input && parseInt(input.value) < 99) {
          input.value = (parseInt(input.value) + 1).toString();
          toggleSliderVisibility(id, parseInt(input.value));
          calculateElectrical();
        }
      });
    });

    qtyInputs.forEach(input => {
      input.addEventListener('input', () => {
        const target = input as HTMLInputElement;
        if (parseInt(target.value) < 0) target.value = '0';
        toggleSliderVisibility(target.id, parseInt(target.value) || 0);
        calculateElectrical();
      });
    });

    sliders.forEach(slider => {
      slider.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        const appId = target.id.replace('-hours', '');
        const display = document.getElementById(`${appId}-display`);
        if (display) {
          display.textContent = parseFloat(target.value).toFixed(1);
        }
        calculateElectrical();
      });
    });

    if (costKwhInput) costKwhInput.addEventListener('input', calculateElectrical);
    if (fixedChargeInput) fixedChargeInput.addEventListener('input', calculateElectrical);

    // 4. Engineering math
    function calculateElectrical() {
      let totalWatts = 0;
      let totalKwhMes = 0;
      
      const activeAppliances: Array<{
        id: string;
        name: string;
        watts: number;
        qty: number;
        hours: number;
        kwhMes: number;
        costMes: number;
        icon: string;
        tip: string;
      }> = [];

      const costKwh = parseFloat(costKwhInput?.value) || 115;
      const fixedCharge = parseFloat(fixedChargeInput?.value) || 4500;

      const items = document.querySelectorAll('.elec-app-item');
      items.forEach(item => {
        const id = item.getAttribute('data-id') || '';
        const watts = parseFloat(item.getAttribute('data-watts') || '0');
        const tip = item.getAttribute('data-tip') || '';
        const qtyInput = document.getElementById(id) as HTMLInputElement;
        const qty = parseInt(qtyInput?.value || '0');

        if (qty > 0) {
          totalWatts += qty * watts;

          const hoursSlider = document.getElementById(`${id}-hours`) as HTMLInputElement;
          const hours = parseFloat(hoursSlider?.value || '0');

          const kwhMes = qty * (watts / 1000) * hours * 30;
          const costMes = kwhMes * costKwh;
          totalKwhMes += kwhMes;

          const icon = item.querySelector('.elec-app-icon')?.textContent || '⚡';
          const name = item.querySelector('.elec-app-name')?.textContent || 'Appliance';

          activeAppliances.push({
            id,
            name,
            watts,
            qty,
            hours,
            kwhMes,
            costMes,
            icon,
            tip
          });
        }
      });

      const simultaneousWatts = totalWatts * SIMULTANEITY_FACTOR;
      const amps = simultaneousWatts / VOLTAGE;
      const costoTotal = totalKwhMes > 0 ? fixedCharge + (totalKwhMes * costKwh) : 0;
      const co2 = totalKwhMes * 0.36; // Footprint: 0.36 kg of CO2 per kWh

      // Update KPI displays
      if (resWatts) resWatts.textContent = formatNumber(totalWatts);
      if (resSimWatts) resSimWatts.textContent = formatNumber(Math.round(simultaneousWatts));
      if (resAmps) resAmps.textContent = amps.toFixed(2);
      if (resMensualKwh) resMensualKwh.textContent = formatNumber(totalKwhMes, 1);
      if (resCostoTotal) resCostoTotal.textContent = formatNumber(Math.round(costoTotal));

      if (resCostoDesc) {
        if (totalKwhMes > 0) {
          resCostoDesc.innerHTML = `Includes $${formatNumber(Math.round(fixedCharge))} Fixed Charge + $${formatNumber(Math.round(costKwh))}/kWh Variable Charge.`;
        } else {
          resCostoDesc.innerHTML = 'No appliances selected.';
        }
      }

      if (resCo2) resCo2.textContent = formatNumber(co2, 1);

      // Breaker protections recommendations
      let breakerSize = '16A';
      let rcdSize = '25A';
      let statusColor = '';
      let statusBg = '';
      let borderLeft = '';
      let statusTitleText = 'Low (Basic Load)';
      let statusDescText = 'The load is safe for a single-phase standard residential circuit.';

      if (amps === 0) {
        statusTitleText = 'No load';
        statusDescText = 'Add appliances to run technical simulation.';
        statusBg = 'rgba(255, 255, 255, 0.02)';
        borderLeft = '4px solid var(--border-color)';
        statusColor = 'var(--text-muted)';
        breakerSize = '16A';
        rcdSize = '25A';
      } else if (amps <= 12) {
        breakerSize = '16A';
        rcdSize = '25A (30mA)';
        statusTitleText = 'Low (Basic Load)';
        statusDescText = '<strong>Suggested Protection:</strong> <strong>16A</strong> main breaker & <strong>25A</strong> RCD/GFCI.<br>Perfectly safe for standard installations.';
        statusBg = 'rgba(140, 198, 63, 0.08)';
        borderLeft = '4px solid var(--accent)';
        statusColor = 'var(--accent)';
      } else if (amps <= 20) {
        breakerSize = '25A';
        rcdSize = '25A or 40A (30mA)';
        statusTitleText = 'Moderate (Medium Load)';
        statusDescText = '<strong>Suggested Protection:</strong> <strong>25A</strong> main breaker & <strong>25A or 40A</strong> RCD/GFCI.<br>We suggest separating the board into at least two circuits.';
        statusBg = 'rgba(255, 193, 7, 0.08)';
        borderLeft = '4px solid #ffc107';
        statusColor = '#ffc107';
      } else if (amps <= 32) {
        breakerSize = '40A';
        rcdSize = '40A or 63A (30mA)';
        statusTitleText = 'High (Heavy Load)';
        statusDescText = '<strong>Suggested Protection:</strong> <strong>40A</strong> main breaker & <strong>40A or 63A</strong> RCD/GFCI.<br>Mandatory to subdivide into separate lines with dedicated lines for heavy loads.';
        statusBg = 'rgba(255, 152, 0, 0.08)';
        borderLeft = '4px solid #ff9800';
        statusColor = '#ff9800';
      } else {
        breakerSize = '50A or 63A';
        rcdSize = '63A (30mA)';
        statusTitleText = 'Critical (Very High Demand)';
        statusDescText = '<strong>Suggested Protection:</strong> <strong>50A or 63A</strong> main breaker & <strong>63A</strong> RCD/GFCI.<br>Risk of overload. Sizing upgrades required; consider upgrading to a 3-phase supply.';
        statusBg = 'rgba(244, 67, 54, 0.08)';
        borderLeft = '4px solid #f44336';
        statusColor = '#f44336';
      }

      if (breakerText) breakerText.textContent = `Main MCB: ${breakerSize}`;
      if (rcdText) rcdText.textContent = `RCD/GFCI: ${rcdSize}`;

      if (statusAlert && statusTitle && statusDesc) {
        statusAlert.style.backgroundColor = statusBg;
        statusAlert.style.borderLeft = borderLeft;
        statusTitle.textContent = statusTitleText;
        statusTitle.style.color = statusColor;
        statusDesc.innerHTML = statusDescText;
      }

      // 5. Intelligent Optimization Analyzer
      if (optimizerContainer) {
        if (activeAppliances.length === 0) {
          optimizerContainer.innerHTML = `
            <div class="elec-optimizer-placeholder" style="text-align: center; padding: 30px; color: var(--text-muted);">
              <span style="font-size: 2.5rem; display: block; margin-bottom: 10px;">⚡</span>
              Select appliance quantities to view your top energy consumers and receive customized savings suggestions in real-time.
            </div>
          `;
        } else {
          activeAppliances.sort((a, b) => b.kwhMes - a.kwhMes);
          const top3 = activeAppliances.slice(0, 3);
          
          let cardsHtml = '';
          top3.forEach(app => {
            const share = ((app.kwhMes / totalKwhMes) * 100).toFixed(0);
            
            cardsHtml += `
              <div class="elec-opt-card">
                <span class="elec-opt-share-badge">Accounts for ${share}%</span>
                <div class="elec-opt-icon">${app.icon}</div>
                <div>
                  <h4 class="elec-opt-title">${app.name}</h4>
                  <p class="elec-opt-desc" style="margin-bottom: 10px; color: var(--text-muted); font-size: 0.78rem;">
                    Monthly usage: <strong>${formatNumber(app.kwhMes, 1)} kWh/mo</strong> | Est. cost: <strong>$${formatNumber(Math.round(app.costMes))}</strong>
                  </p>
                  <p class="elec-opt-desc">${app.tip}</p>
                </div>
              </div>
            `;
          });

          optimizerContainer.innerHTML = `
            <div style="margin-bottom: 15px; font-size: 0.9rem; color: var(--accent); font-weight: 700;">
              ⚠️ Your top 3 estimated electrical consumers this month:
            </div>
            <div class="elec-opt-grid">
              ${cardsHtml}
            </div>
          `;
        }
      }
    }

    // 6. PDF Printing
    if (btnPrint) {
      btnPrint.addEventListener('click', () => {
        calculateElectrical();

        const tbody = document.getElementById('elec-print-tbody');
        const pDate = document.getElementById('elec-print-date');
        const pTotalW = document.getElementById('elec-print-total-w');
        const pSimW = document.getElementById('elec-print-sim-w');
        const pAmps = document.getElementById('elec-print-total-amps');
        const pTotalKwh = document.getElementById('elec-print-total-kwh');
        const pTotalCost = document.getElementById('elec-print-total-cost');
        const pBreaker = document.getElementById('elec-print-breaker');
        const pRcd = document.getElementById('elec-print-rcd');
        const pStatusDesc = document.getElementById('elec-print-status-desc');

        if (!tbody || !pTotalW || !pSimW || !pAmps || !pTotalKwh || !pTotalCost) return;

        tbody.innerHTML = '';

        let tWatts = 0;
        let tKwh = 0;
        let tCost = 0;
        let activeCount = 0;

        const costKwh = parseFloat(costKwhInput?.value) || 115;
        const fixedCharge = parseFloat(fixedChargeInput?.value) || 4500;

        const items = document.querySelectorAll('.elec-app-item');
        items.forEach(item => {
          const id = item.getAttribute('data-id') || '';
          const watts = parseFloat(item.getAttribute('data-watts') || '0');
          const qtyInput = document.getElementById(id) as HTMLInputElement;
          const qty = parseInt(qtyInput?.value || '0');

          if (qty > 0) {
            activeCount++;
            const name = item.querySelector('.elec-app-name')?.textContent || 'Appliance';
            const hoursSlider = document.getElementById(`${id}-hours`) as HTMLInputElement;
            const hours = parseFloat(hoursSlider?.value || '0');

            const subWatts = qty * watts;
            const subKwh = qty * (watts / 1000) * hours * 30;
            const subCost = subKwh * costKwh;

            tWatts += subWatts;
            tKwh += subKwh;
            tCost += subCost;

            const tr = document.createElement('tr');
            tr.innerHTML = `
              <td>${qty}</td>
              <td>${name}</td>
              <td>${formatNumber(watts)} W</td>
              <td>${hours.toFixed(1)} hrs/day</td>
              <td>${formatNumber(subKwh, 1)} kWh</td>
              <td>$${formatNumber(Math.round(subCost))}</td>
            `;
            tbody.appendChild(tr);
          }
        });

        // Add fixed charge
        if (tKwh > 0) {
          tCost += fixedCharge;
          const tr = document.createElement('tr');
          tr.style.fontStyle = 'italic';
          tr.style.color = '#666';
          tr.innerHTML = `
            <td>-</td>
            <td>Grid Fixed Monthly Charge</td>
            <td>-</td>
            <td>-</td>
            <td>-</td>
            <td>$${formatNumber(Math.round(fixedCharge))}</td>
          `;
          tbody.appendChild(tr);
        }

        if (activeCount === 0) {
          tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;">No appliances selected.</td></tr>`;
        }

        const simWatts = tWatts * SIMULTANEITY_FACTOR;
        const amps = simWatts / VOLTAGE;

        pTotalW.textContent = formatNumber(tWatts) + ' W';
        pSimW.textContent = formatNumber(Math.round(simWatts)) + ' W';
        pAmps.textContent = amps.toFixed(2) + ' A';
        pTotalKwh.textContent = formatNumber(tKwh, 1) + ' kWh/mo';
        pTotalCost.textContent = '$ ' + formatNumber(Math.round(tCost)) + ' ARS';

        if (pBreaker && breakerText) pBreaker.textContent = breakerText.textContent || '';
        if (pRcd && rcdText) pRcd.textContent = rcdText.textContent || '';
        if (pStatusDesc && statusDesc) pStatusDesc.innerHTML = statusDesc.innerHTML || '';

        if (pDate) {
          const today = new Date();
          pDate.textContent = today.toLocaleDateString('en-US') + ' ' + today.toLocaleTimeString('en-US');
        }

        document.body.classList.add('printing-elec');
        window.print();
        window.addEventListener('afterprint', () => document.body.classList.remove('printing-elec'), { once: true });
      });
    }

    calculateElectrical();
  });
</script>
