<script>
  document.addEventListener('DOMContentLoaded', () => {
    // DOM Elements
    const labelRed = document.getElementById('label-gas-red');
    const labelEnvasado = document.getElementById('label-gas-envasado');
    const radioRed = document.querySelector('input[name="tipo-gas"][value="red"]');
    const radioEnvasado = document.querySelector('input[name="tipo-gas"][value="envasado"]');
    
    const checkPilotos = document.getElementById('gas-incluir-pilotos') as HTMLInputElement;
    const qtyInputs = document.querySelectorAll('.gas-qty');
    const btnMinus = document.querySelectorAll('.gas-minus');
    const btnPlus = document.querySelectorAll('.gas-plus');
    const sliders = document.querySelectorAll('.gas-slider');

    const resKcal = document.getElementById('gas-res-kcal');
    const resCaudal = document.getElementById('gas-res-caudal');
    const resCaudalUnit = document.getElementById('gas-res-caudal-unit');
    const resMensual = document.getElementById('gas-res-mensual');
    const resMensualUnit = document.getElementById('gas-res-mensual-unit');
    const resEquivGlp = document.getElementById('gas-res-equivalente-glp');
    const resCosto = document.getElementById('gas-res-costo');
    const resCostoDesc = document.getElementById('gas-res-costo-desc');
    const resCo2 = document.getElementById('gas-res-co2');
    
    const regulatorAlert = document.getElementById('gas-regulator-alert');
    const regulatorText = document.getElementById('gas-regulator-text');
    const regulatorDesc = document.getElementById('gas-regulator-desc');
    const btnPrint = document.getElementById('gas-btn-print');

    // New safety and sizing elements
    const checkCalefonDefect = document.getElementById('gas-calefon-evac-defect') as HTMLInputElement;
    const checkTermoDefect = document.getElementById('gas-termo-evac-defect') as HTMLInputElement;

    const resRejillaInf = document.getElementById('gas-res-rejilla-inf');
    const resRejillaInfDim = document.getElementById('gas-res-rejilla-inf-dim');
    const resRejillaSup = document.getElementById('gas-res-rejilla-sup');
    const resRejillaSupDim = document.getElementById('gas-res-rejilla-sup-dim');
    const resPotAbierta = document.getElementById('gas-res-pot-abierta');

    const coAlert = document.getElementById('gas-co-alert');
    const coBadge = document.getElementById('gas-co-badge');
    const coText = document.getElementById('gas-co-text');


    let tipoGas = 'red'; // 'red' or 'envasado'

    // Shared variables for gas print report and calculation
    let potenciaAbierta = 0;
    let rejillaArea = 0;
    let rejillaDimension = 'No requirement';
    let coStatus = 'SAFE';
    let coColor = '#2ed573';
    let coBg = 'rgba(46, 213, 115, 0.08)';
    let coMessage = 'Installation does not contain high-risk (unvented) appliances. Keep standard ventilation active.';

    function formatNumber(num: number, decimals: number = 0): string {
      return num.toLocaleString('en-US', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
    }

    // Toggle Suministro
    if (labelRed && labelEnvasado && radioRed && radioEnvasado) {
      labelRed.addEventListener('click', () => {
        labelRed.classList.add('active');
        labelEnvasado.classList.remove('active');
        (radioRed as HTMLInputElement).checked = true;
        tipoGas = 'red';
        calculateGas();
      });

      labelEnvasado.addEventListener('click', () => {
        labelEnvasado.classList.add('active');
        labelRed.classList.remove('active');
        (radioEnvasado as HTMLInputElement).checked = true;
        tipoGas = 'envasado';
        calculateGas();
      });
    }

    // Quantities +/-
    btnMinus.forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-target');
        if (!id) return;
        const input = document.getElementById(id) as HTMLInputElement;
        if (input && parseInt(input.value) > 0) {
          input.value = (parseInt(input.value) - 1).toString();
          toggleSliderVisibility(id, parseInt(input.value));
          calculateGas();
        }
      });
    });

    btnPlus.forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-target');
        if (!id) return;
        const input = document.getElementById(id) as HTMLInputElement;
        if (input && parseInt(input.value) < 99) {
          input.value = (parseInt(input.value) + 1).toString();
          toggleSliderVisibility(id, parseInt(input.value));
          calculateGas();
        }
      });
    });

    qtyInputs.forEach(input => {
      input.addEventListener('input', () => {
        const target = input as HTMLInputElement;
        if (parseInt(target.value) < 0) target.value = '0';
        toggleSliderVisibility(target.id, parseInt(target.value) || 0);
        calculateGas();
      });
    });

    // Sliders
    sliders.forEach(slider => {
      slider.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        const displayId = target.id.replace('-hours', '-display');
        const display = document.getElementById(displayId);
        if (display) {
          display.textContent = parseFloat(target.value).toFixed(1);
        }
        calculateGas();
      });
    });

    // Checkbox Pilotos and Evacuación
    if (checkPilotos) {
      checkPilotos.addEventListener('change', calculateGas);
    }
    if (checkCalefonDefect) {
      checkCalefonDefect.addEventListener('change', calculateGas);
    }
    if (checkTermoDefect) {
      checkTermoDefect.addEventListener('change', calculateGas);
    }

    function toggleSliderVisibility(id: string, qty: number) {
      const item = document.querySelector(`.gas-appliance-item[data-id="${id}"]`);
      if (!item) return;
      const sliderContainer = item.querySelector('.gas-app-slider-container');
      if (sliderContainer) {
        if (qty > 0) {
          sliderContainer.classList.add('active');
        } else {
          sliderContainer.classList.remove('active');
        }
      }
    }

    // Mathematical Logic
    function calculateGas() {
      let totalKcal = 0;
      let totalKcalMes = 0;
      let qtyPilotosCount = 0;
      potenciaAbierta = 0;

      const qtyCalefon = parseInt((document.getElementById('gas-calefon') as HTMLInputElement)?.value || '0');
      const qtyTermo = parseInt((document.getElementById('gas-termo') as HTMLInputElement)?.value || '0');
      const qtyEstufaSS = parseInt((document.getElementById('gas-estufa-ss') as HTMLInputElement)?.value || '0');

      const items = document.querySelectorAll('.gas-appliance-item');
      items.forEach(item => {
        const id = item.getAttribute('data-id') || '';
        const kcal = parseFloat(item.getAttribute('data-kcal') || '0');
        const qtyInput = document.getElementById(id) as HTMLInputElement;
        const qty = parseInt(qtyInput?.value || '0');

        if (qty > 0) {
          totalKcal += qty * kcal;
          
          const hoursSlider = document.getElementById(`${id}-hours`) as HTMLInputElement;
          const hours = parseFloat(hoursSlider?.value || '0');
          
          totalKcalMes += qty * kcal * hours * 30;
          qtyPilotosCount += qty;

          // Open-chamber classification for NAG-200 ventilation
          if (id !== 'gas-tb-chico' && id !== 'gas-tb-med' && id !== 'gas-tb-grn') {
            potenciaAbierta += qty * kcal;
          }
        }
      });

      // Pilot Flame
      if (checkPilotos && checkPilotos.checked && qtyPilotosCount > 0) {
        const kcalPiloto = 150;
        // Pilot lights run 24 hours a day
        totalKcal += qtyPilotosCount * kcalPiloto;
        totalKcalMes += qtyPilotosCount * kcalPiloto * 24 * 30;
      }

      // Ventilation grille sizing calculation (NAG-200)
      rejillaArea = 0;
      rejillaDimension = 'No requirement';

      if (potenciaAbierta > 0) {
        if (potenciaAbierta <= 10000) {
          rejillaArea = 100;
          rejillaDimension = '15x15 cm / 6x6" (commercial)';
        } else if (potenciaAbierta <= 20000) {
          rejillaArea = 150;
          rejillaDimension = '15x30 cm / 6x12" or 20x20 cm / 8x8"';
        } else {
          // 8 cm2 per 1,000 kcal/h
          rejillaArea = Math.round((potenciaAbierta / 1000) * 8);
          // Suggest commercial sizes based on free area
          if (rejillaArea <= 200) {
            rejillaDimension = '20x20 cm / 8x8" or 20x30 cm / 8x12"';
          } else if (rejillaArea <= 300) {
            rejillaDimension = '20x30 cm / 8x12" (2 u.) or 30x30 cm / 12x12"';
          } else {
            rejillaDimension = 'Special dimension / Consult installer';
          }
        }
      }

      // Update ventilation UI
      if (resRejillaInf) resRejillaInf.textContent = potenciaAbierta > 0 ? rejillaArea.toString() : '0';
      if (resRejillaInfDim) resRejillaInfDim.textContent = potenciaAbierta > 0 ? `(${rejillaDimension})` : '-';
      if (resRejillaSup) resRejillaSup.textContent = potenciaAbierta > 0 ? rejillaArea.toString() : '0';
      if (resRejillaSupDim) resRejillaSupDim.textContent = potenciaAbierta > 0 ? `(${rejillaDimension})` : '-';
      if (resPotAbierta) resPotAbierta.textContent = formatNumber(potenciaAbierta);

      // Carbon Monoxide (CO) Safety Logic and Risk Assessment
      coStatus = 'SAFE';
      coColor = '#2ed573';
      coBg = 'rgba(46, 213, 115, 0.08)';
      coMessage = 'Installation does not contain high-risk (unvented) appliances. Keep standard ventilation active.';

      const hasDefect = (qtyCalefon > 0 && checkCalefonDefect?.checked) || (qtyTermo > 0 && checkTermoDefect?.checked);
      const hasEstufaSS = qtyEstufaSS > 0;

      if (hasDefect || hasEstufaSS) {
        coStatus = 'CRITICAL HAZARD';
        coColor = '#ff4757';
        coBg = 'rgba(255, 71, 87, 0.08)';
        if (hasEstufaSS && !hasDefect) {
          coMessage = '⚠️ Unvented Space Heater active. Prohibited in bedrooms and bathrooms. Requires a 100 cm² lower air inlet and periodic burner checks.';
        } else if (hasDefect && !hasEstufaSS) {
          coMessage = '⚠️ Defective/obstructed hot water flue venting. Extreme risk of Carbon Monoxide (CO) poisoning. Turn off the appliance and contact a certified gas fitter immediately.';
        } else {
          coMessage = '⚠️ Unvented heater and defective hot water flue detected. Extreme CO poisoning risk. Ventilate the room immediately and shut off all gas appliances.';
        }
      } else if (potenciaAbierta > 0) {
        coStatus = 'WARNING';
        coColor = '#FFA500';
        coBg = 'rgba(255, 165, 0, 0.08)';
        coMessage = 'Open-chamber appliances are active. Permanent lower/upper safety grilles (NAG-200) are required by code to ensure constant air renewal.';
      }

      if (coAlert && coBadge && coText) {
        coAlert.style.background = coBg;
        coAlert.style.borderLeftColor = coColor;
        coBadge.style.background = coColor;
        coBadge.textContent = coStatus;
        coText.innerHTML = coMessage;
      }

      // Sizing & Consumption based on Gas Type
      let caudalMax = 0;
      let consumoMensual = 0;
      let co2 = 0;
      let costoMensual = 0;
      let descCosto = '';

      // Reference rates in Argentina as of June 2026
      const COSTO_M3_RED = 361.63;     // Average residential rate per m3 (Camuzzi R1)
      const CARGO_FIJO_RED = 13034.97; // Average monthly fixed fee residential Camuzzi R1
      const PRECIO_GARRAFA_10 = 25000; // Average deregulated 10kg cylinder price
      const PRECIO_TUBO_45 = 100000;   // Average 45kg tank price

      if (tipoGas === 'red') {
        caudalMax = totalKcal / 9300;
        consumoMensual = totalKcalMes / 9300;
        co2 = consumoMensual * 1.9; // 1.9 kg CO2 per m3 of natural gas
        
        costoMensual = consumoMensual > 0 ? CARGO_FIJO_RED + (consumoMensual * COSTO_M3_RED) : 0;
        descCosto = `Includes $${formatNumber(Math.round(CARGO_FIJO_RED))} fixed fee and $${formatNumber(Math.round(COSTO_M3_RED))}/m³ variable (Approx. Camuzzi R1).`;
        
        if (resCaudalUnit) resCaudalUnit.textContent = 'm³/h';
        if (resMensualUnit) resMensualUnit.textContent = 'm³';
        if (resEquivGlp) resEquivGlp.style.display = 'none';
      } else {
        caudalMax = totalKcal / 11000;
        consumoMensual = totalKcalMes / 11000;
        co2 = consumoMensual * 3.0; // 3.0 kg CO2 per kg of LPG
        
        if (consumoMensual === 0) {
          costoMensual = 0;
          descCosto = 'No consumption selected.';
        } else {
          const garrafasNeeded = Math.ceil(consumoMensual / 10);
          const costoGarrafas = garrafasNeeded * PRECIO_GARRAFA_10;
          const tubosNeeded = Math.ceil(consumoMensual / 45);
          const costoTubos = tubosNeeded * PRECIO_TUBO_45;

          if (consumoMensual <= 20) {
            costoMensual = costoGarrafas;
            descCosto = `Recommended: 10kg cylinders ($${formatNumber(costoGarrafas)} for ${garrafasNeeded} u.). Alternative in 45kg cylinders: $${formatNumber(costoTubos)} (${tubosNeeded} u.).`;
          } else {
            costoMensual = costoTubos;
            descCosto = `Recommended: 45kg cylinders ($${formatNumber(costoTubos)} for ${tubosNeeded} u.). Alternative in 10kg cylinders: $${formatNumber(costoGarrafas)} (${garrafasNeeded} u.).`;
          }
        }
        
        if (resCaudalUnit) resCaudalUnit.textContent = 'kg/h';
        if (resMensualUnit) resMensualUnit.textContent = 'kg';
        
        if (resEquivGlp) {
          resEquivGlp.style.display = 'block';
          const garrafas = consumoMensual / 10;
          const tubos = consumoMensual / 45;
          resEquivGlp.innerHTML = `Equivalent to <strong>${garrafas.toFixed(1)}</strong> 10kg cylinders or <strong>${tubos.toFixed(1)}</strong> 45kg tanks per month.`;
        }
      }

      // Update basic UI
      if (resKcal) resKcal.textContent = formatNumber(totalKcal);
      if (resCaudal) resCaudal.textContent = formatNumber(caudalMax, 2);
      if (resMensual) resMensual.textContent = formatNumber(consumoMensual, 1);
      if (resCosto) resCosto.textContent = formatNumber(Math.round(costoMensual));
      if (resCostoDesc) resCostoDesc.textContent = descCosto;
      if (resCo2) resCo2.textContent = formatNumber(co2, 1);

      // Pressure Regulator Sizing recommendation
      if (!regulatorAlert || !regulatorText || !regulatorDesc) return;

      if (totalKcal === 0) {
        regulatorText.textContent = 'No consumption';
        regulatorDesc.innerHTML = 'Add appliances to suggest the regulatory pressure regulator.';
        return;
      }

      if (tipoGas === 'red') {
        if (caudalMax <= 6) {
          regulatorText.textContent = 'Standard 6 m³/h Regulator';
          regulatorDesc.innerHTML = '<strong>Fitter\'s advice:</strong> Ideal model for standard domestic use (e.g. Cooker + Water Heater + 1 Heater). Requires approved 40x60x30 cm external regulatory box on the municipal line.';
        } else if (caudalMax <= 10) {
          regulatorText.textContent = 'Reinforced 10 m³/h Regulator';
          regulatorDesc.innerHTML = '<strong>Fitter\'s advice:</strong> Ideal for medium-to-large residential loads (Boiler + Cooker + Storage Heater + Space Heaters). Requires homologated cabinet and a double-stage safety regulator.';
        } else if (caudalMax <= 25) {
          regulatorText.textContent = 'Commercial 25 m³/h Regulator';
          regulatorDesc.innerHTML = '<strong>Fitter\'s advice:</strong> Suitable for multi-family complexes, small buildings, or commercial units with high flow demands. Meter manifold and fast shutoff valve advised.';
        } else if (caudalMax <= 50) {
          regulatorText.textContent = 'Semi-Industrial 50 m³/h Regulator';
          regulatorDesc.innerHTML = '<strong>Fitter\'s advice:</strong> For small factories or larger buildings. Requires installation in a regulatory cabinet with cross ventilation grilles and a pilot-operated regulator.';
        } else {
          regulatorText.textContent = 'Specialized Regulating & Metering Cabin (> 50 m³/h)';
          regulatorDesc.innerHTML = '<strong>Fitter\'s advice:</strong> Very high gas flow. Requires technical blueprints signed by a Mechanical Engineer and Certified Gas Fitter from N3i for utility approval (e.g. Camuzzi).';
        }
      } else {
        // Bottled LPG
        if (caudalMax <= 2) {
          regulatorText.textContent = 'Single Cylinder Regulator (2 kg/h)';
          regulatorDesc.innerHTML = '<strong>Fitter\'s advice:</strong> Standard single-stage regulator with screw-on threads, suitable for one 10kg or 15kg cylinder. Recommended only for simple setups (e.g. Cooker only).';
        } else if (caudalMax <= 4) {
          regulatorText.textContent = '4 kg/h Regulator with Double Cylinder Manifold (45kg Tubo)';
          regulatorDesc.innerHTML = '<strong>Fitter\'s advice:</strong> Regulatory manifold for 2 x 45kg cylinders with 4 kg/h regulator and automatic changeover valve (allows swapping empty cylinders without outage). Mandatory for water heaters or boilers.';
        } else if (caudalMax <= 8) {
          regulatorText.textContent = '8 kg/h Regulator for 4-Cylinder Manifold or Small Zeppelin';
          regulatorDesc.innerHTML = '<strong>Fitter\'s advice:</strong> Manifold layout for 4 x 45kg cylinders (2 duty / 2 standby) or a small bulk tank (Zeppelin). Guarantees stable pressure when boiler/heaters kick in.';
        } else if (caudalMax <= 12) {
          regulatorText.textContent = 'High Capacity Regulator (12 kg/h) for Zeppelin';
          regulatorDesc.innerHTML = '<strong>Fitter\'s advice:</strong> Recommended installation fed by a bulk propane storage tank (Zeppelin / Chancha). Offers maximum autonomy and pressure stability.';
        } else {
          regulatorText.textContent = 'Industrial Dual-Stage LPG Regulator (> 12 kg/h)';
          regulatorDesc.innerHTML = '<strong>Fitter\'s advice:</strong> High industrial load. Requires first-stage pressure regulator at the LPG tank and second-stage regulators at the gas inlet of each commercial machine.';
        }
      }
    }

    // Print functionality
    if (btnPrint) {
      btnPrint.addEventListener('click', () => {
        calculateGas();

        const tbody = document.getElementById('gas-print-tbody');
        const pDate = document.getElementById('gas-print-date');
        const pTipo = document.getElementById('gas-print-tipo');
        const pTotalKcal = document.getElementById('gas-print-total-kcal');
        const pCaudal = document.getElementById('gas-print-caudal');
        const pMensual = document.getElementById('gas-print-mensual');
        const pRegulador = document.getElementById('gas-print-regulador');
        const pReguladorDesc = document.getElementById('gas-print-regulador-desc');
        
        const pRejillaInf = document.getElementById('gas-print-rejilla-inf');
        const pRejillaInfDim = document.getElementById('gas-print-rejilla-inf-dim');
        const pRejillaSup = document.getElementById('gas-print-rejilla-sup');
        const pRejillaSupDim = document.getElementById('gas-print-rejilla-sup-dim');
        const pPotAbierta = document.getElementById('gas-print-pot-abierta');
        const pCoSection = document.getElementById('gas-print-co-section');
        const pCoTitle = document.getElementById('gas-print-co-title');
        const pCoStatus = document.getElementById('gas-print-co-status');
        const pCoDesc = document.getElementById('gas-print-co-desc');

        if (!tbody || !pTotalKcal || !pCaudal) return;

        // Clear table
        tbody.innerHTML = '';
        
        const items = document.querySelectorAll('.gas-appliance-item');
        items.forEach(item => {
          const id = item.getAttribute('data-id') || '';
          const kcal = parseFloat(item.getAttribute('data-kcal') || '0');
          const qtyInput = document.getElementById(id) as HTMLInputElement;
          const qty = parseInt(qtyInput?.value || '0');

          if (qty > 0) {
            const name = item.querySelector('.gas-app-name')?.textContent || 'Appliance';
            const hoursSlider = document.getElementById(`${id}-hours`) as HTMLInputElement;
            const hours = parseFloat(hoursSlider?.value || '0');
            const subtotalKcal = qty * kcal;

            const tr = document.createElement('tr');
            tr.innerHTML = `
              <td>${qty}</td>
              <td>${name}</td>
              <td>${formatNumber(kcal)} kcal/h</td>
              <td>${hours.toFixed(1)} hrs/day</td>
              <td>${formatNumber(subtotalKcal)} kcal/h</td>
            `;
            tbody.appendChild(tr);
          }
        });

        // Add pilots in report
        if (checkPilotos && checkPilotos.checked) {
          let qtyPilotos = 0;
          qtyInputs.forEach(input => {
            qtyPilotos += parseInt((input as HTMLInputElement).value) || 0;
          });

          if (qtyPilotos > 0) {
            const tr = document.createElement('tr');
            tr.innerHTML = `
              <td>${qtyPilotos}</td>
              <td>Permanent pilot flames active</td>
              <td>150 kcal/h</td>
              <td>24.0 hrs/day</td>
              <td>${formatNumber(qtyPilotos * 150)} kcal/h</td>
            `;
            tbody.appendChild(tr);
          }
        }

        if (tbody.innerHTML === '') {
          tbody.innerHTML = `<tr><td colspan="5" style="text-align:center;">No appliances selected</td></tr>`;
        }

        // Header details
        if (pTipo) pTipo.textContent = tipoGas === 'red' ? 'Natural Gas - Utility (9,300 kcal/m³)' : 'Bottled Propane - LPG (11,000 kcal/kg)';
        if (pTotalKcal && resKcal) pTotalKcal.textContent = resKcal.textContent + ' kcal/h';
        
        if (pCaudal && resCaudal && resCaudalUnit) {
          pCaudal.textContent = resCaudal.textContent + ' ' + resCaudalUnit.textContent;
        }

        if (pMensual && resMensual && resMensualUnit) {
          let text = resMensual.textContent + ' ' + resMensualUnit.textContent;
          if (tipoGas === 'envasado' && resEquivGlp) {
            text += ` (${resEquivGlp.textContent})`;
          }
          pMensual.textContent = text;
        }

        const pCosto = document.getElementById('gas-print-costo');
        if (pCosto && resCosto) {
          pCosto.textContent = '$ ' + resCosto.textContent + ' ARS';
        }

        if (pRegulador && regulatorText) pRegulador.textContent = regulatorText.textContent;
        if (pReguladorDesc && regulatorDesc) pReguladorDesc.innerHTML = regulatorDesc.innerHTML;

        if (pRejillaInf) pRejillaInf.textContent = potenciaAbierta > 0 ? `${rejillaArea} cm²` : '0 cm²';
        if (pRejillaInfDim) pRejillaInfDim.textContent = potenciaAbierta > 0 ? rejillaDimension : 'No requirement';
        if (pRejillaSup) pRejillaSup.textContent = potenciaAbierta > 0 ? `${rejillaArea} cm²` : '0 cm²';
        if (pRejillaSupDim) pRejillaSupDim.textContent = potenciaAbierta > 0 ? rejillaDimension : 'No requirement';
        if (pPotAbierta) pPotAbierta.textContent = formatNumber(potenciaAbierta);

        if (pCoSection && pCoTitle && pCoStatus && pCoDesc) {
          pCoStatus.textContent = coStatus;
          pCoDesc.innerHTML = coMessage;
          pCoStatus.style.color = coColor;
          pCoTitle.style.color = coColor;
          pCoSection.style.borderColor = coColor;
          pCoSection.style.background = coBg.replace('0.08', '0.05'); // soft color for print
        }

        if (pDate) {
          const today = new Date();
          pDate.textContent = today.toLocaleDateString('en-US') + ' ' + today.toLocaleTimeString('en-US');
        }

        // Trigger print
        document.body.classList.add('printing-gas');
        window.print();
        window.addEventListener('afterprint', () => document.body.classList.remove('printing-gas'), { once: true });
      });
    }

    // Initial calculation
    calculateGas();
  });
</script>
