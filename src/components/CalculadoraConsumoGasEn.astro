---
// src/components/CalculadoraConsumoGasEn.astro
// Gas Consumption Simulator and Pressure Regulator Sizing (Aesthetic Orange/Gas Theme - English Version)
---

<section class="section section-alt" id="calc-consumo-gas">
  <div class="container">
    <div class="section-header reveal" style="margin: 0 auto 50px auto; text-align: center;">
      <span class="section-subtitle">Gas Engineering / NAG-200</span>
      <h2 class="section-title">Gas Consumption Simulator</h2>
      <p class="section-desc">
        Estimate your monthly gas consumption, size the regulatory pressure regulator for your installation, and receive professional technical safety recommendations.
      </p>
    </div>

    <!-- Main Gas Type Selector -->
    <div class="gas-type-selector card reveal" style="margin-bottom: 30px; text-align: center; max-width: 600px; margin-left: auto; margin-right: auto; padding: 20px;">
      <h3 style="font-size: 1.2rem; margin-bottom: 15px; color: var(--text-primary);">Select Your Gas Supply Type</h3>
      <div class="gas-toggle-group">
        <label class="gas-toggle-label active" id="label-gas-red">
          <input type="radio" name="tipo-gas" value="red" checked style="display:none;" />
          🔥 Natural Gas (Utility Network)
        </label>
        <label class="gas-toggle-label" id="label-gas-envasado">
          <input type="radio" name="tipo-gas" value="envasado" style="display:none;" />
          📦 Bottled LPG (Propane/Cylinders)
        </label>
      </div>
    </div>

    <div class="calculator-grid">
      <!-- Input Form (Gas Appliances) -->
      <div class="calc-appliances card reveal">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; flex-wrap: wrap; gap: 10px;">
          <h3 style="margin: 0;">Appliances & Usage Hours</h3>
          <label class="pilot-checkbox-wrapper">
            <input type="checkbox" id="gas-incluir-pilotos" />
            <span>Include pilot lights (150 kcal/h each, 24/7)</span>
          </label>
        </div>
        <p style="margin-bottom: 20px; font-size: 0.9rem; color: var(--text-light);">
          Indicate the quantity of each appliance and the estimated average hours they are used per day.
        </p>

        <div class="gas-appliances-list">
          <!-- Cooker -->
          <div class="gas-appliance-item" data-id="gas-cocina" data-kcal="8000">
            <div class="gas-app-main">
              <div class="gas-app-info">
                <span class="gas-app-icon">🍳</span>
                <div>
                  <span class="gas-app-name">Standard Cooker (4 Burners & Oven)</span>
                  <span class="gas-app-kcal">8,000 kcal/h</span>
                </div>
              </div>
              <div class="app-controls">
                <button type="button" class="btn-qty gas-minus" data-target="gas-cocina">-</button>
                <input type="number" class="qty-input gas-qty" id="gas-cocina" value="1" min="0" max="99" />
                <button type="button" class="btn-qty gas-plus" data-target="gas-cocina">+</button>
              </div>
            </div>
            <div class="gas-app-slider-container active">
              <div class="gas-slider-header">
                <span>Daily usage time:</span>
                <strong class="gas-hours-display"><span id="gas-cocina-display">1.5</span> hrs</strong>
              </div>
              <input type="range" class="gas-slider" id="gas-cocina-hours" min="0.5" max="24" step="0.5" value="1.5" />
            </div>
          </div>

          <!-- Cooktop -->
          <div class="gas-appliance-item" data-id="gas-anafe" data-kcal="5000">
            <div class="gas-app-main">
              <div class="gas-app-info">
                <span class="gas-app-icon">🔥</span>
                <div>
                  <span class="gas-app-name">Built-in Cooktop (4 Burners)</span>
                  <span class="gas-app-kcal">5,000 kcal/h</span>
                </div>
              </div>
              <div class="app-controls">
                <button type="button" class="btn-qty gas-minus" data-target="gas-anafe">-</button>
                <input type="number" class="qty-input gas-qty" id="gas-anafe" value="0" min="0" max="99" />
                <button type="button" class="btn-qty gas-plus" data-target="gas-anafe">+</button>
              </div>
            </div>
            <div class="gas-app-slider-container">
              <div class="gas-slider-header">
                <span>Daily usage time:</span>
                <strong class="gas-hours-display"><span id="gas-anafe-display">1.0</span> hrs</strong>
              </div>
              <input type="range" class="gas-slider" id="gas-anafe-hours" min="0.5" max="24" step="0.5" value="1.0" />
            </div>
          </div>

          <!-- Oven -->
          <div class="gas-appliance-item" data-id="gas-horno" data-kcal="3000">
            <div class="gas-app-main">
              <div class="gas-app-info">
                <span class="gas-app-icon">🍕</span>
                <div>
                  <span class="gas-app-name">Built-in Gas Oven</span>
                  <span class="gas-app-kcal">3,000 kcal/h</span>
                </div>
              </div>
              <div class="app-controls">
                <button type="button" class="btn-qty gas-minus" data-target="gas-horno">-</button>
                <input type="number" class="qty-input gas-qty" id="gas-horno" value="0" min="0" max="99" />
                <button type="button" class="btn-qty gas-plus" data-target="gas-horno">+</button>
              </div>
            </div>
            <div class="gas-app-slider-container">
              <div class="gas-slider-header">
                <span>Daily usage time:</span>
                <strong class="gas-hours-display"><span id="gas-horno-display">1.0</span> hrs</strong>
              </div>
              <input type="range" class="gas-slider" id="gas-horno-hours" min="0.5" max="24" step="0.5" value="1.0" />
            </div>
          </div>

          <!-- Tankless Water Heater -->
          <div class="gas-appliance-item" data-id="gas-calefon" data-kcal="20000">
            <div class="gas-app-main">
              <div class="gas-app-info">
                <span class="gas-app-icon">🚿</span>
                <div>
                  <span class="gas-app-name">Tankless Water Heater (14 L/min)</span>
                  <span class="gas-app-kcal">20,000 kcal/h</span>
                </div>
              </div>
              <div class="app-controls">
                <button type="button" class="btn-qty gas-minus" data-target="gas-calefon">-</button>
                <input type="number" class="qty-input gas-qty" id="gas-calefon" value="0" min="0" max="99" />
                <button type="button" class="btn-qty gas-plus" data-target="gas-calefon">+</button>
              </div>
            </div>
            <div class="gas-app-slider-container">
              <div class="gas-slider-header">
                <span>Daily usage time:</span>
                <strong class="gas-hours-display"><span id="gas-calefon-display">1.0</span> hrs</strong>
              </div>
              <input type="range" class="gas-slider" id="gas-calefon-hours" min="0.5" max="24" step="0.5" value="1.0" />
              <label class="pilot-checkbox-wrapper" style="margin-top: 8px; display: flex; text-align: left; align-items: flex-start; gap: 6px;">
                <input type="checkbox" id="gas-calefon-evac-defect" style="margin-top: 2px;" />
                <span style="font-size: 0.8rem; color: #ff9800; line-height: 1.2;">Defective/missing flue duct (no compliant outdoor venting)</span>
              </label>
            </div>
          </div>

          <!-- Storage Water Heater -->
          <div class="gas-appliance-item" data-id="gas-termo" data-kcal="6000">
            <div class="gas-app-main">
              <div class="gas-app-info">
                <span class="gas-app-icon">🌡️</span>
                <div>
                  <span class="gas-app-name">Storage Water Heater (50 - 120 Liters)</span>
                  <span class="gas-app-kcal">6,000 kcal/h</span>
                </div>
              </div>
              <div class="app-controls">
                <button type="button" class="btn-qty gas-minus" data-target="gas-termo">-</button>
                <input type="number" class="qty-input gas-qty" id="gas-termo" value="0" min="0" max="99" />
                <button type="button" class="btn-qty gas-plus" data-target="gas-termo">+</button>
              </div>
            </div>
            <div class="gas-app-slider-container">
              <div class="gas-slider-header">
                <span>Daily burner active time (estimated):</span>
                <strong class="gas-hours-display"><span id="gas-termo-display">2.0</span> hrs</strong>
              </div>
              <input type="range" class="gas-slider" id="gas-termo-hours" min="0.5" max="24" step="0.5" value="2.0" />
              <label class="pilot-checkbox-wrapper" style="margin-top: 8px; display: flex; text-align: left; align-items: flex-start; gap: 6px;">
                <input type="checkbox" id="gas-termo-evac-defect" style="margin-top: 2px;" />
                <span style="font-size: 0.8rem; color: #ff9800; line-height: 1.2;">Defective/missing flue duct (no compliant outdoor venting)</span>
              </label>
            </div>
          </div>

          <!-- Boiler -->
          <div class="gas-appliance-item" data-id="gas-caldera" data-kcal="24000">
            <div class="gas-app-main">
              <div class="gas-app-info">
                <span class="gas-app-icon">📟</span>
                <div>
                  <span class="gas-app-name">Combi Boiler (Heating + Sanitary Hot Water)</span>
                  <span class="gas-app-kcal">24,000 kcal/h</span>
                </div>
              </div>
              <div class="app-controls">
                <button type="button" class="btn-qty gas-minus" data-target="gas-caldera">-</button>
                <input type="number" class="qty-input gas-qty" id="gas-caldera" value="0" min="0" max="99" />
                <button type="button" class="btn-qty gas-plus" data-target="gas-caldera">+</button>
              </div>
            </div>
            <div class="gas-app-slider-container">
              <div class="gas-slider-header">
                <span>Daily usage time:</span>
                <strong class="gas-hours-display"><span id="gas-caldera-display">4.0</span> hrs</strong>
              </div>
              <input type="range" class="gas-slider" id="gas-caldera-hours" min="0.5" max="24" step="0.5" value="4.0" />
            </div>
          </div>

          <!-- Small Flue Space Heater -->
          <div class="gas-appliance-item" data-id="gas-tb-chico" data-kcal="2000">
            <div class="gas-app-main">
              <div class="gas-app-info">
                <span class="gas-app-icon">🧱</span>
                <div>
                  <span class="gas-app-name">Balanced Flue Space Heater (Small - 2000 kcal/h)</span>
                  <span class="gas-app-kcal">2,000 kcal/h</span>
                </div>
              </div>
              <div class="app-controls">
                <button type="button" class="btn-qty gas-minus" data-target="gas-tb-chico">-</button>
                <input type="number" class="qty-input gas-qty" id="gas-tb-chico" value="0" min="0" max="99" />
                <button type="button" class="btn-qty gas-plus" data-target="gas-tb-chico">+</button>
              </div>
            </div>
            <div class="gas-app-slider-container">
              <div class="gas-slider-header">
                <span>Daily usage time:</span>
                <strong class="gas-hours-display"><span id="gas-tb-chico-display">6.0</span> hrs</strong>
              </div>
              <input type="range" class="gas-slider" id="gas-tb-chico-hours" min="0.5" max="24" step="0.5" value="6.0" />
            </div>
          </div>

          <!-- Medium Flue Space Heater -->
          <div class="gas-appliance-item" data-id="gas-tb-med" data-kcal="3000">
            <div class="gas-app-main">
              <div class="gas-app-info">
                <span class="gas-app-icon">🏡</span>
                <div>
                  <span class="gas-app-name">Balanced Flue Space Heater (Medium - 3000 kcal/h)</span>
                  <span class="gas-app-kcal">3,000 kcal/h</span>
                </div>
              </div>
              <div class="app-controls">
                <button type="button" class="btn-qty gas-minus" data-target="gas-tb-med">-</button>
                <input type="number" class="qty-input gas-qty" id="gas-tb-med" value="0" min="0" max="99" />
                <button type="button" class="btn-qty gas-plus" data-target="gas-tb-med">+</button>
              </div>
            </div>
            <div class="gas-app-slider-container">
              <div class="gas-slider-header">
                <span>Daily usage time:</span>
                <strong class="gas-hours-display"><span id="gas-tb-med-display">6.0</span> hrs</strong>
              </div>
              <input type="range" class="gas-slider" id="gas-tb-med-hours" min="0.5" max="24" step="0.5" value="6.0" />
            </div>
          </div>

          <!-- Large Flue Space Heater -->
          <div class="gas-appliance-item" data-id="gas-tb-grn" data-kcal="5000">
            <div class="gas-app-main">
              <div class="gas-app-info">
                <span class="gas-app-icon">🛋️</span>
                <div>
                  <span class="gas-app-name">Balanced Flue Space Heater (Large - 5000 kcal/h)</span>
                  <span class="gas-app-kcal">5,000 kcal/h</span>
                </div>
              </div>
              <div class="app-controls">
                <button type="button" class="btn-qty gas-minus" data-target="gas-tb-grn">-</button>
                <input type="number" class="qty-input gas-qty" id="gas-tb-grn" value="0" min="0" max="99" />
                <button type="button" class="btn-qty gas-plus" data-target="gas-tb-grn">+</button>
              </div>
            </div>
            <div class="gas-app-slider-container">
              <div class="gas-slider-header">
                <span>Daily usage time:</span>
                <strong class="gas-hours-display"><span id="gas-tb-grn-display">6.0</span> hrs</strong>
              </div>
              <input type="range" class="gas-slider" id="gas-tb-grn-hours" min="0.5" max="24" step="0.5" value="6.0" />
            </div>
          </div>

          <!-- Vent-free Heater -->
          <div class="gas-appliance-item" data-id="gas-estufa-ss" data-kcal="3000">
            <div class="gas-app-main">
              <div class="gas-app-info">
                <span class="gas-app-icon">⚠️</span>
                <div>
                  <span class="gas-app-name">Vent-Free Space Heater (Infrared / Catalytic)</span>
                  <span class="gas-app-kcal">3,000 kcal/h</span>
                </div>
              </div>
              <div class="app-controls">
                <button type="button" class="btn-qty gas-minus" data-target="gas-estufa-ss">-</button>
                <input type="number" class="qty-input gas-qty" id="gas-estufa-ss" value="0" min="0" max="99" />
                <button type="button" class="btn-qty gas-plus" data-target="gas-estufa-ss">+</button>
              </div>
            </div>
            <div class="gas-app-slider-container">
              <div class="gas-slider-header">
                <span>Daily usage time:</span>
                <strong class="gas-hours-display"><span id="gas-estufa-ss-display">4.0</span> hrs</strong>
              </div>
              <input type="range" class="gas-slider" id="gas-estufa-ss-hours" min="0.5" max="24" step="0.5" value="4.0" />
            </div>
          </div>
        </div>
      </div>

      <!-- Results Panel -->
      <div class="calc-results card reveal" style="transition-delay: 0.1s;">
        <div class="results-sticky">
          <h3 style="color: #FF7A00; border-bottom: 1px solid rgba(255,122,0,0.15); padding-bottom: 10px; margin-bottom: 20px;">
            Installation Diagnosis
          </h3>

          <div class="result-box">
            <span class="result-label">Total Installed Thermal Load</span>
            <div class="result-value" style="color: var(--text-primary);"><span id="gas-res-kcal">8,000</span> <span style="font-size:1.1rem; font-weight:600;">kcal/h</span></div>
          </div>

          <!-- Max Caudal -->
          <div class="result-box">
            <span class="result-label">Maximum Flow Rate Required (100% Simultaneity)</span>
            <div class="result-value" style="color: var(--text-primary);"><span id="gas-res-caudal">0.86</span> <span style="font-size:1.1rem; font-weight:600;" id="gas-res-caudal-unit">m³/h</span></div>
            <span class="result-note" style="display:block; margin-top:5px; font-size:0.75rem;">Required to size gas pipes and regulator.</span>
          </div>

          <!-- Monthly consumption -->
          <div class="result-box gas-primary-result">
            <span class="result-label" style="color: #FF7A00;">Estimated Monthly Consumption</span>
            <div class="result-value" style="color: #FF7A00;"><span id="gas-res-mensual">38.7</span> <span style="font-size:1.1rem; font-weight:800;" id="gas-res-mensual-unit">m³</span></div>
            <span class="result-note" id="gas-res-equivalente-glp" style="font-size: 0.8rem; color: var(--text-light); margin-top:5px; display:block;"></span>
          </div>

          <!-- Estimated Monthly Cost -->
          <div class="result-box gas-primary-result" style="border-color: #ff9800; background: rgba(255, 152, 0, 0.12);">
            <span class="result-label" style="color: #ff9800;">Estimated Monthly Cost (ARS)</span>
            <div class="result-value" style="color: #ff9800;">$ <span id="gas-res-costo">0</span></div>
            <span class="result-note" id="gas-res-costo-desc" style="font-size: 0.75rem; color: var(--text-light); margin-top:5px; display:block;"></span>
          </div>


          <!-- Carbon footprint -->
          <div class="result-box">
            <span class="result-label">Estimated Monthly CO₂ Emissions</span>
            <div class="result-value" style="color: #FF7A00; font-size: 1.6rem;"><span id="gas-res-co2">73.5</span> <span style="font-size:1rem; font-weight:600;">kg CO₂/mo</span></div>
          </div>

          <!-- Mandatory Ventilation NAG-200 -->
          <div class="result-box" style="border: 1px solid rgba(255, 122, 0, 0.2); background: rgba(255, 122, 0, 0.03); padding: 15px; border-radius: 8px; margin-bottom: 15px;">
            <span class="result-label" style="color: #FF7A00; font-weight: 700; display: flex; align-items: center; gap: 5px; font-size: 0.9rem;">
              💨 Mandatory Ventilation (NAG-200)
            </span>
            <div style="margin-top: 10px; display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
              <div style="border-right: 1px solid rgba(255, 255, 255, 0.05); padding-right: 5px;">
                <span class="result-note" style="display: block; font-size: 0.72rem; color: var(--text-light); margin-bottom: 2px;">Lower Grille (Air Intake)</span>
                <span style="font-size: 1.1rem; font-weight: 700; color: var(--text-primary);"><span id="gas-res-rejilla-inf">100</span> <span style="font-size: 0.75rem; font-weight: 600;">cm²</span></span>
                <span id="gas-res-rejilla-inf-dim" style="display: block; font-size: 0.72rem; color: var(--text-secondary); margin-top: 2px;">(15x15 cm / 6x6")</span>
              </div>
              <div style="padding-left: 5px;">
                <span class="result-note" style="display: block; font-size: 0.72rem; color: var(--text-light); margin-bottom: 2px;">Upper Grille (Outlet)</span>
                <span style="font-size: 1.1rem; font-weight: 700; color: var(--text-primary);"><span id="gas-res-rejilla-sup">100</span> <span style="font-size: 0.75rem; font-weight: 600;">cm²</span></span>
                <span id="gas-res-rejilla-sup-dim" style="display: block; font-size: 0.72rem; color: var(--text-secondary); margin-top: 2px;">(15x15 cm / 6x6")</span>
              </div>
            </div>
            <span class="result-note" style="display:block; margin-top:10px; font-size:0.72rem; color: var(--text-light); border-top: 1px solid rgba(255, 255, 255, 0.05); padding-top: 6px;">
              Based on <strong id="gas-res-pot-abierta" style="color: #FF7A00;">8,000</strong> kcal/h open chamber load.
            </span>
          </div>

          <!-- Carbon Monoxide (CO) Safety Alert -->
          <div class="result-alert" id="gas-co-alert" style="background: rgba(46, 213, 115, 0.08); border-left: 4px solid #2ed573; transition: var(--transition-smooth); margin-bottom: 15px; padding: 12px; border-radius: 4px;">
            <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 5px;">
              <strong style="font-size: 0.85rem; color: var(--text-primary);">CO Risk Level:</strong>
              <span id="gas-co-badge" style="padding: 2px 6px; border-radius: 3px; font-size: 0.7rem; font-weight: 700; background: #2ed573; color: #000000; text-transform: uppercase; letter-spacing: 0.5px;">Safe</span>
            </div>
            <p id="gas-co-text" style="font-size: 0.78rem; margin-top: 8px; line-height: 1.4; color: var(--text-secondary);">
              Installation does not contain high-risk (unvented) appliances. Keep standard ventilation active.
            </p>
          </div>

          <!-- Regulator recommendation -->
          <div class="result-alert" id="gas-regulator-alert" style="background: rgba(255, 122, 0, 0.1); border-left-color: #FF7A00;">
            <strong style="color: #FF7A00; font-size: 0.95rem;">Suggested Pressure Regulator (NAG-200):</strong>
            <span id="gas-regulator-text" style="font-weight: 700; color: var(--text-primary); display:block; margin-top:5px; font-size:1.1rem;"></span>
            <p id="gas-regulator-desc" style="font-size: 0.82rem; margin-top: 10px; line-height: 1.4; color: var(--text-secondary);"></p>
          </div>

          <div class="disclaimer" style="margin-bottom: 20px;">
            <p><strong>⚠️ Fitter's Warning:</strong> All work on gas piping, gas lines, or pressure regulators must be executed exclusively by a **certified gas fitter**. Proper ventilation grilles are mandatory by law to prevent carbon monoxide poisoning.</p>
          </div>

          <a href="/en#contacto" class="btn btn-primary" style="width: 100%; justify-content: center; background: #FF7A00; box-shadow: 0 4px 15px rgba(255, 122, 0, 0.3); color: #000000;">
            Request Technical Review
            <span class="btn-icon">➔</span>
          </a>

          <button id="gas-btn-print" class="btn btn-outline" style="width: 100%; justify-content: center; margin-top: 10px; border-color: #FF7A00; color: var(--text-primary); background: transparent;">
            Print Report (PDF)
            <span class="btn-icon" style="background: transparent;">🖨️</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Gas Efficiency Tips Section -->
    <div class="card reveal" style="margin-top: 40px; border-top: 3px solid #FF7A00;">
      <h3 style="color: #FF7A00; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; font-size: 1.4rem;">
        <span>💡</span> Professional Tips to Save Gas
      </h3>
      <div class="gas-tips-grid">
        <div class="gas-tip-card">
          <div class="gas-tip-icon">🔥</div>
          <div>
            <h4 class="gas-tip-title">Clean Blue Flames</h4>
            <p class="gas-tip-desc">Keep burners clean. If the flame is yellow or orange, it indicates poor combustion (produces toxic CO and consumes up to 30% more gas). Schedule annual cleaning.</p>
          </div>
        </div>
        <div class="gas-tip-card">
          <div class="gas-tip-icon">🚿</div>
          <div>
            <h4 class="gas-tip-title">Adjust Water Temp Directly</h4>
            <p class="gas-tip-desc">Set your water heater thermostat directly to a comfortable shower temp. Avoid mixing super hot water with cold in the shower, which wastes gas.</p>
          </div>
        </div>
        <div class="gas-tip-card">
          <div class="gas-tip-icon">🚪</div>
          <div>
            <h4 class="gas-tip-title">Turn Off Pilot Lights</h4>
