---
// src/components/CalculadoraFrigoriasEn.astro
// AC Capacity & Advanced Thermal Balance Calculator N3i (Teal Theme) - English Version
---
<section class="section section-alt" id="calc-frigorias">
  <div class="container">
    <div class="section-header reveal" style="margin: 0 auto 50px auto; text-align: center;">
      <span class="section-subtitle" style="color: #00bcd4;">Thermal Engineering & HVAC</span>
      <h2 class="section-title">Thermal Load & AC Capacity Calculator</h2>
      <p class="section-desc">
        Perform a professional thermal balance for your space. Calculate the required capacity for summer cooling and winter heating, and compare the power bills of a standard unit versus an Inverter.
      </p>
    </div>

    <div class="calculator-grid">
      <!-- User Input Form (Structural & Internal Data) -->
      <div class="calc-appliances card reveal">
        <h3 style="color: #00bcd4; border-bottom: 1px solid rgba(0, 188, 212, 0.15); padding-bottom: 10px; margin-bottom: 20px;">
          Room Dimensions & Characteristics
        </h3>
        
        <!-- Physical Dimensions -->
        <h4 style="font-size: 0.95rem; margin-bottom: 12px; color: var(--text-primary);">1. Room Dimensions</h4>
        <div class="form-group-grid">
          <div class="form-group">
            <label>Length (meters)</label>
            <input type="number" id="frig-largo" class="calc-input" value="4.0" min="1" step="0.5" />
          </div>
          <div class="form-group">
            <label>Width (meters)</label>
            <input type="number" id="frig-ancho" class="calc-input" value="4.0" min="1" step="0.5" />
          </div>
          <div class="form-group">
            <label>Height (meters)</label>
            <input type="number" id="frig-alto" class="calc-input" value="2.8" min="2" step="0.1" />
          </div>
        </div>

        <!-- Structural Characteristics -->
        <h4 style="font-size: 0.95rem; margin-top: 10px; margin-bottom: 12px; color: var(--text-primary);">2. Construction & Environment</h4>
        <div class="form-group">
          <label>Room Type</label>
          <select id="frig-ambiente" class="calc-select">
            <option value="50">Bedroom / Living Room / Lounge (50 fg/m³)</option>
            <option value="65">Kitchen / Dining Area (Higher load from cooking & fridge - 65 fg/m³)</option>
            <option value="55">Office / Classroom / Commercial Space (55 fg/m³)</option>
          </select>
        </div>

        <div class="form-group-grid">
          <div class="form-group">
            <label>Window Orientation</label>
            <select id="frig-orientacion" class="calc-select">
              <option value="1.0">Normal / Mixed</option>
              <option value="1.15">North or West (Heavy afternoon sun exposure)</option>
              <option value="0.95">South or East (Cooler, morning sun exposure)</option>
            </select>
          </div>
          <div class="form-group">
            <label>Window Glazing</label>
            <select id="frig-ventanas" class="calc-select">
              <option value="1.10">Single Pane (Standard Window)</option>
              <option value="0.90">Double Glazed / Thermopane (DVH)</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label>Roof Exposure (Direct Solar Heat Gain)</label>
          <select id="frig-techo" class="calc-select">
            <option value="1.0">Intermediate Ceiling / Ground Floor (Protected by floor above)</option>
            <option value="1.08">Top Floor with thermally insulated ceiling</option>
            <option value="1.22">Top Floor / Roof slab or metal sheets without insulation</option>
          </select>
        </div>

        <!-- Internal Heat Sources -->
        <h4 style="font-size: 0.95rem; margin-top: 10px; margin-bottom: 12px; color: var(--text-primary);">3. Internal Heat Sources (Sensible Loads)</h4>
        <div class="form-group-grid">
          <div class="form-group">
            <label>Occupants (People)</label>
            <input type="number" id="frig-personas" class="calc-input" value="2" min="1" step="1" />
          </div>
          <div class="form-group">
            <label>Computers / Laptops</label>
            <input type="number" id="frig-pcs" class="calc-input" value="0" min="0" step="1" />
          </div>
          <div class="form-group">
            <label>TVs / Gaming Consoles</label>
            <input type="number" id="frig-tvs" class="calc-input" value="0" min="0" step="1" />
          </div>
        </div>
      </div>

      <!-- Results Panel & Electricity Rates -->
      <div class="calc-results card reveal" style="transition-delay: 0.1s;">
        <div class="results-sticky">
          
          <!-- Energy Rate Input -->
          <div style="background: rgba(255, 255, 255, 0.02); border: 1px solid var(--border-color); padding: 12px 15px; border-radius: 8px; margin-bottom: 15px;">
            <label for="frig-cost-kwh" style="display: block; font-size: 0.8rem; color: var(--text-secondary); font-weight: 600; margin-bottom: 5px;">Reference Utility Rate ($/kWh):</label>
            <input type="number" id="frig-cost-kwh" class="calc-input" value="115" min="1" style="padding: 8px 12px; font-size: 0.9rem;" />
          </div>

          <h3 style="font-size: 1.15rem; margin-bottom: 15px; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 8px;">
            Thermal Balance Results
          </h3>

          <div class="kpi-grid-two">
            <div class="result-box" style="padding: 10px;">
              <span class="result-label" style="font-size: 0.72rem;">Room Volume</span>
              <div class="result-value" style="font-size: 1.35rem;"><span id="frig-volumen">44.8</span> m³</div>
            </div>
            <div class="result-box" style="padding: 10px; border-left: 2px solid #ff9800;">
              <span class="result-label" style="font-size: 0.72rem; color: #ff9800;">Winter Heating</span>
              <div class="result-value" style="font-size: 1.35rem; color: #ff9800;"><span id="frig-res-calefaccion">0</span> <span style="font-size: 0.72rem;">BTU/h</span></div>
            </div>
          </div>

          <!-- Principal Cooling Result -->
          <div class="result-box primary-result" style="border-color: #00bcd4; background: rgba(0, 188, 212, 0.08); margin-top: 12px;">
            <span class="result-label" style="color: #00bcd4;">Required Cooling Capacity</span>
            <div class="result-value" style="color: #00bcd4; font-size: 2.1rem;"><span id="frig-resultado-btu">11816</span> <span style="font-size: 1.1rem; font-weight: 800;">BTU/h</span></div>
            <span class="result-note" style="display: block; margin-top: 3px; font-size: 0.75rem;">Equals <span id="frig-resultado-fg">2954</span> Frigorías | <span id="frig-res-watts-termico">3435</span> W thermal</span>
          </div>

          <!-- Commercial Recommended Unit -->
          <div class="result-alert" id="frig-alert" style="background: rgba(0, 188, 212, 0.08); border-left: 4px solid #00bcd4; margin-top: 12px; padding: 12px 15px; font-size: 0.85rem; line-height: 1.4;">
            <strong>Suggested Commercial Sizing:</strong>
            <span id="frig-equipo" style="color: #00bcd4; font-weight: 800; display: block; margin-top: 3px; font-size: 1rem;">12,000 BTU/h (3000 fg)</span>
            <p style="font-size: 0.78rem; margin-top: 5px; color: var(--text-secondary);">Correct commercial sizing prevents compressor damage caused by continuous duty cycle overload.</p>
          </div>

          <!-- Inverter Savings Simulator -->
          <div style="background: rgba(63, 198, 180, 0.05); border: 1px solid rgba(63, 198, 180, 0.25); border-radius: 8px; padding: 15px; margin-top: 15px;" id="frig-inverter-card">
            <h4 style="color: #3fc6b4; font-size: 0.85rem; margin-bottom: 10px; display: flex; align-items: center; gap: 6px; font-family: var(--font-title);">
              <span>⚡</span> N3i Inverter Savings Simulator
            </h4>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 12px;">
              <div style="background: rgba(0,0,0,0.15); padding: 8px; border-radius: 6px; text-align: center;">
                <span style="font-size: 0.65rem; color: var(--text-muted); display: block; text-transform: uppercase;">Standard (On/Off)</span>
                <span style="font-size: 1rem; font-weight: bold; color: var(--text-primary);">$ <span id="frig-cost-onoff">0</span></span>
                <span style="font-size: 0.62rem; color: var(--text-muted); display: block;"><span id="frig-kwh-onoff">0</span> kWh/mo</span>
              </div>
              <div style="background: rgba(63, 198, 180, 0.15); padding: 8px; border-radius: 6px; text-align: center; border: 1px solid rgba(63, 198, 180, 0.2);">
                <span style="font-size: 0.65rem; color: #3fc6b4; display: block; text-transform: uppercase; font-weight: 700;">Inverter Tech</span>
                <span style="font-size: 1rem; font-weight: bold; color: #3fc6b4;">$ <span id="frig-cost-inverter">0</span></span>
                <span style="font-size: 0.62rem; color: #3fc6b4; display: block; font-weight: 600;"><span id="frig-kwh-inverter">0</span> kWh/mo</span>
              </div>
            </div>
            <div style="font-size: 0.75rem; color: var(--text-secondary); line-height: 1.45;">
              🟢 Estimated annual savings (4 mos heavy use): <strong style="color: #3fc6b4;">$ <span id="frig-ahorro-anual">0</span></strong>
              <br>
              ⏱️ Inverter price premium payback period: <strong style="color: #3fc6b4;"><span id="frig-amortizacion">0</span> active months</strong>.
            </div>
          </div>

          <div style="margin-top: 15px; display: flex; flex-direction: column; gap: 8px;">
            <a href="/en#contacto" class="btn btn-primary" style="width: 100%; justify-content: center; background: #00bcd4; color: #000; box-shadow: 0 4px 15px rgba(0, 188, 212, 0.3);">
              Request Professional Install
              <span class="btn-icon">❄️</span>
            </a>
            <button type="button" id="frig-btn-print" class="btn btn-outline" style="width: 100%; justify-content: center; border-color: #00bcd4; color: var(--text-primary); background: transparent;">
              Print Thermal Balance
              <span class="btn-icon" style="background: transparent;">🖨️</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- HVAC Engineering Best Practices -->
    <div class="card reveal" style="margin-top: 40px; border-top: 3px solid #00bcd4;">
      <h3 style="color: #00bcd4; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; font-size: 1.3rem;">
        <span>💡</span> HVAC Technician Tips for Peak Performance
      </h3>
      <div class="gas-tips-grid">
        <div class="gas-tip-card">
          <div class="gas-tip-icon" style="color: #00bcd4;">❄️</div>
          <div>
            <h4 class="gas-tip-title">Mandatory Vacuum Pump Purge</h4>
            <p class="gas-tip-desc">During installation, always require the technician to purge lines with a vacuum pump, not by blowing refrigerant gas. Moisture in lines oxidizes the compressor and cuts its lifespan by 50%.</p>
          </div>
        </div>
        <div class="gas-tip-card">
          <div class="gas-tip-icon" style="color: #00bcd4;">🌬️</div>
          <div>
            <h4 class="gas-tip-title">Mounting Height & Air Clearance</h4>
            <p class="gas-tip-desc">The indoor split unit must be mounted with at least 15 cm (6 inches) of top ceiling clearance. Blocking this prevents proper air intake, causing erroneous sensor readings and premature compressor cycles.</p>
          </div>
        </div>
        <div class="gas-tip-card">
          <div class="gas-tip-icon" style="color: #00bcd4;">🌡️</div>
          <div>
            <h4 class="gas-tip-title">Wall & Roof Insulation</h4>
            <p class="gas-tip-desc">Hanging thick curtains on west-facing windows and insulating attic spaces with glass wool or cellulose can lower indoor ambient temperatures by 6°C, reducing the required cooling power of your unit.</p>
          </div>
        </div>
        <div class="gas-tip-card">
          <div class="gas-tip-icon" style="color: #00bcd4;">🔌</div>
          <div>
            <h4 class="gas-tip-title">Dedicated Circuit Breaker</h4>
            <p class="gas-tip-desc">A typical 12,000 BTU split draws up to 7 Amps continuous. It requires a dedicated 2.5 mm² line back to the main distribution panel with its own 16A breaker to prevent wall outlet overheating.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Hidden English Print Area -->
<div id="print-area-frig" class="print-only-frig">
  <div class="print-header" style="border-bottom-color: #00bcd4;">
    <img src="/assets/img/logo.webp" alt="N3i Logo" width="80" />
    <div>
      <h2 style="color: #00bcd4;">Thermal Sizing & HVAC Engineering Report</h2>
      <p>N3i Engineering & Maintenance</p>
    </div>
  </div>
  <div class="print-details">
    <p><strong>Date:</strong> <span id="frig-print-date"></span></p>
    <p><strong>Document Type:</strong> Thermal Balance Sizing Sheet (Cooling & Heating)</p>
  </div>
  
  <table class="print-table">
    <thead>
      <tr>
        <th>Constructive Parameter / Load Source</th>
        <th>Details Entered</th>
      </tr>
    </thead>
    <tbody id="frig-print-tbody">
      <!-- Populated by JS -->
    </tbody>
    <tfoot>
      <tr>
        <td style="text-align: right;"><strong>Room Volume:</strong></td>
        <td><strong id="frig-print-volumen">0 m³</strong></td>
      </tr>
      <tr>
        <td style="text-align: right; color: #ff9800;"><strong>Required Heating Load (Winter):</strong></td>
        <td><strong id="frig-print-calefaccion" style="color: #ff9800;">0 BTU/h</strong></td>
      </tr>
      <tr>
        <td style="text-align: right; color: #00bcd4;"><strong>Required Cooling Load (Summer):</strong></td>
        <td><strong id="frig-print-resultado" style="color: #00bcd4; font-size: 1.15rem;">0 BTU/h</strong></td>
      </tr>
    </tfoot>
  </table>
  
  <div style="background: rgba(0, 188, 212, 0.08); padding: 15px; border-radius: 8px; border-left: 5px solid #00bcd4; margin-bottom: 20px;">
    <h3 style="margin-top: 0; color: #00bcd4; font-size: 1.1rem;">Recommended Unit Specification</h3>
    <p style="font-size: 1.15rem; margin-bottom: 5px;"><strong>Suggested Commercial Size:</strong> <span id="frig-print-equipo" style="font-weight: 800;"></span></p>
    <p style="font-size: 0.9rem; color: #555;">Equals approximately <span id="frig-print-watts-termico"></span> Watts of cooling capacity.</p>
  </div>

  <div style="background: rgba(63, 198, 180, 0.08); padding: 15px; border-radius: 8px; border-left: 5px solid #3fc6b4; margin-bottom: 20px;" id="frig-print-inverter-info">
    <h3 style="margin-top: 0; color: #2a8f82; font-size: 1.1rem;">Inverter Sizing Economics & Energy Estimates</h3>
    <table style="width: 100%; border: none; font-size: 0.9rem; margin-top: 10px;">
      <tr>
        <td style="padding: 5px 0;">Standard (On/Off) Monthly Sizing consumption:</td>
        <td><strong id="frig-print-kwh-onoff">0 kWh</strong> ($ <span id="frig-print-cost-onoff">0</span>/mo)</td>
      </tr>
      <tr>
        <td style="padding: 5px 0;">Inverter Technology Monthly consumption:</td>
        <td><strong id="frig-print-kwh-inverter" style="color: #2a8f82;">0 kWh</strong> ($ <span id="frig-print-cost-inverter" style="color: #2a8f82;">0</span>/mo)</td>
      </tr>
      <tr style="border-top: 1px solid #ddd;">
        <td style="padding: 10px 0; font-weight: bold; color: #2a8f82;">Projected Annual Savings (4 mos heavy use):</td>
        <td style="padding: 10px 0; font-weight: bold; color: #2a8f82;">$ <span id="frig-print-ahorro-anual">0</span> ARS</td>
      </tr>
      <tr>
        <td style="padding: 5px 0; font-style: italic;">Inverter Premium Surcharges Payback Period:</td>
        <td style="font-style: italic;"><span id="frig-print-amortizacion">0</span> active months of use</td>
      </tr>
    </table>
  </div>

  <div class="print-footer">
    <p style="font-size: 0.8rem; margin-top: 15px;">* Technical Note: This thermal balance is performed based on constructive specifications provided by the client. It does not replace a definitive manual calculation for central ducted zoning. Inverter technology saves up to 35% of power by adjusting motor speed instead of cycling the compressor on and off.</p>
    <p style="font-size: 0.8rem; margin-top: 5px;">To schedule a certified professional installation, technical contact is available at <strong>www.n3i.com.ar</strong> or via WhatsApp at +54 9 291 416-8232.</p>
  </div>
</div>

<style is:global>
  .print-only-frig {
    display: none;
  }

  @media print {
    body.printing-frig .header, 
    body.printing-frig .footer, 
    body.printing-frig .section-header, 
    body.printing-frig .calculator-grid, 
    body.printing-frig .section { 
      display: none !important; 
    }
    body.printing-frig .print-only-frig {
      display: block !important;
      font-family: Arial, sans-serif;
      background: white !important;
      color: black !important;
      padding: 1.5cm;
    }
    .print-only-frig .print-header { display: flex; align-items: center; border-bottom: 2px solid #00bcd4; padding-bottom: 20px; margin-bottom: 20px; gap: 20px; }
    .print-only-frig .print-header h2 { margin: 0; font-size: 1.5rem; }
    .print-only-frig .print-table { width: 100%; border-collapse: collapse; margin-bottom: 30px; }
    .print-only-frig .print-table th, .print-only-frig .print-table td { border: 1px solid #ddd; padding: 10px; text-align: left; }
    .print-only-frig .print-table th { background-color: #f5f5f5; color: #333; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Inputs
    const iLargo = document.getElementById('frig-largo') as HTMLInputElement;
    const iAncho = document.getElementById('frig-ancho') as HTMLInputElement;
    const iAlto = document.getElementById('frig-alto') as HTMLInputElement;
    const iAmbiente = document.getElementById('frig-ambiente') as HTMLSelectElement;
    const iOrientacion = document.getElementById('frig-orientacion') as HTMLSelectElement;
    const iVentanas = document.getElementById('frig-ventanas') as HTMLSelectElement;
    const iTecho = document.getElementById('frig-techo') as HTMLSelectElement;
    
    const iPersonas = document.getElementById('frig-personas') as HTMLInputElement;
    const iPcs = document.getElementById('frig-pcs') as HTMLInputElement;
    const iTvs = document.getElementById('frig-tvs') as HTMLInputElement;

    const costKwhInput = document.getElementById('frig-cost-kwh') as HTMLInputElement;

    // Outputs UI
    const oVolumen = document.getElementById('frig-volumen');
    const oResultadoBtu = document.getElementById('frig-resultado-btu');
    const oResultadoFg = document.getElementById('frig-resultado-fg');
    const oResCalefaccion = document.getElementById('frig-res-calefaccion');
    const oResWattsTermico = document.getElementById('frig-res-watts-termico');
    const oEquipo = document.getElementById('frig-equipo');

    const oCostOnoff = document.getElementById('frig-cost-onoff');
    const oCostInverter = document.getElementById('frig-cost-inverter');
    const oKwhOnoff = document.getElementById('frig-kwh-onoff');
    const oKwhInverter = document.getElementById('frig-kwh-inverter');
    const oAhorroAnual = document.getElementById('frig-ahorro-anual');
    const oAmortizacion = document.getElementById('frig-amortizacion');

    const btnPrint = document.getElementById('frig-btn-print');

    function formatNumber(num: number, decimals: number = 0): string {
      return num.toLocaleString('en-US', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
    }

    function calculateFrigorias() {
      if (!iLargo) return;

      const largo = parseFloat(iLargo.value) || 0;
      const ancho = parseFloat(iAncho.value) || 0;
      const alto = parseFloat(iAlto.value) || 0;

      const vol = largo * ancho * alto;

      // Factors
      const factorAmbiente = parseFloat(iAmbiente.value) || 50;
      const factorOrientacion = parseFloat(iOrientacion.value) || 1.0;
      const factorVentanas = parseFloat(iVentanas.value) || 1.10;
      const factorTecho = parseFloat(iTecho.value) || 1.0;

      // Base load
      let baseFg = vol * factorAmbiente * factorOrientacion * factorVentanas * factorTecho;

      // Internal loads
      const personas = parseInt(iPersonas.value) || 0;
      const personasLoad = personas > 2 ? (personas - 2) * 150 : 0;

      const pcs = parseInt(iPcs.value) || 0;
      const pcsLoad = pcs * 150;

      const tvs = parseInt(iTvs.value) || 0;
      const tvsLoad = tvs * 80;

      // Final Cooling capacity (Frigorías/h)
      const fgFinal = Math.ceil(baseFg + personasLoad + pcsLoad + tvsLoad);
      // BTU/h conversion (1 fg = 3.968 BTU/h)
      const btuFinal = Math.ceil(fgFinal * 3.968);

      // Heating capacity (+15% winter delta)
      const caloriasFinal = Math.ceil(fgFinal * 1.15);
      const btuHeating = Math.ceil(caloriasFinal * 3.968);

      // Thermal Watts (1 fg = 1.163 W)
      const wattsTermicosCool = Math.ceil(fgFinal * 1.163);

      // Update Screen
      if (oVolumen) oVolumen.textContent = vol.toFixed(1);
      if (oResultadoBtu) oResultadoBtu.textContent = formatNumber(btuFinal);
      if (oResultadoFg) oResultadoFg.textContent = formatNumber(fgFinal);
      if (oResCalefaccion) oResCalefaccion.textContent = formatNumber(btuHeating);
      if (oResWattsTermico) oResWattsTermico.textContent = formatNumber(wattsTermicosCool);

      // Recommended commercial capacity
      let equipoSugerido = "12,000 BTU/h (3000 fg)";
      let capWattsThermal = 3500;

      if (fgFinal === 0) {
        equipoSugerido = "No load";
        capWattsThermal = 0;
      } else if (fgFinal <= 2250) {
        equipoSugerido = "9,000 BTU/h (2250 fg - 2500W)";
        capWattsThermal = 2500;
      } else if (fgFinal <= 3100) {
        equipoSugerido = "12,000 BTU/h (3000 fg - 3500W)";
        capWattsThermal = 3500;
      } else if (fgFinal <= 4600) {
        equipoSugerido = "18,000 BTU/h (4500 fg - 5200W)";
        capWattsThermal = 5200;
      } else if (fgFinal <= 6200) {
        equipoSugerido = "24,000 BTU/h (6000 fg - 7000W)";
        capWattsThermal = 7000;
      } else {
        equipoSugerido = "Multiple Splits or Central System (> 7000W)";
        capWattsThermal = wattsTermicosCool;
      }

      if (oEquipo) oEquipo.textContent = equipoSugerido;

      // Inverter savings math
      const costKwh = parseFloat(costKwhInput?.value) || 115;
      const horasUsoAlMes = 150;
      const copOnoff = 2.8;
      const copInverter = 3.6;

      const wattsElectricosOnoff = capWattsThermal > 0 ? capWattsThermal / copOnoff : 0;
      const kwhMensualOnoff = (wattsElectricosOnoff / 1000) * horasUsoAlMes * 0.75;
      const costoMensualOnoff = kwhMensualOnoff * costKwh;

      const kwhMensualInverter = kwhMensualOnoff * 0.65;
      const costoMensualInverter = kwhMensualInverter * costKwh;

      const ahorroMensual = costoMensualOnoff - costoMensualInverter;
      const ahorroAnual = ahorroMensual * 4;

      const brechaPrecioInverter = 150000;
      const mesesAmortizacion = ahorroMensual > 0 ? Math.ceil(brechaPrecioInverter / ahorroMensual) : 0;

      // Update Inverter UI
      if (oCostOnoff) oCostOnoff.textContent = formatNumber(Math.round(costoMensualOnoff));
      if (oCostInverter) oCostInverter.textContent = formatNumber(Math.round(costoMensualInverter));
      if (oKwhOnoff) oKwhOnoff.textContent = kwhMensualOnoff.toFixed(1);
      if (oKwhInverter) oKwhInverter.textContent = kwhMensualInverter.toFixed(1);
      if (oAhorroAnual) oAhorroAnual.textContent = formatNumber(Math.round(ahorroAnual));
      
      if (oAmortizacion) {
        if (ahorroMensual > 0) {
          oAmortizacion.textContent = mesesAmortizacion.toString();
        } else {
          oAmortizacion.textContent = "-";
        }
      }
    }

    const allInputs = document.querySelectorAll('#calc-frigorias input, #calc-frigorias select');
    allInputs.forEach(el => {
      el.addEventListener('input', calculateFrigorias);
    });

    calculateFrigorias();

    // Print logic
    if (btnPrint) {
      btnPrint.addEventListener('click', () => {
        calculateFrigorias();

        const tbody = document.getElementById('frig-print-tbody');
        const pDate = document.getElementById('frig-print-date');
        const pResultado = document.getElementById('frig-print-resultado');
        const pCalefaccion = document.getElementById('frig-print-calefaccion');
        const pVolumen = document.getElementById('frig-print-volumen');
        const pEquipo = document.getElementById('frig-print-equipo');
        const pWattsTermico = document.getElementById('frig-print-watts-termico');

        const pKwhOnoff = document.getElementById('frig-print-kwh-onoff');
        const pCostOnoff = document.getElementById('frig-print-cost-onoff');
        const pKwhInverter = document.getElementById('frig-print-kwh-inverter');
        const pCostInverter = document.getElementById('frig-print-cost-inverter');
        const pAhorroAnual = document.getElementById('frig-print-ahorro-anual');
        const pAmortizacion = document.getElementById('frig-print-amortizacion');
        
        if (!tbody || !pResultado || !pCalefaccion) return;

        tbody.innerHTML = '';
        
        const rows = [
          { label: 'Length x Width x Height', value: `${iLargo.value}m x ${iAncho.value}m x ${iAlto.value}m` },
          { label: 'Room Destination', value: iAmbiente.options[iAmbiente.selectedIndex].text },
          { label: 'Solar Exposure (Walls/Windows)', value: iOrientacion.options[iOrientacion.selectedIndex].text },
          { label: 'Window Insulation', value: iVentanas.options[iVentanas.selectedIndex].text },
          { label: 'Roof Exposure', value: iTecho.options[iTecho.selectedIndex].text },
          { label: 'Average Occupants', value: `${iPersonas.value} people` },
          { label: 'Computers / Laptops', value: `${iPcs.value} units` },
          { label: 'TVs / Gaming Consoles', value: `${iTvs.value} units` }
        ];

        rows.forEach(row => {
          const tr = document.createElement('tr');
          tr.innerHTML = `<td><strong>${row.label}</strong></td><td>${row.value}</td>`;
          tbody.appendChild(tr);
        });

        // Totales
        const btuCool = Math.ceil((oResultadoFg?.textContent ? parseInt(oResultadoFg.textContent.replace(/\./g, '')) : 0) * 3.968);
        const btuHeat = Math.ceil((oResCalefaccion?.textContent ? parseInt(oResCalefaccion.textContent.replace(/\./g, '')) : 0));

        if (pVolumen && oVolumen) pVolumen.textContent = oVolumen.textContent + ' m³';
        pResultado.textContent = formatNumber(btuCool) + ' BTU/h';
        pCalefaccion.textContent = formatNumber(btuHeat) + ' BTU/h';

        if (pEquipo && oEquipo) pEquipo.textContent = oEquipo.textContent || "";
        if (pWattsTermico && oResWattsTermico) pWattsTermico.textContent = oResWattsTermico.textContent || "";

        // Inverter print values
        if (pKwhOnoff && oKwhOnoff) pKwhOnoff.textContent = oKwhOnoff.textContent + ' kWh';
        if (pCostOnoff && oCostOnoff) pCostOnoff.textContent = oCostOnoff.textContent;
        if (pKwhInverter && oKwhInverter) pKwhInverter.textContent = oKwhInverter.textContent + ' kWh';
        if (pCostInverter && oCostInverter) pCostInverter.textContent = oCostInverter.textContent;
        if (pAhorroAnual && oAhorroAnual) pAhorroAnual.textContent = oAhorroAnual.textContent;
        if (pAmortizacion && oAmortizacion) pAmortizacion.textContent = oAmortizacion.textContent;

        if (pDate) {
          const today = new Date();
          pDate.textContent = today.toLocaleDateString('en-US') + ' ' + today.toLocaleTimeString('en-US');
        }

        document.body.classList.add('printing-frig');
        window.print();
        window.addEventListener('afterprint', () => document.body.classList.remove('printing-frig'), { once: true });
      });
    }
  });
</script>
